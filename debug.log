ead, int k) {\\n        if(head == null || head.next == null )\\n        {\\n            return head;\\n        }\\n        int length = 1;\\n        ListNode temp = head;\\n        while(temp.next != null)\\n        {\\n            temp = temp.next;\\n            length++;\\n        }\\n        k = k%length;\\n        if(k > 0)\\n        {\\n            ListNode temp2 = head;\\n            ListNode newHead = head.next;\\n            for(int i = 0 ; i < length-k-1; i++)\\n            {\\n                temp2 = temp2.next;\\n                newHead = newHead.next;\\n            }\\n            temp.next = head;\\n            temp2.next = null;\\n            return newHead;\\n        }\\n        return head;\\n        \\n    }\\n\\n}","compare_result":"1111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"rotate-list","has_notes":false,"flag_type":1,"frontend_id":698},{"id":1877442181,"question_id":61,"lang":"java","lang_name":"Java","time":"2\xc2\xa0months, 2\xc2\xa0weeks","timestamp":1767779738,"status":11,"status_display":"Wrong Answer","runtime":"N/A","url":"/submissions/detail/1877442181/","is_pending":"Not Pending","title":"Rotate List","memory":"N/A","code":"/**\\n * Definition for singly-linked list.\\n * public class ListNode {\\n *     int val;\\n *     ListNode next;\\n *     ListNode() {}\\n *     ListNode(int val) { this.val = val; }\\n *     ListNode(int val, ListNode next) { this.val = val; this.next = next; }\\n * }\\n */\\nclass Solution {\\n    public ListNode rotateRight(ListNode head, int k) {\\n        if(head == null || head.next == null )\\n        {\\n            return head;\\n        }\\n        int length = 1;\\n        ListNode temp = head;\\n        while(temp.next != null)\\n        {\\n            temp = temp.next;\\n            length++;\\n        }\\n        k = k%length;\\n        ListNode temp2 = head;\\n        ListNode newHead = head.next;\\n        for(int i = 0 ; i < length-k-1; i++)\\n        {\\n            temp2 = temp2.next;\\n            newHead = newHead.next;\\n        }\\n        temp2.next = null;\\n        temp.next = head;\\n        return newHead;\\n    }\\n\\n}","compare_result":"1111111010111011011101110111101101111111101101111111101111111111111111111111111111111011111111110111011111110111011010111111011111011111111111111111111111101111111111111111111111111111111111111111111111111011111111111111111111111111","title_slug":"rotate-list","has_notes":false,"flag_type":1,"frontend_id":697},{"id":1876755759,"question_id":1116,"lang":"java","lang_name":"Java","time":"2\xc2\xa0months, 2\xc2\xa0weeks","timestamp":1767720877,"status":10,"status_display":"Accepted","runtime":"8 ms","url":"/submissions/detail/1876755759/","is_pending":"Not Pending","title":"Maximum Level Sum of a Binary Tree","memory":"49.5 MB","code":"/**\\n * Definition for a binary tree node.\\n * public class TreeNode {\\n *     int val;\\n *     TreeNode left;\\n *     TreeNode right;\\n *     TreeNode() {}\\n *     TreeNode(int val) { this.val = val; }\\n *     TreeNode(int val, TreeNode left, TreeNode right) {\\n *         this.val = val;\\n *         this.left = left;\\n *         this.right = right;\\n *     }\\n * }\\n */\\nclass Solution {\\n    public int maxLevelSum(TreeNode root) {\\n        Queue<TreeNode> queue = new LinkedList<>();\\n        int level = 1;\\n        int ans = 1;\\n        int sum = root.val;\\n        queue.offer(root);\\n        while(!queue.isEmpty())\\n        {\\n            int sum1 = 0;\\n            int levelsize = queue.size();\\n            for(int i = 0 ; i < levelsize ; i++)\\n            {\\n                TreeNode node = queue.poll();\\n                sum1 += node.val;\\n                if(node.left != null)\\n                {\\n                    queue.offer(node.left);\\n                    \\n                }\\n                if(node.right != null)\\n                {\\n                    queue.offer(node.right);\\n                    \\n                }\\n            }\\n            if(sum1 > sum)\\n            {\\n                sum = sum1;\\n                ans = level;\\n            }\\n            level++;\\n        }\\n\\n        return ans;\\n        \\n    }\\n}","compare_result":"11111111111111111111111111111111111111111","title_slug":"maximum-level-sum-of-a-binary-tree","has_notes":false,"flag_type":1,"frontend_id":696},{"id":1876736076,"question_id":1116,"lang":"java","lang_name":"Java","time":"2\xc2\xa0months, 2\xc2\xa0weeks","timestamp":1767720005,"status":11,"status_display":"Wrong Answer","runtime":"N/A","url":"/submissions/detail/1876736076/","is_pending":"Not Pending","title":"Maximum Level Sum of a Binary Tree","memory":"N/A","code":"/**\\n * Definition for a binary tree node.\\n * public class TreeNode {\\n *     int val;\\n *     TreeNode left;\\n *     TreeNode right;\\n *     TreeNode() {}\\n *     TreeNode(int val) { this.val = val; }\\n *     TreeNode(int val, TreeNode left, TreeNode right) {\\n *         this.val = val;\\n *         this.left = left;\\n *         this.right = right;\\n *     }\\n * }\\n */\\nclass Solution {\\n    public int maxLevelSum(TreeNode root) {\\n        Queue<TreeNode> queue = new LinkedList<>();\\n        int level = 1;\\n        int ans = 1;\\n        int sum = root.val;\\n        queue.offer(root);\\n        while(!queue.isEmpty())\\n        {\\n            level++;\\n            int sum1 = 0;\\n            TreeNode node = queue.poll();\\n            if(node.left != null)\\n            {\\n                queue.offer(node.left);\\n                sum1 += node.left.val;\\n            }\\n            if(node.right != null)\\n            {\\n                queue.offer(node.right);\\n                sum1 += node.right.val;\\n            }\\n            if(sum1 > sum)\\n            {\\n                sum = sum1;\\n                ans = level;\\n            }\\n        }\\n\\n        return ans;\\n        \\n    }\\n}","compare_result":"11110100100000000000000000000000000000001","title_slug":"maximum-level-sum-of-a-binary-tree","has_notes":false,"flag_type":1,"frontend_id":695},{"id":1875135263,"question_id":2089,"lang":"java","lang_name":"Java","time":"2\xc2\xa0months, 3\xc2\xa0weeks","timestamp":1767606530,"status":10,"status_display":"Accepted","runtime":"9 ms","url":"/submissions/detail/1875135263/","is_pending":"Not Pending","title":"Maximum Matrix Sum","memory":"68 MB","code":"class Solution {\\n    public long maxMatrixSum(int[][] matrix) {\\n        long sum = 0;\\n        long negativeelements = 0;\\n        int zerocount=0;\\n        long smallestnegative = Long.MAX_VALUE;\\n        for(int i = 0 ; i < matrix.length ; i++)\\n        {\\n            for(int j = 0 ; j < matrix[i].length ; j++)\\n            {\\n                sum += Math.abs(matrix[i][j]);\\n                if(matrix[i][j] < 0)\\n                {\\n                    negativeelements++;\\n                }\\n                if(Math.abs(matrix[i][j]) < Math.abs(smallestnegative))\\n                {\\n                    smallestnegative = Math.abs(matrix[i][j]);\\n                }\\n            }\\n        }\\n        if(negativeelements == 0 || negativeelements%2 == 0)\\n        {\\n            return sum;\\n        }\\n        return sum-smallestnegative-smallestnegative;\\n        \\n    }\\n}","compare_result":"11111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"maximum-matrix-sum","has_notes":false,"flag_type":1,"frontend_id":694},{"id":1875133837,"question_id":2089,"lang":"java","lang_name":"Java","time":"2\xc2\xa0months, 3\xc2\xa0weeks","timestamp":1767606429,"status":10,"status_display":"Accepted","runtime":"10 ms","url":"/submissions/detail/1875133837/","is_pending":"Not Pending","title":"Maximum