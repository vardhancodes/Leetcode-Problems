title":"Most Frequent Subtree Sum","memory":"46.8 MB","code":"/**\\n * Definition for a binary tree node.\\n * public class TreeNode {\\n *     int val;\\n *     TreeNode left;\\n *     TreeNode right;\\n *     TreeNode() {}\\n *     TreeNode(int val) { this.val = val; }\\n *     TreeNode(int val, TreeNode left, TreeNode right) {\\n *         this.val = val;\\n *         this.left = left;\\n *         this.right = right;\\n *     }\\n * }\\n */\\nclass Solution {\\n    public int[] findFrequentTreeSum(TreeNode root) {\\n        HashMap<Integer,Integer> map = new HashMap<>();\\n        dfs(root, map);\\n        int max = 0;\\n        List<Integer> list = new ArrayList<>();\\n        for(Map.Entry<Integer,Integer> entry : map.entrySet())\\n        {\\n            if(entry.getValue() > max)\\n            {\\n                max = entry.getValue();\\n                list.clear();\\n            }\\n            if(entry.getValue() == max)\\n            {\\n                list.add(entry.getKey());\\n            }\\n\\n        }\\n        int ans[] = new int[list.size()];\\n        for(int i = 0 ; i < list.size() ; i++)\\n        {\\n            ans[i] = list.get(i);\\n        }\\n\\n        return ans;\\n    }\\n\\n    public static int dfs(TreeNode root, HashMap<Integer,Integer> map)\\n    {\\n        if(root == null)\\n        {\\n            return 0;\\n        }\\n\\n        int leftsum = dfs(root.left,map);\\n        int rightsum = dfs(root.right,map);\\n\\n        map.put(leftsum+rightsum+root.val, map.getOrDefault(leftsum+rightsum+root.val,0)+1);\\n\\n        return root.val+leftsum+rightsum;\\n    }\\n}","compare_result":"1111111111111111111111111111111111111111111111111111111111","title_slug":"most-frequent-subtree-sum","has_notes":false,"flag_type":1,"frontend_id":905},{"id":1929224815,"question_id":124,"lang":"java","lang_name":"Java","time":"1\xc2\xa0month","timestamp":1771908632,"status":10,"status_display":"Accepted","runtime":"1 ms","url":"/submissions/detail/1929224815/","is_pending":"Not Pending","title":"Binary Tree Maximum Path Sum","memory":"47.1 MB","code":"/**\\n * Definition for a binary tree node.\\n * public class TreeNode {\\n *     int val;\\n *     TreeNode left;\\n *     TreeNode right;\\n *     TreeNode() {}\\n *     TreeNode(int val) { this.val = val; }\\n *     TreeNode(int val, TreeNode left, TreeNode right) {\\n *         this.val = val;\\n *         this.left = left;\\n *         this.right = right;\\n *     }\\n * }\\n */\\nclass Solution {\\n    public int maxPathSum(TreeNode root) {\\n        int[] max = new int[1];\\n        max[0] = Integer.MIN_VALUE;\\n        max(root,max);\\n        return max[0];\\n\\n    }\\n\\n    public static int max(TreeNode root , int[] max)\\n    {\\n        if(root == null)\\n        {\\n            return 0;\\n        }\\n        \\n        int leftmax =  Math.max(0,max(root.left,max));\\n        int rightmax = Math.max(0,max(root.right,max));\\n        \\n        max[0] =  Math.max(max[0],leftmax+rightmax+root.val);\\n\\n        return root.val+ Math.max(leftmax,rightmax);\\n\\n\\n\\n    }\\n}","compare_result":"111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"binary-tree-maximum-path-sum","has_notes":false,"flag_type":1,"frontend_id":904},{"id":1929223199,"question_id":124,"lang":"java","lang_name":"Java","time":"1\xc2\xa0month","timestamp":1771908548,"status":11,"status_display":"Wrong Answer","runtime":"N/A","url":"/submissions/detail/1929223199/","is_pending":"Not Pending","title":"Binary Tree Maximum Path Sum","memory":"N/A","code":"/**\\n * Definition for a binary tree node.\\n * public class TreeNode {\\n *     int val;\\n *     TreeNode left;\\n *     TreeNode right;\\n *     TreeNode() {}\\n *     TreeNode(int val) { this.val = val; }\\n *     TreeNode(int val, TreeNode left, TreeNode right) {\\n *         this.val = val;\\n *         this.left = left;\\n *         this.right = right;\\n *     }\\n * }\\n */\\nclass Solution {\\n    public int maxPathSum(TreeNode root) {\\n        int[] max = new int[1];\\n        max[0] = Integer.MIN_VALUE;\\n        max(root,max);\\n        return max[0];\\n\\n    }\\n\\n    public static int max(TreeNode root , int[] max)\\n    {\\n        if(root == null)\\n        {\\n            return 0;\\n        }\\n        \\n        int leftmax =  max(root.left,max);\\n        int rightmax = max(root.right,max);\\n        \\n        max[0] =  Math.max(max[0],leftmax+rightmax+root.val);\\n\\n        return root.val+ Math.max(leftmax,rightmax);\\n\\n\\n\\n    }\\n}","compare_result":"111111011001101101111101111111001101110000110011110101010011111111110110001111011111110111111110","title_slug":"binary-tree-maximum-path-sum","has_notes":false,"flag_type":1,"frontend_id":903},{"id":1929222390,"question_id":124,"lang":"java","lang_name":"Java","time":"1\xc2\xa0month","timestamp":1771908506,"status":11,"status_display":"Wrong Answer","runtime":"N/A","url":"/submissions/detail/1929222390/","is_pending":"Not Pending","title":"Binary Tree Maximum Path Sum","memory":"N/A","code":"/**\\n * Definition for a binary tree node.\\n * public class TreeNode {\\n *     int val;\\n *     TreeNode left;\\n *     TreeNode right;\\n *     TreeNode() {}\\n *     TreeNode(int val) { this.val = val; }\\n *     TreeNode(int val, TreeNode left, TreeNode right) {\\n *         this.val = val;\\n *         this.left = left;\\n *         this.right = right;\\n *     }\\n * }\\n */\\nclass Solution {\\n    public int maxPathSum(TreeNode root) {\\n        int[] max = new int[1];\\n        max(root,max);\\n        return max[0];\\n\\n    }\\n\\n    public static int max(TreeNode root , int[] max)\\n    {\\n        if(root == null)\\n        {\\n            return 0;\\n        }\\n        \\n        int leftmax =  max(root.left,max);\\n        int rightmax = max(root.right,max);\\n        \\n        max[0] =  Math.max(max[0],leftmax+rightmax+root.val);\\n\\n        return root.val+ Math.max(leftmax,rightmax);\\n\\n\\n\\n    }\\n}","compare_result":"111101010001100101111101111111001101110000110011110101010011111111110110001111010111110111111110","title_slug":"binary-tree-maximum-path-sum","has_notes":false,"flag_type":1,"frontend_id":902},{"id":1928717815,"question_id":662,"lang":"java","lang_name":"Java","time":"1\xc2\xa0month","timestamp":1771863894,"status":10,"status_display":"Accepted","runtime":"1 ms","url":"/submissions/detail/1928717815/","is_pending":"Not Pending","title":"Maximum Width of Binary Tree","memory":"45.2 MB","code":"/**\\n * Definition for a binary tree node.\\n * public class TreeNode {\\n *     int val;\\n *     TreeNode left;\\n *     TreeNode right;\\n *     TreeNode() {}\\n *     TreeNode(int val) { this.val = val; }\\n *     TreeNode(int val, TreeNode left, TreeNode right) {\\n *         this.val = val;\\n *         this.left = left;\\n *         this.right = right;\\n *     }\\n * }\\n */\\nclass Solution {\\n    public int widthOfBinaryTree(TreeNode root) {\\n        int ans = 1;\\n        Queue<CustomNode> queue = new LinkedList<>();\\n        if(root == null)\\n        {\\n            return 0;\\n        }\\n        queue.offer(new CustomNode(root,1));\\n        while(!queue.isEmpty())\\n        {\\n            int levelsize = queue.size();\\n            int leftmost = -1;\\n            int rightmost = -1;\\n            int min = queue.peek().pos;\\n            for(int i = 0 ; i < levelsize ; i++)\\n            {\\n                CustomNode cus = queue.poll();\\n                int position = cus.pos-min;\\n                if(leftmost == -1)\\n                {\\n                    leftmost = position;\\n                }\\n                rightmost = position;\\n\\n                if(cus.node.left != null)\\n                {\\n                    queue.offer(new CustomNode(cus.node.left,2*position));\\n                }\\n                if(cus.node.right != null)\\n                {\\n                    queue.offer(new CustomNode(cus.node.right,2*position+1));\\n                }\\n            }\\n            if(leftmost != -1 && rightmost != -1 &&(leftmost != rightmost))\\n            {\\n                ans = Math.max(ans,rightmost-leftmost+1);\\n            }\\n\\n        }\\n        return ans;\\n    }\\n}\\nclass CustomNode\\n{\\n    int pos;\\n    TreeNode node;\\n    CustomNode(TreeNode node, int pos)\\n    {\\n        this.pos = pos;\\n        this.node = node;\\n    }\\n\\n}","compare_result":"111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"maximum-width-of-binary-tree","has_notes":false,"flag_type":1,"frontend_id":901},{"id":1928708199,"question_id":662,"lang":"java","lang_name":"Java","time":"1\xc2\xa0month","timestamp":1771863425,"status":11,"status_display":"Wrong Answer","runtime":"N/A","url":"/submissions/detail/1928708199/","is_pending":"Not Pending","title":"Maximum Width of Binary Tree","memory":"N/A","code":"/**\\n * Definition for a binary tree node.\\n * public class TreeNode {\\n *     int val;\\n *     TreeNode left;\\n *     TreeNode right;\\n *     TreeNode() {}\\n *     TreeNode(int val) { this.val = val; }\\n *     TreeNode(int val, TreeNode left, TreeNode right) {\\n *         this.val = val;\\n *         this.left = left;\\n *         this.right = right;\\n *     }\\n * }\\n */\\nclass Solution {\\n    public int widthOfBinaryTree(TreeNode root) {\\n        int ans = 1;\\n        Queue<CustomNode> queue = new LinkedList<>();\\n        if(root == null)\\n        {\\n            return 0;\\n        }\\n        queue.offer(new CustomNode(root,1));\\n        while(!queue.isEmpty())\\n        {\\n            int levelsize = queue.size();\\n            long leftmost = -1;\\n            long rightmost = -1;\\n            for(int i = 0 ; i < levelsize ; i++)\\n            {\\n                CustomNode cus = queue.poll();\\n                if(leftmost == -1)\\n                {\\n                    leftmost = cus.pos;\\n                }\\n                rightmost = cus.pos;\\n\\n                if(cus.node.left != null)\\n                {\\n                    queue.offer(new CustomNode(cus.node.left,2*cus.pos));\\n                }\\n                if(cus.node.right != null)\\n                {\\n                    queue.offer(new CustomNode(cus.node.right,2*cus.pos+1));\\n                }\\n            }\\n            if(leftmost != -1 && rightmost != -1 &&(leftmost != rightmost))\\n            {\\n                ans = (int)Math.max(ans,rightmost-leftmost+1);\\n            }\\n\\n        }\\n        return ans;\\n    }\\n}\\nclass CustomNode\\n{\\n    int pos;\\n    TreeNode node;\\n    CustomNode(TreeNode node, int pos)\\n    {\\n        this.pos = pos;\\n        this.node = node;\\n    }\\n\\n}","compare_result":"111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111110111111111110111110111","title_slug":"maximum-width-of-binary-tree","has_notes":false,"flag_type":1,"frontend_id":900},{"id":1928698862,"question_id":662,"lang":"java","lang_name":"Java","time":"1\xc2\xa0month","timestamp":1771862967,"status":11,"status_display":"Wrong Answer","runtime":"N/A","url":"/submissions/detail/1928698862/","is_pending":"Not Pending","title":"Maximum Width of Binary Tree","memory":"N/A","code":"/**\\n * Definition for a binary tree node.\\n * public class TreeNode {\\n *     int val;\\n *     TreeNode left;\\n *     TreeNode right;\\n *     TreeNode() {}\\n *     TreeNode(int val) { this.val = val; }\\n *     TreeNode(int val, TreeNode left, TreeNode right) {\\n *         this.val = val;\\n *         this.left = left;\\n *         this.right = right;\\n *     }\\n * }\\n */\\nclass Solution {\\n    public int widthOfBinaryTree(TreeNode root) {\\n        int ans = 0;\\n        Queue<CustomNode> queue = new LinkedList<>();\\n        if(root == null)\\n        {\\n            return ans;\\n        }\\n        queue.offer(new CustomNode(root,0));\\n        while(!queue.isEmpty())\\n        {\\n            int levelsize = queue.size();\\n            int leftmost = -1;\\n            int rightmost = -1;\\n            for(int i = 0 ; i < levelsize ; i++)\\n            {\\n                CustomNode cus = queue.poll();\\n                if(leftmost == -1)\\n                {\\n                    leftmost = cus.pos;\\n                }\\n                else\\n                {\\n                    rightmost = cus.pos;\\n                }\\n                if(cus.node.left != null)\\n                {\\n                    queue.offer(new CustomNode(cus.node.left,2*cus.pos+1));\\n                }\\n                if(cus.node.right != null)\\n                {\\n                    queue.offer(new CustomNode(cus.node.right,2*cus.pos+2));\\n                }\\n            }\\n            if(leftmost != -1 && rightmost != -1)\\n            {\\n                ans = Math.max(ans,rightmost-leftmost+1);\\n            }\\n\\n        }\\n        return ans;\\n    }\\n}\\nclass CustomNode\\n{\\n    int pos;\\n    TreeNode node;\\n    CustomNode(TreeNode node, int pos)\\n    {\\n        this.pos = pos;\\n        this.node = node;\\n    }\\n\\n}","compare_result":"111111000010000110110100100001110111110110111110110110100110110100100011100011110011111111111011111111111111111001111","title_slug":"maximum-width-of-binary-tree","has_notes":false,"flag_type":1,"frontend_id":899},{"id":1927692933,"question_id":1,"lang":"java","lang_name":"Java","time":"1\xc2\xa0month","timestamp":1771782604,"status":10,"status_display":"Accepted","runtime":"2 ms","url":"/submissions/detail/1927692933/","is_pending":"Not Pending","title":"Two Sum","memory":"47.4 MB","code":"class Solution {\\n    public int[] twoSum(int[] nums, int target) {\\n        int ans[] = new int[2];\\n        HashMap<Integer,Integer> map = new HashMap<>();\\n        for(int i = 0 ; i < nums.