de && rightside)\\n        {\\n            root.left = null;\\n        }\\n\\n        else if(!rightside && leftside)\\n        {\\n            root.right = null;\\n        }\\n\\n        sum[0] -= root.val;\\n\\n        return leftside || rightside;\\n\\n        \\n    }\\n}","compare_result":"111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"insufficient-nodes-in-root-to-leaf-paths","has_notes":false,"flag_type":1,"frontend_id":923},{"id":1934484354,"question_id":1157,"lang":"java","lang_name":"Java","time":"3\xc2\xa0weeks, 4\xc2\xa0days","timestamp":1772348241,"status":11,"status_display":"Wrong Answer","runtime":"N/A","url":"/submissions/detail/1934484354/","is_pending":"Not Pending","title":"Insufficient Nodes in Root to Leaf Paths","memory":"N/A","code":"/**\\n * Definition for a binary tree node.\\n * public class TreeNode {\\n *     int val;\\n *     TreeNode left;\\n *     TreeNode right;\\n *     TreeNode() {}\\n *     TreeNode(int val) { this.val = val; }\\n *     TreeNode(int val, TreeNode left, TreeNode right) {\\n *         this.val = val;\\n *         this.left = left;\\n *         this.right = right;\\n *     }\\n * }\\n */\\nclass Solution {\\n    public TreeNode sufficientSubset(TreeNode root, int limit) {\\n        int[] sum = new int[1];\\n        dfs(root,limit,sum);\\n        return root;\\n    }\\n\\n    public static boolean dfs(TreeNode root, int limit, int[] sum)\\n    {\\n        if(root == null)\\n        {\\n            return false;\\n        }\\n        sum[0] += root.val;\\n        if(root.left == null && root.right == null)\\n        {\\n            if(sum[0] < limit)\\n            {\\n                sum[0] -= root.val;\\n                return false;\\n            }\\n            else\\n            {\\n                sum[0] -= root.val;\\n                return true;\\n            }\\n            \\n        }\\n\\n        \\n        boolean leftside = dfs(root.left,limit,sum);\\n        boolean rightside = dfs(root.right,limit,sum);\\n\\n        \\n\\n        if(!leftside && rightside)\\n        {\\n            root.left = null;\\n        }\\n\\n        else if(!rightside && leftside)\\n        {\\n            root.right = null;\\n        }\\n\\n        sum[0] -= root.val;\\n\\n        return leftside || rightside;\\n\\n        \\n    }\\n}","compare_result":"111111111110101011111111111111111111011101100100011101100110011101110100100011010000011110110110110110001101110011101","title_slug":"insufficient-nodes-in-root-to-leaf-paths","has_notes":false,"flag_type":1,"frontend_id":922},{"id":1934453364,"question_id":1807,"lang":"java","lang_name":"Java","time":"3\xc2\xa0weeks, 4\xc2\xa0days","timestamp":1772345987,"status":10,"status_display":"Accepted","runtime":"7 ms","url":"/submissions/detail/1934453364/","is_pending":"Not Pending","title":"Partitioning Into Minimum Number Of Deci-Binary Numbers","memory":"47.3 MB","code":"class Solution {\\n    public int minPartitions(String n) {\\n        int ans = 0;\\n        int count = 0;\\n        for(int i = n.length()-1 ; i >= 0 ; i--)\\n        {\\n            int num = (int)(n.charAt(i)-\'0\');\\n            count = num/1;\\n            ans = Math.max(count,ans);\\n\\n        }\\n        return ans;\\n        \\n    }\\n}","compare_result":"1111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"partitioning-into-minimum-number-of-deci-binary-numbers","has_notes":false,"flag_type":1,"frontend_id":921},{"id":1933909789,"question_id":662,"lang":"java","lang_name":"Java","time":"3\xc2\xa0weeks, 5\xc2\xa0days","timestamp":1772297607,"status":10,"status_display":"Accepted","runtime":"1 ms","url":"/submissions/detail/1933909789/","is_pending":"Not Pending","title":"Maximum Width of Binary Tree","memory":"45.4 MB","code":"/**\\n * Definition for a binary tree node.\\n * public class TreeNode {\\n *     int val;\\n *     TreeNode left;\\n *     TreeNode right;\\n *     TreeNode() {}\\n *     TreeNode(int val) { this.val = val; }\\n *     TreeNode(int val, TreeNode left, TreeNode right) {\\n *         this.val = val;\\n *         this.left = left;\\n *         this.right = right;\\n *     }\\n * }\\n */\\nclass Solution {\\n    public int widthOfBinaryTree(TreeNode root) {\\n        int ans = 1;\\n        Queue<CustomNode> queue = new LinkedList<>();\\n        if(root == null)\\n        {\\n            return 0;\\n        }\\n        queue.offer(new CustomNode(root,1));\\n        while(!queue.isEmpty())\\n        {\\n            int levelsize = queue.size();\\n            int leftmost = -1;\\n            int rightmost = -1;\\n            int min = queue.peek().pos;\\n            for(int i = 0 ; i < levelsize ; i++)\\n            {\\n                CustomNode cus = queue.poll();\\n                int position = cus.pos-min;\\n                if(leftmost == -1)\\n                {\\n                    leftmost = position;\\n                }\\n                rightmost = position;\\n\\n                if(cus.node.left != null)\\n                {\\n                    queue.offer(new CustomNode(cus.node.left,2*position));\\n                }\\n                if(cus.node.right != null)\\n                {\\n                    queue.offer(new CustomNode(cus.node.right,2*position+1));\\n                }\\n            }\\n            if(leftmost != -1 && rightmost != -1 &&(leftmost != rightmost))\\n            {\\n                ans = Math.max(ans,rightmost-leftmost+1);\\n            }\\n\\n        }\\n        return ans;\\n    }\\n}\\nclass CustomNode\\n{\\n    int pos;\\n    TreeNode node;\\n    CustomNode(TreeNode node, int pos)\\n    {\\n        this.pos = pos;\\n        this.node = node;\\n    }\\n\\n}","compare_result":"111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"maximum-width-of-binary-tree","has_notes":false,"flag_type":1,"frontend_id":920},{"id":1932610979,"question_id":1050,"lang":"java","lang_name":"Java","time":"3\xc2\xa0weeks, 6\xc2\xa0days","timestamp":1772182307,"status":10,"status_display":"Accepted","runtime":"0 ms","url":"/submissions/detail/1932610979/","is_pending":"Not Pending","title":"Construct Binary Search Tree from Preorder Traversal","memory":"43.5 MB","code":"/**\\n * Definition for a binary tree node.\\n * public class TreeNode {\\n *     int val;\\n *     TreeNode left;\\n *     TreeNode right;\\n *     TreeNode() {}\\n *     TreeNode(int val) { this.val = val; }\\n *     TreeNode(int val, TreeNode left, TreeNode right) {\\n *         this.val = val;\\n *         this.left = left;\\n *         this.right = right;\\n *     }\\n * }\\n */\\nclass Solution {\\n    public TreeNode bstFromPreorder(int[] preorder) {\\n        int index[] = new int[1];\\n        return construct(preorder,Integer.MIN_VALUE,Integer.MAX_VALUE,index);\\n    }\\n\\n    public static TreeNode construct(int[] preorder, int min , int max, int[] index)\\n    {\\n        if(index[0] == preorder.length)\\n        {\\n            return null;\\n        }\\n\\n        if(preorder[index[0]] > max || preorder[index[0]] < min)\\n        {\\n            return null;\\n        }\\n        \\n        TreeNode root = new TreeNode(preorder[index[0]]);\\n        index[0]++;\\n        \\n        root.left = construct(preorder,min,root.val,index);\\n        root.right = construct(preorder,root.val,max,index);\\n\\n        return root;\\n\\n\\n    }\\n}","compare_result":"111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"construct-binary-search-tree-from-preorder-traversal","has_notes":false,"flag_type":1,"frontend_id":919},{"id":1932583273,"question_id":1370,"lang":"java","lang_name":"Java","time":"3\xc2\xa0weeks, 6\xc2\xa0days","timestamp":1772179835,"status":10,"status_display":"Accepted","runtime":"14 ms","url":"/submissions/detail/1932583273/","is_pending":"Not Pending","title":"Count Number of Nice Subarrays","memory":"59.8 MB","code":"class Solution {\\n    public int numberOfSubarrays(int[] nums, int k) {\\n        return atMostK(nums,k)-atMostK(nums,k-1);\\n\\n    }\\n    public static int atMostK(int[] nums, int k)\\n    {\\n        int windowStart = 0;\\n        int windowEnd = 0;\\n        int ans = 0;\\n        int count = 0;\\n        while(windowEnd < nums.length)\\n        {\\n            if(nums[windowEnd] %2 != 0)\\n            {\\n                count++;\\n            }\\n\\n            if(count > k)\\n            {\\n                while(count > k)\\n                {\\n                    if(nums[windowStart] %2 != 0)\\n                    {\\n                        count--;\\n                    }\\n                    windowStart++;\\n                }\\n            }\\n            ans += windowEnd-windowStart+1;\\n            windowEnd++;\\n        }\\n        return ans;\\n    }\\n}","compare_result":"11111111111111111111111111111111111111","title_slug":"count-number-of-nice-subarrays","has_notes":false,"flag_type":1,"frontend_id":918},{"id":1932581158,"question_id":1475,"lang":"java","lang_name":"Java","time":"3\xc2\xa0weeks, 6\xc2\xa0days","timestamp":1772179631,"status":10,"status_display":"Accepted","runtime":"5 ms","url":"/submissions/detail/1932581158/","is_pending":"Not Pending","title":"Maximum Sum BST in Binary Tree","memory":"62.6 MB","code":"/**\\n * Definition for a binary tree node.\\n * public class TreeNode {\\n *     int val;\\n *     TreeNode left;\\n *     TreeNode right;\\n *     TreeNode() {}\\n *     TreeNode(int val) { this.val = val; }\\n *     TreeNode(int val, TreeNode left, TreeNode right) {\\n *         this.val = val;\\n *         this.left = left;\\n *         this.right = right;\\n *     }\\n * }\\n */\\nclass Solution {\\n    public int maxSumBST(TreeNode root) {\\n        int max[] = new int[1];\\n        dfs(root,max);\\n        return max[0];\\n    }\\n\\n    public static int[] dfs(TreeNode root, int[] ans)\\n    {\\n        if(root == null)\\n        {\\n            return (new int[]{0,Integer.MIN_VALUE,Integer.MAX_VALUE});\\n        }\\n\\n        int[] leftsubtree = dfs(root.left,ans);\\n        int[] rightsubtree = dfs(root.right,ans);\\n\\n        if(root.val > leftsubtree[1] && root.val < rightsubtree[2])\\n        {\\n            int currSum = leftsubtree[0] + rightsubtree[0] + root.val;\\n            ans[0] = Math.max(ans[0],currSum);\\n            int min = Math.min(leftsubtree[2],root.val);\\n            int max = Math.max(rightsubtree[1],root.val);\\n\\n            return (new int[]{currSum,max,min});\\n        }\\n        return (new int[]{0,Integer.MAX_VALUE,Integer.MIN_VALUE});\\n\\n\\n\\n    }\\n}","compare_result":"111111111111111111111111111111111111111111111111111111111111","title_slug":"maximum-sum-bst-in-binary-tree","has_notes":false,"flag_type":1,"frontend_id":917},{"id":1932429801,"question_id":1370,"lang":"java","lang_name":"Java","time":"1\xc2\xa0month","timestamp":1772168388,"status":10,"status_display":"Accepted","runtime":"14 ms","url":"/submissions/detail/1932429801/","is_pending":"Not Pending","title":"Count Number of Nice Subarrays","memory":"59.8 MB","code":"class Solution {\\n    public int numberOfSubarrays(int[] nums, int k) {\\n        return atMostK(nums,k)-atMostK(nums,k-1);\\n\\n    }\\n    public static int atMostK(int[] nums, int k)\\n    {\\n        int windowStart = 0;\\n        int windowEnd = 0;\\n        int ans = 0;\\n        int count = 0;\\n        while(windowEnd < nums.length)\\n        {\\n            if(nums[windowEnd] %2 != 0)\\n            {\\n                count++;\\n            }\\n\\n            if(count > k)\\n            {\\n                while(count > k)\\n                {\\n                    if(nums[windowStart] %2 != 0)\\n                    {\\n                        count--;\\n       