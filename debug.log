ccepted","runtime":"21 ms","url":"/submissions/detail/1862467163/","is_pending":"Not Pending","title":"Binary Subarrays With Sum","memory":"52.7 MB","code":"class Solution {\\n    public int numSubarraysWithSum(int[] nums, int goal) {\\n        int ans = 0;\\n        int n = nums.length;\\n        int sum  = 0;\\n        HashMap<Integer,Integer> map = new HashMap<>();\\n        map.put(0,1);\\n        for(int i = 0 ; i < nums.length ; i++)\\n        {\\n            sum += nums[i];\\n            int rem = sum-goal;\\n            if(map.containsKey(rem))\\n            {\\n                ans += map.get(rem);\\n            }\\n            map.put(sum,map.getOrDefault(sum,0)+1);\\n        }\\n        return ans;\\n    }\\n}","compare_result":"1111111111111111111111111111111111111111111111111111111111111","title_slug":"binary-subarrays-with-sum","has_notes":false,"flag_type":1,"frontend_id":657},{"id":1862466056,"question_id":966,"lang":"java","lang_name":"Java","time":"3\xc2\xa0months","timestamp":1766413236,"status":11,"status_display":"Wrong Answer","runtime":"N/A","url":"/submissions/detail/1862466056/","is_pending":"Not Pending","title":"Binary Subarrays With Sum","memory":"N/A","code":"class Solution {\\n    public int numSubarraysWithSum(int[] nums, int goal) {\\n        int ans = 0;\\n        int n = nums.length;\\n        int sum  = 0;\\n        HashMap<Integer,Integer> map = new HashMap<>();\\n        map.put(0,1);\\n        for(int i = 0 ; i < nums.length ; i++)\\n        {\\n            sum += nums[i];\\n            int rem = goal - sum;\\n            if(map.containsKey(rem))\\n            {\\n                ans += map.get(rem);\\n            }\\n            map.put(rem,map.getOrDefault(rem,0)+1);\\n        }\\n        return ans;\\n    }\\n}","compare_result":"1100110000000000001000011001010000100000101000000000000000011","title_slug":"binary-subarrays-with-sum","has_notes":false,"flag_type":1,"frontend_id":656},{"id":1862367088,"question_id":940,"lang":"ja