 , List<String> list , String s )\\n    {\\n        if(s.length() == n*2)\\n        {\\n            if(isValid(s))\\n            {\\n                list.add(s);\\n            }\\n            return;\\n            \\n        }\\n\\n        s = s + \\"(\\";\\n        recur(n,list,s);\\n        s=s.substring(0,s.length()-1);\\n        s=s+\\")\\";\\n        recur(n,list,s);\\n    }\\n\\n    public static boolean isValid(String s)\\n    {\\n        Stack<Character> stack = new Stack<>();\\n        for(int i = 0 ; i < s.length() ; i++)\\n        {\\n            char ch = s.charAt(i);\\n            if(ch == \'(\' )\\n            {\\n                stack.push(ch);\\n            }\\n            else\\n            {\\n                if(stack.isEmpty() && ch == \')\')\\n                {\\n                    return false;\\n                }\\n                else\\n                {\\n                    stack.pop();\\n                }\\n            }\\n        }\\n\\n        return stack.isEmpty();\\n\\n    }\\n}","compare_result":"11111111","title_slug":"generate-parentheses","has_notes":false,"flag_type":1,"frontend_id":383},{"id":1792081304,"question_id":79,"lang":"java","lang_name":"Java","time":"5\xc2\xa0months, 3\xc2\xa0weeks","timestamp":1759662966,"status":10,"status_display":"Accepted","runtime":"189 ms","url":"/submissions/detail/1792081304/","is_pending":"Not Pending","title":"Word Search","memory":"44.9 MB","code":"class Solution {\\n    public boolean exist(char[][] board, String word) {\\n        int il = 0;\\n       for(int i = 0 ; i < board.length ; i++)\\n       {\\n            for(int j = 0 ; j < board[i].length ; j++)\\n            {\\n                if(board[i][j] == word.charAt(il))\\n                {\\n                    if(recur(board,word,i,j,il))\\n                    {\\n                        return true;\\n                    }\\n                }\\n            }\\n       }\\n       return false;\\n        \\n    }\\n    public static boolean recur(char[][] board , String word , int i , int j, int il)\\n    {  \\n        if( i < 0 || i >= board.length ||  j < 0 || j >= board[i].length || board[i][j] != word.charAt(il) ){\\n            return false;\\n        }\\n\\n        //basecase\\n        if(il == word.length()-1)\\n        {\\n            return true;\\n        }\\n\\n        int di[] = {1,0,0,-1};\\n        int dj[] = {0,-1,1,0};\\n        char orig = board[i][j];\\n        board[i][j] = \'0\';\\n        for(int ind = 0 ; ind < 4 ; ind++)\\n        { \\n           \\n            if(recur(board,word,i+di[ind],j+dj[ind],il+1))\\n            {\\n                board[i][j] = orig;\\n                return true;\\n            }\\n        }\\n        board[i][j] = orig;\\n        return false;\\n        \\n    }\\n}","compare_result":"1111111111111111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"word-search","has_notes":false,"flag_type":1,"frontend_id":382},{"id":1792069345,"question_id":79,"lang":"java","lang_name":"Java","time":"5\xc2\xa0months, 3\xc2\xa0weeks","timestamp":1759662018,"status":10,"status_display":"Accepted","runtime":"191 ms","url":"/submissions/detail/1792069345/","is_pending":"Not Pending","title":"Word Search","memory":"45.2 MB","code":"class Solution {\\n    public boolean exist(char[][] board, String word) {\\n        int il = 0;\\n       for(int i = 0 ; i < board.length ; i++)\\n       {\\n            for(int j = 0 ; j < board[i].length ; j++)\\n            {\\n                if(board[i][j] == word.charAt(il))\\n                {\\n                    if(recur(board,word,i,j,il))\\n                    {\\n                        return true;\\n                    }\\n                }\\n            }\\n       }\\n       return false;\\n        \\n    }\\n    public static boolean recur(char[][] board , String word , int i , int j, int il)\\n    {  \\n        if( i < 0 || i >= board.length ||  j < 0 || j >= board[i].length || board[i][j] != word.charAt(il) || board[i][j] == \'0\'){\\n            return false;\\n        }\\n\\n        //basecase\\n        if(il == word.length()-1)\\n        {\\n            return true;\\n        }\\n\\n        int di[] = {1,0,0,-1};\\n        int dj[] = {0,-1,1,0};\\n        char orig = board[i][j];\\n        board[i][j] = \'0\';\\n        for(int ind = 0 ; ind < 4 ; ind++)\\n        { \\n           \\n            if(recur(board,word,i+di[ind],j+dj[ind],il+1))\\n            {\\n                board[i][j] = orig;\\n                return true;\\n            }\\n        }\\n        board[i][j] = orig;\\n        return false;\\n        \\n    }\\n}","compare_result":"1111111111111111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"word-search","has_notes":false,"flag_type":1,"frontend_id":381},{"id":1792039832,"question_id":52,"lang":"java","lang_name":"Java","time":"5\xc2\xa0months, 3\xc2\xa0weeks","timestamp":1759659667,"status":10,"status_display":"Accepted","runtime":"12 ms","url":"/submissions/detail/1792039832/","is_pending":"Not Pending","title":"N-Queens II","memory":"42 MB","code":"class Solution {\\n    public int totalNQueens(int n) {\\n       List<List<String>> list = new ArrayList<List<String>>();\\n        List<List<String>> board = new ArrayList<List<String>>();\\n        for(int i = 0 ; i < n ; i++)\\n        {\\n            List<String> sublist = new ArrayList<String>();\\n            for(int j = 0 ; j < n ; j++)\\n            {\\n                sublist.add(\\".\\");\\n            }\\n            board.add(sublist);\\n        }\\n        recur(n,list,0,board);\\n        return list.size();\\n    }\\n    public static boolean isPossible(List<List<String>> board,int n , int i , int j)\\n    {\\n        //horizontal check\\n        for(int col = 0 ; col < j ; col++)\\n        {\\n            if(board.get(i).get(col).equals(\\"Q\\"))\\n            {\\n                return false;\\n            }\\n        }\\n        //upper diagnol\\n        for(int row = i-1 , col = j-1 ; row>=0 && col>=0 ; row-- , col--)\\n        {\\n            if(board.get(row).get(col).equals(\\"Q\\"))\\n            {\\n                return false;\\n            }\\n        }\\n        //Lower Diagnol\\n        for(int row = i+1 , col = j-1 ; row<n && col>=0 ; row++ , col--)\\n        {\\n            if(board.get(row).get(col).equals(\\"Q\\"))\\n            {\\n                return false;\\n            }\\n        }\\n        return true;\\n\\n    }\\n    public static void recur(int n , List<List<String>> list ,int j, List<List<String>> board)\\n    {\\n        if(j >= n)\\n        {\\n            List<String> sublist = new ArrayList<String>();\\n            for(int i = 0 ; i < n ; i++)\\n            {\\n                String s = \\"\\";\\n                for(int col = 0 ; col < n ; col++)\\n                {\\n                    s = s + board.get(i).get(col);\\n                }\\n                sublist.add(s);\\n            }\\n            list.add(sublist);\\n            return;\\n        }\\n\\n        for(int row = 0 ; row < n ; row++)\\n        {\\n            if(isPossible(board,n,row,j))\\n            {\\n                board.get(row).set(j,\\"Q\\");\\n                recur(n,list,j+1,board);\\n                board.get(row).set(j,\\".\\");\\n\\n            }\\n\\n        }\\n    }\\n}","compare_result":"111111111","title_slug":"n-queens-ii","has_notes":false,"flag_type":1,"frontend_id":380},{"id":1791533629,"question_id":51,"lang":"java","lang_name":"Java","time":"5\xc2\xa0months, 3\xc2\xa0weeks","timestamp":1759618610,"status":10,"status_display":"Accepted","runtime":"11 ms","url":"/submissions/detail/1791533629/","is_pending":"Not Pending","title":"N-Queens","memory":"44.8 MB","code":"class Solution {\\n    public List<List<String>> solveNQueens(int n) {\\n        List<List<String>> list = new ArrayList<List<String>>();\\n        List<List<String>> board = new ArrayList<List<S