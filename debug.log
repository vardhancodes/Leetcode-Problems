 List<Integer> sublist = new ArrayList<>();\\n            for(int i = 0 ; i < nums.length ; i++)\\n            {\\n                sublist.add(nums[i]);\\n            }\\n            list.add(sublist);\\n        }\\n\\n        for(int i = ind ; i < nums.length ; i++)\\n        {\\n            swap(nums,i,ind);\\n            recur(list,ind+1,nums);\\n            swap(nums,i,ind);\\n        }\\n    }\\n\\n    public static void swap(int[] arr, int start , int end)\\n    {\\n        int temp = arr[start];\\n        arr[start] = arr[end];\\n        arr[end] = temp;\\n    }\\n}","compare_result":"11111111111111111111111111","title_slug":"permutations","has_notes":false,"flag_type":1,"frontend_id":760},{"id":1895218716,"question_id":17,"lang":"java","lang_name":"Java","time":"2\xc2\xa0months","timestamp":1769250684,"status":10,"status_display":"Accepted","runtime":"3 ms","url":"/submissions/detail/1895218716/","is_pending":"Not Pending","title":"Letter Combinations of a Phone Number","memory":"49.1 MB","code":"class Solution {\\n    public List<String> letterCombinations(String digits) {\\n        List<String> list = new ArrayList<>();\\n        HashMap<Character,String> map = new HashMap<>();\\n        map.put(\'2\',\\"abc\\");\\n        map.put(\'3\',\\"def\\");\\n        map.put(\'4\',\\"ghi\\");\\n        map.put(\'5\',\\"jkl\\");\\n        map.put(\'6\',\\"mno\\");\\n        map.put(\'7\',\\"pqrs\\");\\n        map.put(\'8\',\\"tuv\\");\\n        map.put(\'9\',\\"wxyz\\");\\n        String ans = \\"\\";\\n        recur(list,map,0,ans,digits);\\n        return list;\\n    }\\n    public static void recur(List<String> list, HashMap<Character,String> map, int ind, String ans, String digits)\\n    {\\n        if(ans.length() == digits.length())\\n        {\\n            list.add(ans);\\n            return;\\n        }\\n        if(ind == digits.length())\\n        {\\n            return;\\n        }\\n\\n        for(int i = 0 ; i < map.get(digits.charAt(ind)).length() ; 