n            if(rem < 0)\\n            {\\n                rem = rem+k;\\n            }\\n            if(map.containsKey(rem))\\n            {\\n                ans += map.get(rem);\\n            }\\n            map.put(rem,map.getOrDefault(rem,0)+1);\\n        }\\n        return ans;\\n    }\\n}","compare_result":"1111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"subarray-sums-divisible-by-k","has_notes":false,"flag_type":1,"frontend_id":637},{"id":1836569600,"question_id":56,"lang":"java","lang_name":"Java","time":"4\xc2\xa0months","timestamp":1763798502,"status":10,"status_display":"Accepted","runtime":"9 ms","url":"/submissions/detail/1836569600/","is_pending":"Not Pending","title":"Merge Intervals","memory":"49 MB","code":"class Solution {\\n    public int[][] merge(int[][] intervals) {\\n        Arrays.sort(intervals, (a, b) -> Integer.compare(a[0], b[0]));\\n        List<List<Integer>> list = new  ArrayList<>();\\n        int start = intervals[0][0];\\n        int end = intervals[0][1];\\n        for(int i = 1; i < intervals.length ; i++)\\n        {\\n            if(end >= intervals[i][0])\\n            {\\n                end = Math.max(end,intervals[i][1]);\\n            }\\n            else\\n            {\\n                List<Integer> sublist = new ArrayList<>();\\n                sublist.add(start);\\n                sublist.add(end);\\n                list.add(sublist);\\n                start = intervals[i][0];\\n                end = intervals[i][1];\\n\\n            }\\n        }\\n        List<Integer> sublist = new ArrayList<>();\\n        sublist.add(start);\\n        sublist.add(end);\\n        list.add(sublist);\\n        int ans[][] = new int[list.size()][2];\\n        for(int i = 0 ; i < list.size() ; i++)\\n        {\\n            for(int j = 0 ; j < list.get(i).size() ; j++)\\n            {\\n                ans[i][j] = list.get(i).get(j);\\n            }\\n        }\\n\\n        return ans;\\n    }\\n}","compare_result":"1111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"merge-intervals","has_notes":false,"flag_type":1,"frontend_id":636},{"id":1836557229,"question_id":3476,"lang":"java","lang_name":"Java","time":"4\xc2\xa0months","timestamp":1763797173,"status":10,"status_display":"Accepted","runtime":"0 ms","url":"/submissions/detail/1836557229/","is_pending":"Not Pending","title":"Find Minimum Operations to Make All Elements Divisible by Three","memory":"43.5 MB","code":"class Solution {\\n    public int minimumOperations(int[] nums) {\\n        int count = 0;\\n        for(int i = 0 ; i < nums.length ; i++)\\n        {\\n            if(nums[i]%3 == 0)\\n            {\\n                continue;\\n            }\\n            else\\n            {\\n                count++;\\n            }\\n        }\\n        return count;\\n    }\\n}","compare_result":"","title_slug":"find-minimum-operations-to-make-all-elements-divisible-by-three","has_notes":false,"flag_type":1,"frontend_id":635},{"id":1835871276,"question_id":2059,"lang":"java","lang_name":"Java","time":"4\xc2\xa0months","timestamp":1763715906,"status":10,"status_display":"Accepted","runtime":"264 ms","url":"/submissions/detail/1835871276/","is_pending":"Not Pending","title":"Unique Length-3 Palindromic Subsequences","memory":"46.7 MB","code":"class Solution {\\n    public int countPalindromicSubsequence(String s) {\\n        HashMap<Character,Integer> first = new HashMap<>();\\n        // storing occurrence\\n        for(int i = 0 ; i < s.length() ; i++)\\n        {\\n            char ch = s.charAt(i);\\n            if(!first.containsKey(ch))\\n            {\\n                first.put(ch,i);\\n            }\\n        }\\n        HashMap<Character,Integer> last = new HashMap<>();\\n        for(int i = 0 ; i < s.length() ; i++)\\n        {\\n            char ch = s.charAt(i);\\n            last.put(ch,i);\\n        }\\n        int ans = 0;\\n        for(Map.Entry<Character,Integer> entry : first.entrySet())\\n        {\\n            char ch = entry.getKey();\\n            int val = entry.getValue();\\n            if((last.get(ch)-val) > 0)\\n            {\\n                HashSet<Character> set = new HashSet<>();\\n                for(int i = val+1 ; i < last.get(ch) ; i++)\\n                {\\n                    char chart = s.charAt(i);\\n                    if(!set.contains(chart))\\n                    {\\n                        set.add(chart);\\n                    }\\n                }\\n                ans+=set.size();\\n\\n            }\\n        }\\n        return ans;\\n    }\\n}","compare_result":"1111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"unique-length-3-palindromic-subsequences","has_notes":false,"flag_type":1,"frontend_id":634},{"id":1835870420,"question_id":2059,"lang":"java","lang_name":"Java","time":"4\xc2\xa0months","timestamp":1763715821,"status":10,"status_display":"Accepted","runtime":"278 ms","url":"/submissions/detail/1835870420/","is_pending":"Not Pending","title":"Unique Length-3 Palindromic Subsequences","memory":"47.3 MB","code":"class Solution {\\n    public int countPalindromicSubsequence(String s) {\\n        HashMap<Character,Integer> first = new HashMap<>();\\n        HashMap<Character,Integer> last = new HashMap<>();\\n        // storing occurrence\\n        for(int i = 0 ; i < s.length() ; i++)\\n        {\\n            last.put(s.charAt(i),i);\\n            if(!first.containsKey(s.charAt(i)))\\n            {\\n                first.put(s.charAt(i),i);\\n            }\\n        }\\n        int ans = 0;\\n        for(Map.Entry<Character,Integer> entry : first.entrySet())\\n        {\\n            char ch = entry.getKey();\\n            int val = entry.getValue()+1;\\n            HashSet<Character> set = new HashSet<>();\\n            while(val <= la