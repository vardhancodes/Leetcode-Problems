,\\".\\");\\n\\n            }\\n\\n        }\\n    }\\n}","compare_result":"111111111","title_slug":"n-queens","has_notes":false,"flag_type":1,"frontend_id":379},{"id":1791472728,"question_id":2662,"lang":"java","lang_name":"Java","time":"5\xc2\xa0months, 3\xc2\xa0weeks","timestamp":1759610594,"status":10,"status_display":"Accepted","runtime":"1 ms","url":"/submissions/detail/1791472728/","is_pending":"Not Pending","title":"Check Knight Tour Configuration","memory":"44.7 MB","code":"class Solution {\\n    public boolean checkValidGrid(int[][] grid) {\\n        if(grid[0][0] != 0)\\n        {\\n            return false;\\n        }\\n      return recur(grid,grid.length,0,0,0);\\n        \\n    }\\n    public static boolean isValid(int grid[][] , int i , int j , int n, int nextMove)\\n    {\\n        if(i < 0 || i >= n || j < 0 || j >= n || grid[i][j] != nextMove)\\n        {\\n            return false;\\n        }\\n        return true;\\n\\n    }\\n    public static boolean recur(int[][] grid , int n ,  int i , int j , int moves)\\n    {        \\n\\n        if(n*n-1 == moves)\\n        {\\n            return true;\\n        }\\n\\n        int di[] = {2,2,-2,-2,1,-1,-1,1};\\n        int dj[] = {-1,1,1,-1,2,2,-2,-2};\\n\\n        for(int ind = 0 ; ind < 8 ; ind++)\\n        {\\n            int nextI = i+di[ind];\\n            int nextJ = j+dj[ind];\\n            int nextMove = moves+1;\\n            if(isValid(grid,nextI,nextJ,n,nextMove))\\n            {\\n                if(recur(grid,n,nextI,nextJ,nextMove))\\n                {\\n                    return true;\\n                }\\n\\n            }\\n\\n        }\\n        return false;\\n    }\\n}","compare_result":"","title_slug":"check-knight-tour-configuration","has_notes":false,"flag_type":1,"frontend_id":378},{"id":1791471743,"question_id":2662,"lang":"java","lang_name":"Java","time":"5\xc2\xa0months, 3\xc2\xa0weeks","timestamp":1759610481,"status":11,"status_display":"Wrong Answer","runtime":"N/A","url":"/submissions/detail/1791471743/","is_pending":"Not Pending","title":"Check Knight Tour Configuration","memory":"N/A","code":"class Solution {\\n    public boolean checkValidGrid(int[][] grid) {\\n      return recur(grid,grid.length,0,0,0);\\n        \\n    }\\n    public static boolean isValid(int grid[][] , int i , int j , int n, int nextMove)\\n    {\\n        if(i < 0 || i >= n || j < 0 || j >= n || grid[i][j] != nextMove)\\n        {\\n            return false;\\n        }\\n        return true;\\n\\n    }\\n    public static boolean recur(int[][] grid , int n ,  int i , int j , int moves)\\n    {        \\n\\n        if(n*n-1 == moves)\\n        {\\n            return true;\\n        }\\n\\n        int di[] = {2,2,-2,-2,1,-1,-1,1};\\n        int dj[] = {-1,1,1,-1,2,2,-2,-2};\\n\\n        for(int ind = 0 ; ind < 8 ; ind++)\\n        {\\n            int nextI = i+di[ind];\\n            int nextJ = j+dj[ind];\\n            int nextMove = moves+1;\\n            if(isValid(grid,nextI,nextJ,n,nextMove))\\n            {\\n                if(recur(grid,n,nextI,nextJ,nextMove))\\n                {\\n                    return true;\\n                }\\n\\n            }\\n\\n        }\\n        return false;\\n    }\\n}","compare_result":"","title_slug":"check-knight-tour-configuration","has_notes":false,"flag_type":1,"frontend_id":377},{"id":1791409715,"question_id":200,"lang":"java","lang_name":"Java","time":"5\xc2\xa0months, 3\xc2\xa0weeks","timestamp":1759604896,"status":10,"status_display":"Accepted","runtime":"3 ms","url":"/submissions/detail/1791409715/","is_pending":"Not Pending","title":"Number of Islands","memory":"49.5 MB","code":"class Solution {\\n    public int numIslands(char[][] grid) {\\n        //checking if the current digit has land \\n        int n = grid.length;\\n        int count = 0;\\n        for(int i = 0 ; i < n ; i++)\\n        {\\n            int m = grid[i].length;\\n            for(int j = 0 ; j < m ; j++)\\n            {\\n                if(grid[i][j] == \'1\')\\n                {\\n                    recur(grid,i,j,n,m);\\n                    count++;\\n                }\\n            }\\n        }\\n        return count;\\n    }\\n\\n    public static void recur(char[][] grid, int i , int j ,int n , int m)\\n    {\\n        //deadends\\n        if(i < 0 || i >= n || j < 0 || j >= m || grid[i][j] == \'2\' || grid [i][j] == \'0\')\\n        {\\n            return;\\n        }\\n\\n        grid[i][j] = \'2\';\\n\\n        //FOUR options:\\n        //lexicographically -> D , L , R, U\\n        recur(grid,i+1,j,n,m);\\n        recur(grid,i,j-1,n,m);\\n        recur(grid,i,j+1,n,m);\\n        recur(grid,i-1,j,n,m);\\n\\n\\n\\n\\n    }\\n}","compare_result":"1111111111111111111111111111111111111111111111111","title_slug":"number-of-islands","has_notes":false,"flag_type":1,"frontend_id":376},{"id":1791409310,"question_id":200,"lang":"java","lang_name":"Java","time":"5\xc2\xa0months, 3\xc2\xa0weeks","timestamp":1759604862,"status":10,"status_display":"Accepted","runtime":"3 ms","url":"/submissions/detail/1791409310/","is_pending":"Not Pending","title":"Number of Islands","memory":"49.4 MB","code":"class Solution {\\n    public int numIslands(char[][] grid) {\\n        //checking if the current digit has land \\n        int n = grid.length;\\n        int count = 0;\\n        for(int i = 0 ; i < n ; i++)\\n        {\\n            int m = grid[i].length;\\n            for(int j = 0 ; j < m ; j++)\\n            {\\n                if(grid[i][j] == \'1\')\\n                {\\n                    recur(grid,i,j,n,m);\\n                    count++;\\n                }\\n            }\\n        }\\n        return count;\\n    }\\n\\n    public static void recur(char[][] grid, int i , int j ,int n , int m)\\n    {\\n        //deadends\\n        if(i < 0 || i >= n || j < 0 || j >= m || grid[i][j] == \'2\' || grid [i][j] == \'0\')\\n        {\\n            return;\\n        }\\n\\n        grid[i][j] = \'2\';\\n\\n        //FOUR options:\\n        //lexicographically -> D , L , R, U\\n        recur(grid,i+1,j,n,m);\\n        recur(grid,i,j-1,n,m);\\n        recur(grid,i,j+1,n,m);\\n        recur(grid,i-1,j,n,m);\\n\\n\\n\\n\\n    }\\n}","compare_result":"1111111111111111111111111111111111111111111111111","title_slug":"number-of-islands","has_notes":false,"flag_type":1,"frontend_id":375},{"id":1790864521,"question_id":11,"lang":"java","lang_name":"Java","time":"5\xc2\xa0months, 3\xc2\xa0weeks","timestamp":1759565120,"status":10,"status_display":"Accepted","runtime":"5 ms","url":"/submissions/detail/1790864521/","is_pending":"Not Pending","title":"Container With Most Water","memory":"57.2 MB","code":"class Solution {\\n    public int maxArea(int[] height) {\\n        int start = 0 ;\\n        int size = height.length;\\n        int end = size-1;\\n        int ans = 0;\\n        \\n        while(start<end)\\n        {\\n            int area = Math.min(height[start],height[end])*(end-start);\\n            ans = Math.max(ans,area);\\n            if(height[start] < height[end])\\n            {\\n                start++;\\n            }\\n            else\\n            {\\n                end--;\\n            }\\n\\n        }\\n        return ans;\\n    }\\n\\n        \\n}","compare_result":"11111111111111111111111111111111111111111111111111111111111111111","title_slug":"container-with-most-water","has_notes":false,"flag_type":1,"frontend_id":374},{"id":1790859232,"question_id":11,"lang":"java","lang_name":"Java","time":"5\xc2\xa0months, 3\xc2\xa0weeks","timestamp":1759564650,"status":10,"status_display":"Accepted","runtime":"6 ms","url":"/submissions/detail/1790859232/","is_pending":"Not Pending","title":"Container With Most Water","memory":"57.9 MB","code":"class Solution {\\n    public int maxArea(int[] height) {\\n        int start = 0 ;\\n        int size = height.length;\\n        int end = size-1;\\n        int maxarea = 0;\\n\\n        while( start < end)\\n        {\\n            int currentheight = Math.min(height[start], height[end]);\\n            int currentwidth = Math.abs(start-end);\\n            maxarea = Math.max(maxarea , currentheight * currentwidth);\\n\\n            if(height[start] < height[end])\\n            {\\n                start++;\\n            }\\n            else\\n            {\\n                end--;\\n            }\\n        }\\n\\n        return maxarea;\\n\\n    }\\n\\n        \\n}","compare_result":"11111111111111111111111111111111111111111111111111111111111111111","title_slug":"container-with-most-water","has_notes":false,"flag_type":1,"frontend_id":373},{"id":1790198201,"question_id":392,"lang":"java","lang_name":"Java","time":"5\xc2\xa0months, 3\xc2\xa0weeks","timestamp":1759499757,"status":10,"status_display":"Accepted","runtime":"2 ms","url":"/submissions/detail/1790198201/","is_pending":"Not Pending","title":"Is Subsequence","memory":"41.9 MB","code":"class Solution {\\n    public boolean isSubsequence(String s, String t) {\\n        if(s.length() == 0)\\n        {\\n            return true;\\n        }\\n        int counter = 0;\\n        for(int i = 0 ; i < t.length() ; i++)\\n        {\\n            if(t.charAt(i) == s.charAt(counter))\\n            {\\n                counter++;\\n            }\\n            if(counter == s.length())\\n            {\\n                return true;\\n            }\\n        }\\n        return false;\\n    }\\n}","compare_result":"1111111111111111111111","title_slug":"is-subsequence","has_notes":false,"flag_type":1,"frontend_id":372}],"has_next":true,"last_key":""}'
