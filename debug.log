\\n    public double findMaxAverage(int[] nums, int k) {\\n        int n = nums.length;\\n        int index = 0;\\n        int sum = 0;\\n\\n        while(index < k && index < n)\\n        {\\n            sum += nums[index];\\n            index++;\\n        }\\n        double maxSum = (double)sum;\\n\\n        for(int i = 1 ; i <= n-k ; i++)\\n        {\\n            sum = sum - nums[i-1] + nums[i+k-1];\\n            maxSum = Math.max(sum,maxSum);\\n        }\\n\\n        return maxSum/k;\\n        \\n    }\\n}","compare_result":"1111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"maximum-average-subarray-i","has_notes":false,"flag_type":1,"frontend_id":421},{"id":1797443689,"question_id":643,"lang":"java","lang_name":"Java","time":"5\xc2\xa0months, 2\xc2\xa0weeks","timestamp":1760109466,"status":10,"status_display":"Accepted","runtime":"5 ms","url":"/submissions/detail/1797443689/","is_pending":"Not Pending","title":"Maximum Average Subarray I","memory":"56.1 MB","code":"class Solution {\\n    public double findMaxAverage(int[] nums, int k) {\\n        int n = nums.length;\\n        int index = 0;\\n        int sum = 0;\\n\\n        while(index < k && index < n)\\n        {\\n            sum += nums[index];\\n            index++;\\n        }\\n        double maxAvg = (double)sum/k;\\n\\n        for(int i = 1 ; i <= n-k ; i++)\\n        {\\n            sum = sum - nums[i-1] + nums[i+k-1];\\n            double avg = (double)sum/k;\\n            maxAvg = Math.max(avg,maxAvg);\\n        }\\n\\n        return maxAvg;\\n        \\n    }\\n}","compare_result":"1111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"maximum-average-subarray-i","has_notes":false,"flag_type":1,"frontend_id":420},{"id":1796933209,"question_id":3383,"lang":"java","lang_name":"Java","time":"5\xc2\xa0months, 2\xc2\xa0wee