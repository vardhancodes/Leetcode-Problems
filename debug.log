\n        for(int i = 0 ; i < in.length() ; i++)\\n        {\\n            map.put(in.charAt(i),i);\\n        }\\n        int m = in.length();\\n        int n = pre.length();\\n        TreeNode root = createTree(0,n-1,0,m-1,pre,in,map);\\n        return root;\\n\\n    }\\n\\n    public static TreeNode createTree(int prestart, int preend, int instart, int inend, String pre, String in, HashMap<Character,Integer> map)\\n    {\\n        if(prestart > preend || instart > inend)\\n        {\\n            return null;\\n        }\\n        int rootindex = map.get(pre.charAt(prestart));\\n        TreeNode root = new TreeNode(pre.charAt(prestart)-\'0\');\\n        int leftsize = rootindex-instart;\\n        int rightsize = inend-rootindex;\\n        root.left = createTree(prestart+1,prestart+leftsize,instart,rootindex-1,pre,in,map);\\n        root.right = createTree(prestart+leftsize+1,preend,rootindex+1,inend,pre,in,map);\\n\\n        return root;\\n\\n    }\\n}\\n\\n// Your Codec object will be instantiated and called as such:\\n// Codec ser = new Codec();\\n// Codec deser = new Codec();\\n// TreeNode ans = deser.deserialize(ser.serialize(root));","compare_result":"11111111100000000000000000000000000000000000000000000","title_slug":"serialize-and-deserialize-binary-tree","has_notes":false,"flag_type":1,"frontend_id":776},{"id":1898437369,"question_id":236,"lang":"java","lang_name":"Java","time":"1\xc2\xa0month, 3\xc2\xa0weeks","timestamp":1769508040,"status":10,"status_display":"Accepted","runtime":"7 ms","url":"/submissions/detail/1898437369/","is_pending":"Not Pending","title":"Lowest Common Ancestor of a Binary Tree","memory":"46.4 MB","code":"/**\\n * Definition for a binary tree node.\\n * public class TreeNode {\\n *     int val;\\n *     TreeNode left;\\n *     TreeNode right;\\n *     TreeNode(int x) { val = x; }\\n * }\\n */\\nclass Solution {\\n    public TreeNode lowestCommonAncestor(TreeNode root, TreeNode p, TreeNode q) {\\n        if(root == null || root == p || root == q)\\n        {\\n            return root;\\n        }\\n        TreeNode leftchild = lowestCommonAncestor(root.left,p,q);\\n        TreeNode rightchild = lowestCommonAncestor(root.right,p,q);\\n\\n        if(leftchild == null)\\n        {\\n            return rightchild;\\n        }\\n        if(rightchild == null)\\n        {\\n            return leftchild;\\n        }\\n        else\\n        {\\n            return root;\\n        }\\n\\n\\n\\n    }\\n}","compare_result":"11111111111111111111111111111111","title_slug":"lowest-common-ancestor-of-a-binary-tree","has_notes":false,"flag_type":1,"frontend_id":775},{"id":1898345387,"question_id":1029,"lang":"java","lang_name":"Java","time":"1\xc2\xa0month, 3\xc2\xa0weeks","timestamp":1769501874,"status":10,"status_display":"Accepted","runtime":"3 ms","url":"/submissions/detail/1898345387/","is_pending":"Not Pending","title":"Vertical Order Traversal of a Binary Tree","memory":"44.5 MB","code":"/**\\n * Definition for a binary tree node.\\n * public class TreeNode {\\n *     int val;\\n *     TreeNode left;\\n *     TreeNode right;\\n *     TreeNode() {}\\n *     TreeNode(int val) { this.val = val; }\\n *     TreeNode(int val, TreeNode left, TreeNode right) {\\n *         this.val = val;\\n *         this.left = left;\\n *         this.right = right;\\n *     }\\n * }\\n */\\nclass Solution {\\n    public List<List<Integer>> verticalTraversal(TreeNode root) {\\n        TreeMap<Integer,TreeMap<Integer,List<Integer>>> map = new TreeMap<>();\\n        List<List<Integer>> list = new ArrayList<>();\\n        if( root == null)\\n        {\\n            return list;\\n        }\\n        dfs(map,root,0,0);\\n        for(Map.Entry<Integer,TreeMap<Integer,List<Integer>>> colentry : map.entrySet())\\n        {\\n            TreeMap<Integer,List<Integer>> rowsmap = colentry.getValue();\\n            List<Integer> sublist = new ArrayList<>();\\n            for(Map.Entry<Integer,List<Integer>> row : rowsmap.entrySet())\\n            {\\n                List<Integer> rowlist = new ArrayList<>(row.getValue());\\n                Collections.sort(rowlist);\\n                sublist.addAll(rowlist);\\n            }\\n            list.add(sublist);\\n        }\\n        return list;\\n    }\\n\\n    public static void dfs(TreeMap<Integer,TreeMap<Integer,List<Integer>>> map, TreeNode node, int col , int row)\\n    {\\n        if(node == null)\\n        {\\n            return;\\n        }\\n\\n        if(map.containsKey(col))\\n        {\\n            if(map.get(col).containsKey(row))\\n            {\\n                map.get(col).get(row).add(node.val);\\n            }\\n            else\\n            {\\n                List<Integer> sublist = new ArrayList<>();\\n                sublist.add(node.val);\\n                map.get(col).put(row,sublist);\\n            }\\n        }\\n        else\\n        {\\n            TreeMap<Integer,List<Integer>> inner = new TreeMap<>();\\n            List<Integer> sublist = new ArrayList<>();\\n            sublist.add(node.val);\\n            inner.put(row,sublist);\\n            map.put(col,inner);\\n        }\\n\\n        dfs(map,node.left,col-1,row+1);\\n        dfs(map,node.right,col+1,row+1);\\n    }\\n}\\n","compare_result":"1111111111111111111111111111111111","title_slug":"vertical-order-traversal-of-a-binary-tree","has_notes":false,"flag_type":1,"frontend_id":774},{"id":1898320192,"question_id":1029,"lang":"java","lang_name":"Java","time":"1\xc2\xa0month, 3\xc2\xa0weeks","timestamp":1769499819,"status":10,"status_display":"Accepted","runtime":"4 ms","url":"/submissions/detail/1898320192/","is_pending":"Not Pending","title":"Vertical Order Traversal of a Binary Tree","memory":"44.4 MB","code":"/**\\n * Definition for a binary tree node.\\n * public class TreeNode {\\n *     int val;\\n *     TreeNode left;\\n *     TreeNode right;\\n *     TreeNode() {}\\n *     TreeNode(int val) { this.val = val; }\\n *     TreeNode(int val, TreeNode left, TreeNode right) {\\n *         this.val = val;\\n *         this.left = left;\\n *         this.right = right;\\n *     }\\n * }\\n */\\nclass Solution {\\n    public List<List<Integer>> verticalTraversal(TreeNode root) {\\n        TreeMap<Integer,TreeMap<Integer,List<Integer>>> map = new TreeMap<>();\\n        Queue<CustomNode> queue = new LinkedList<>();\\n        List<List<Integer>> list = new ArrayList<>();\\n        if( root == null)\\n        {\\n            return list;\\n        }\\n        queue.offer(new CustomNode(root,0,0));\\n        while(!queue.isEmpty())\\n        {\\n            int levelsize = queue.size();\\n            for(int i = 0 ; i < levelsize ; i++)\\n            {\\n                CustomNode cus = queue.poll();\\n                if(map.containsKey(cus.col))\\n                {\\n                   if(map.get(cus.col).containsKey(cus.row))\\n                   {\\n                       map.get(cus.col).get(cus.row).add(cus.node.val);\\n                   }\\n                   else\\n                   {\\n                       List<Integer> sublist = new ArrayList<>();\\n                       sublist.add(cus.node.val);\\n                       map.get(cus.col).put(cus.row,(sublist));\\n                   }\\n                }\\n                else\\n                {\\n                    TreeMap<Integer,List<Integer>> innermap = new TreeMap<>();\\n                    List<Integer> sublist = new ArrayList<>();\\n                    sublist.add(cus.node.val);\\n                    innermap.put(cus.row,sublist);\\n                    map.put(cus.col,innermap);\\n                }\\n                \\n                if(cus.node.left != null)\\n                {\\n                    queue.offer(new CustomNode(cus.node.left,cus.col-1,cus.row+1));\\n                }\\n                if(cus.node.right != null)\\n                {\\n                    queue.offer(new CustomNode(cus.node.right,cus.col+1,cus.row+1));\\n                }\\n            }\\n        }\\n        \\n        for(Map.Entry<Integer,TreeMap<Integer,List<Integer>>> colentry : map.entrySet())\\n        {\\n            TreeMap<Integer,List<Integer>> rowsmap = colentry.getValue();\\n            List<Integer> sublist = new ArrayList<>();\\n            for(Map.Entry<Integer,List<Integer>> row : rowsmap.entrySet())\\n            {\\n                List<Integer> rowlist = new ArrayList<>(row.getValue());\\n                Collections.sort(rowlist);\\n                sublist.addAll(rowlist);\\n            }\\n            list.add(sublist);\\n        }\\n        return list;\\n    }\\n}\\nclass CustomNode {\\n    TreeNode node;\\n    int col;\\n    int row;\\n    \\n    CustomNode(TreeNode node, int col, int row)\\n    {\\n        this.node = node;\\n        this.col = col;\\n        this.row = row;\\n    }\\n}","compare_result":"1111111111111111111111111111111111","title_slug":"vertical-order-traversal-of-a-binary-tree","has_notes":false,"flag_type":1,"frontend_id":773},{"id":1898320060,"question_id":1029,"lang":"java","lang_name":"Java","time":"1\xc2\xa0month, 3\xc2\xa0weeks","timestamp":1769499810,"status":10,"status_display":"Accepted","runtime":"4 ms","url":"/submissions/detail/1898320060/","is_pending":"Not Pending","title":"Vertical Order Traversal of a Binary Tree","memory":"44.1 MB","code":"/**\\n * Definition for a binary tree node.\\n * public class TreeNode {\\n *     int val;\\n *     TreeNode left;\\n *     TreeNode right;\\n *     TreeNode() {}\\n *     TreeNode(int val) { this.val = val; }\\n *     TreeNode(int val, TreeNode left, TreeNode right) {\\n *         this.val = val;\\n *         this.left = left;\\n *         this.right = right;\\n *     }\\n * }\\n */\\nclass Solution {\\n    public List<List<Integer>> verticalTraversal(TreeNode root) {\\n        TreeMap<Integer,TreeMap<Integer,List<Integer>>> map = new TreeMap<>();\\n        Queue<CustomNode> queue = new LinkedList<>();\\n        List<List<Integer>> list = new 