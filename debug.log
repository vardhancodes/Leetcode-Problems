,"time":"1\xc2\xa0month","timestamp":1771929176,"status":11,"status_display":"Wrong Answer","runtime":"N/A","url":"/submissions/detail/1929534202/","is_pending":"Not Pending","title":"Sum of Root To Leaf Binary Numbers","memory":"N/A","code":"/**\\n * Definition for a binary tree node.\\n * public class TreeNode {\\n *     int val;\\n *     TreeNode left;\\n *     TreeNode right;\\n *     TreeNode() {}\\n *     TreeNode(int val) { this.val = val; }\\n *     TreeNode(int val, TreeNode left, TreeNode right) {\\n *         this.val = val;\\n *         this.left = left;\\n *         this.right = right;\\n *     }\\n * }\\n */\\nclass Solution {\\n    public int sumRootToLeaf(TreeNode root) {\\n        int sum[] = new int[1];\\n        dfs(root,sum,0);\\n        return sum[0];\\n    }\\n\\n    public static void dfs(TreeNode root, int[] sum, long bin)\\n    {\\n        if(root == null)\\n        {\\n            return;\\n        }\\n        bin = 10*bin + (root.val);\\n        if(isLeaf(root))\\n        {\\n            sum[0] += BinarytoInt(bin);\\n            return;\\n        }\\n        \\n        dfs(root.left,sum,bin);\\n        dfs(root.right,sum,bin);\\n        \\n    }\\n\\n    public static boolean isLeaf(TreeNode root)\\n    {\\n        if(root.left == null && root.right == null)\\n        {\\n            return true;\\n        }\\n        return false;\\n    }\\n\\n    public static int BinarytoInt(long bin)\\n    {\\n        int ans = 0;\\n        int i = 0;\\n        while(bin!= 0)\\n        {\\n           ans += Math.pow(2,i)*(bin%10);\\n           i++;\\n           bin /= 10;\\n        }\\n\\n        return ans;\\n    }\\n}","compare_result":"111111111111111111111111111111111111111111111111111111111100000","title_slug":"sum-of-root-to-leaf-binary-numbers","has_notes":false,"flag_type":1,"frontend_id":907},{"id":1929532523,"question_id":1079,"lang":"java","lang_name":"Java","time":"1\xc2\xa0month","timestamp":1771929065,"status":11,"status_display":"Wrong A