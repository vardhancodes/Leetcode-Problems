t;\\n    }\\n    public static void recur(String s, int ind, List<String> sublist, List<List<String>> list)\\n    {\\n        int n = s.length();\\n        if(ind == n)\\n        {\\n            list.add(new ArrayList<String>(sublist));\\n            return;\\n        }\\n        for(int i = ind ; i < n ; i++)\\n        {\\n            if(isPalindrome(s,ind,i))\\n            {\\n                sublist.add(s.substring(ind,i+1));\\n                recur(s,i+1,sublist,list);\\n                sublist.remove(sublist.size()-1);\\n            }\\n        }\\n\\n    }\\n    public static boolean isPalindrome(String s,int ind,int i)\\n    {\\n        while(ind < i)\\n        {\\n            if(s.charAt(ind) != s.charAt(i))\\n            {\\n                return false;\\n            }\\n            ind++;\\n            i--;\\n        }\\n        return true;\\n    }\\n}","compare_result":"11111111111111111111111111111111","title_slug":"palindrome-partitioning","has_notes":false,"flag_type":1,"frontend_id":310},{"id":1778075146,"question_id":47,"lang":"java","lang_name":"Java","time":"6\xc2\xa0months","timestamp":1758459815,"status":11,"status_display":"Wrong Answer","runtime":"N/A","url":"/submissions/detail/1778075146/","is_pending":"Not Pending","title":"Permutations II","memory":"N/A","code":"class Solution {\\n    public List<List<Integer>> permuteUnique(int[] nums) {\\n        List<List<Integer>> list = new ArrayList<List<Integer>>();\\n        Arrays.sort(nums);\\n        recur(nums,0,list);\\n        return list;\\n    }\\n\\n    public static void recur(int[]nums , int ind, List<List<Integer>> list)\\n    {\\n        List<Integer> sublist = new ArrayList<Integer>();\\n        int n = nums.length;\\n        if(ind == n)\\n        {\\n            for(int i = 0 ; i < n ; i++)\\n            {\\n                sublist.add(nums[i]);\\n            }\\n            list.add(new ArrayList<>(sublist));\\n            return;\\n        }\\n        for(int i = ind ; i<n; i++)\