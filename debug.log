isEmpty() && k>0 && ch<stack.peek())\\n            {\\n                stack.pop();\\n                k--;   \\n            }\\n            stack.push(ch);\\n        }\\n        StringBuilder str = new StringBuilder();\\n        while(!stack.isEmpty())\\n        {\\n            if(k>0)\\n            {\\n                stack.pop();\\n                k--;\\n            }\\n            else\\n            {\\n                str.insert(0,stack.pop());\\n            }\\n        }\\n        while(str.length()!=0 && str.charAt(0) == \'0\')\\n        {\\n            str.deleteCharAt(0);\\n        }\\n        return (str.length()==0)?\\"0\\":str.toString();\\n    }\\n}","compare_result":"11111111111111111111111111111111111111111111","title_slug":"remove-k-digits","has_notes":false,"flag_type":1,"frontend_id":253},{"id":1737174586,"question_id":155,"lang":"java","lang_name":"Java","time":"7\xc2\xa0months, 1\xc2\xa0week","timestamp":1755342455,"status":10,"status_display":"Accepted","runtime":"5 ms","url":"/submissions/detail/1737174586/","is_pending":"Not Pending","title":"Min Stack","memory":"45.2 MB","code":"class MinStack {\\n    Stack<Integer> stack;\\n    Stack<Integer> minstack;\\n    int top;\\n    public MinStack(){\\n        stack = new Stack<>();\\n        minstack = new Stack<>();\\n    }\\n    \\n    public void push(int val) {\\n        stack.push(val);\\n        if(minstack.isEmpty() || minstack.peek() > val)\\n        {\\n            minstack.push(val);\\n        }\\n        else\\n        {\\n            minstack.push(minstack.peek());\\n        }\\n    }\\n    \\n    public void pop() {\\n        if(!stack.isEmpty() && !minstack.isEmpty())\\n        {\\n            stack.pop();\\n            minstack.pop();\\n        }\\n        else\\n        {\\n            return;\\n        }\\n    }\\n    \\n    public int top() {\\n        return stack.peek();\\n        \\n    }\\n    \\n    public int getMin() {\\n        return minstack.peek();\\n    }\\n}\\n\\n/**\\n