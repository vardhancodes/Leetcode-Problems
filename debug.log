 int ans = 0;\\n        for(int i = 0 ; i < nums.length ; i++)\\n        {\\n            int count = 0;\\n            HashSet<Integer> set = new HashSet<>();\\n            set.add(nums[i]);\\n            if(nums[i]%2 == 0)\\n            {\\n                count++;\\n            }\\n            else\\n            {\\n                count--;\\n            }\\n            for(int j = i+1 ; j < nums.length ; j++)\\n            {\\n\\n                if(nums[j]%2 == 0 && !set.contains(nums[j]))\\n                {\\n                    count++;\\n                }\\n                else if(nums[j]%2 != 0 && !set.contains(nums[j]))\\n                {\\n                    count--;\\n                }\\n                if(count == 0)\\n                {\\n                    ans = Math.max(ans,j-i+1);\\n                }\\n                set.add(nums[j]);\\n            }\\n        }\\n        return ans;\\n    }\\n}","compare_result":"","title_slug":"longest-balanced-subarray-i","has_notes":false,"flag_type":1,"frontend_id":861},{"id":1913458261,"question_id":784,"lang":"java","lang_name":"Java","time":"1\xc2\xa0month, 2\xc2\xa0weeks","timestamp":1770640501,"status":10,"status_display":"Accepted","runtime":"0 ms","url":"/submissions/detail/1913458261/","is_pending":"Not Pending","title":"Insert into a Binary Search Tree","memory":"47 MB","code":"/**\\n * Definition for a binary tree node.\\n * public class TreeNode {\\n *     int val;\\n *     TreeNode left;\\n *     TreeNode right;\\n *     TreeNode() {}\\n *     TreeNode(int val) { this.val = val; }\\n *     TreeNode(int val, TreeNode left, TreeNode right) {\\n *         this.val = val;\\n *         this.left = left;\\n *         this.right = right;\\n *     }\\n * }\\n */\\nclass Solution {\\n    public TreeNode insertIntoBST(TreeNode root, int val) {\\n        if(root == null)\\n        {\\n            root = new TreeNode(val);\\n            return root;\\n        }\\n\\n        if(root.val > val)\\n        {\\n   