r,inorder,map,preStart+1,preStart+leftsize,inStart,rootIndex-1);\\n        root.right = constructTree(preorder,inorder,map,preStart+leftsize+1,preEnd,rootIndex+1,inEnd);\\n\\n        return root;\\n\\n    }\\n}","compare_result":"11111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"construct-binary-tree-from-preorder-and-inorder-traversal","has_notes":false,"flag_type":1,"frontend_id":710},{"id":1883594402,"question_id":145,"lang":"java","lang_name":"Java","time":"2\xc2\xa0months, 1\xc2\xa0week","timestamp":1768291111,"status":10,"status_display":"Accepted","runtime":"1 ms","url":"/submissions/detail/1883594402/","is_pending":"Not Pending","title":"Binary Tree Postorder Traversal","memory":"43.2 MB","code":"/**\\n * Definition for a binary tree node.\\n * public class TreeNode {\\n *     int val;\\n *     TreeNode left;\\n *     TreeNode right;\\n *     TreeNode() {}\\n *     TreeNode(int val) { this.val = val; }\\n *     TreeNode(int val, TreeNode left, TreeNode right) {\\n *         this.val = val;\\n *         this.left = left;\\n *         this.right = right;\\n *     }\\n * }\\n */\\nclass Solution {\\n    public List<Integer> postorderTraversal(TreeNode root) {\\n        List<Integer> list = new ArrayList<>();\\n        Stack<TreeNode> stack = new Stack<>();\\n        TreeNode node = root;\\n        while(!stack.isEmpty() || node != null)\\n        {\\n            //moving left\\n            while(node != null)\\n            {\\n                stack.push(node);\\n                node = node.left;\\n            }\\n            //moving right\\n            if(stack.peek().right != null)\\n            {\\n                node = stack.peek().right;\\n            }\\n            else\\n            {\\n                TreeNode temp = stack.pop();\\n                list.add(temp.val);\\n                while(!stack.isEmpty() && temp == stack.peek().right)\\n                {\\n                    temp = stack.pop();\\n                    list.add(temp.val); \\n                }\\n                \\n            }\\n        }\\n\\n        return list;\\n    }\\n}","compare_result":"11111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"binary-tree-postorder-traversal","has_notes":false,"flag_type":1,"frontend_id":709},{"id":1883553577,"question_id":94,"lang":"java","lang_name":"Java","time":"2\xc2\xa0months, 1\xc2\xa0week","timestamp":1768287869,"status":10,"status_display":"Accepted","runtime":"0 ms","url":"/submissions/detail/1883553577/","is_pending":"Not Pending","title":"Binary Tree Inorder Traversal","memory":"43.2 MB","code":"/**\\n * Definition for a binary tree node.\\n * public class TreeNode {\\n *     int val;\\n *     TreeNode left;\\n *     TreeNode right;\\n *     TreeNode() {}\\n *     TreeNode(int val) { this.val = val; }\\n *     TreeNode(int val, TreeNode left, TreeNode right) {\\n *         this.val = val;\\n *         this.left = left;\\n *         this.right = right;\\n *     }\\n * }\\n */\\nclass Solution {\\n    public List<Integer> inorderTraversal(TreeNode root) {\\n        Stack<TreeNode> stack = new Stack<>();\\n        List<Integer> list = new ArrayList<>();\\n        if(root == null)\\n        {\\n            return list;        \\n        }\\n        TreeNode node = root;\\n        while(!stack.isEmpty() || node != null)\\n        {\\n            while(node != null)\\n            {\\n                stack.push(node);\\n                node = node.left;\\n            }\\n            node = stack.pop();\\n            list.add(node.val);\\n            node = node.right;\\n        }\\n        return list;\\n    }\\n}","compare_result":"11111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"binary-tree-inorder-traversal","has_notes":false,"flag_type":1,"frontend_id":708},{"id":1883533683,"question_id":1395,"lang":"java","lang_name":"Java","time":"2\xc2\xa0months, 1\xc2\xa0week","timestamp":1768286476,"status":10,"status_display":"Accepted","runtime":"1 ms","url":"/submissions/detail/1883533683/","is_pending":"Not Pending","title":"Minimum Time Visiting All Points","memory":"45 MB","code":"class Solution {\\n    public int minTimeToVisitAllPoints(int[][] points) {\\n        int sum = 0;\\n        for(int i = 0 ; i < points.length-1 ; i++)\\n        {\\n           int diff1 =  (points[i][0] < points[i+1][0])?points[i+1][0] - points[i][0] : points[i][0] - points[i+1][0];\\n           int diff2 =  (points[i][1] < points[i+1][1])?points[i+1][1] - points[i][1] : points[i][1] - points[i+1][1];\\n\\n           sum += Math.max(diff1,diff2);\\n        }\\n        return sum;\\n    }\\n}","compare_result":"111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"minimum-time-visiting-all-points","has_notes":false,"flag_type":1,"frontend_id":707},{"id":1883184473,"question_id":1,"lang":"java","lang_name":"Java","time":"2\xc2\xa0months, 2\xc2\xa0weeks","timestamp":1768246972,"status":10,"status_display":"Accepted","runtime":"3 ms","url":"/submissions/detail/1883184473/","is_pending":"Not Pending","title":"Two Sum","memory":"47.4 MB","code":"class Solution {\\n    public int[] twoSum(int[] nums, int target) {\\n        int ans[] = new int[2];\\n        HashMap<Integer,Integer> map = new HashMap<>();\\n        for(int i = 0 ; i < nums.length ; i++)\\n        {\\n            int secondVal = target-nums[i];\\n            if(map.containsKey(secondVal))\\n            {\\n                ans[0] = i;\\n                ans[1] = map.get(secondVal);\\n                return ans;\\n            }\\n            map.put(nums[i],i);\\n\\n        }\\n        return ans;\\n\\n        \\n        \\n    }\\n\\n   \\n}","compare_result":"111111111111111111111111111111111111111111111111111111111111111","title_slug":"two-sum","has_notes":false,"flag_type":1,"frontend_id":706},{"id":1881806301,"question_id":85,"lang":"java","lang_name":"Java","time":"2\xc2\xa0months, 2\xc2\xa0weeks","timestamp":1768138155,"status":10,"status_display":"Accepted","runtime":"15 ms","url":"/submissions/detail/1881806301/","is_pending":"Not Pending","title":"Maximal Rectangle","memory":"50.1 MB","code":"class Solution {\\n    public int maximalRectangle(char[][] matrix) {\\n        int heights[] = new int[matrix[0].length];\\n\\n        if(matrix.length == 0)\\n        {\\n            return 0;\\n        }\\n        int largest = 0;\\n        for(int i = 0 ; i < matrix.length ; i ++)\\n        {\\n            for(int j = 0 ; j < matrix[i].length ; j++)\\n            {\\n                int val = (matrix[i][j]-\'0\');\\n\\n                if(val == 0)\\n                {\\n                    heights[j] = 0;\\n                }\\n                else\\n                {\\n                    heights[j]+= val;\\n                }\\n            }\\n            int max = largestRectangleArea2(heights);\\n            if(max > largest)\\n            {\\n                largest = max ;\\n            }\\n        }\\n        return largest;\\n        \\n    }\\n\\n    public static int largestRectangleArea2(int[] heights) {\\n        Stack<Integer> stack = new Stack<>();\\n        int n = heights.length;\\n        int max = Integer.MIN_VALUE;\\n        for(int i = 0 ; i <=n ; i ++)\\n        {\\n            int element = (i == n)?0:heights[i];\\n            while(!stack.isEmpty() && heights[stack.peek()]>element)\\n            {\\n                int h = heights[stack.pop()];\\n                int ps = (stack.isEmpty())?-1:stack.peek();\\n                int w = i - ps -1;\\n                max = Math.max(max,h*w);\\n            }\\n            stack.push(i);\\n        }\\n\\n        return (max==Integer.MIN_VALUE)?0:max;\\n    }\\n}","compare_result":"111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"maximal-rectangle","has_notes":false,"flag_type":1,"frontend_id":705},{"id":1880931267,"question_id":764,"lang":"java","lang_name":"Java","time":"2\xc2\xa0months, 2\xc2\xa0weeks","timestamp":1768064706,"status":20,"status_display":"Compile Error","runtime":"N/A","url":"/submissions/detail/1880931267/","is_pending":"Not Pending","title":"N-ary Tree Level Order Traversal","memory":"N/A","code":"/*\\n// Definition for a Node.\\nclass Node {\\n    public int val;\\n    public List<Node> children;\\n\\n    public Node() {}\\n\\n    public Node(int _val) {\\n        val = _val;\\n    }\\n\\n    public Node(int _val, List<Node> _children) {\\n        val = _val;\\n        children = _children;\\n    }\\n};\\n*/\\n\\nclass Solution {\\n    public List<List<Integer>> levelOrder(Node root) {\\n        \\n    }\\n}","compare_result":null,"title_slug":"n-ary-tree-level-order-traversal","has_notes":false,"flag_type":1,"frontend_id":704},{"id":1879751855,"question_id":144,"lang":"java","lang_name":"Java","time":"2\xc2\xa0months, 2\xc2\xa0weeks","timestamp":1767962656,"status":10,"status_display":"Accepted","runtime":"1 ms","url":"/submissions/detail/1879751855/","is_pending":"Not Pending","title":"Binary Tree Preorder Traversal","memory":"43.2 MB","code":"/**\\n * Definition for a binary tree node.\\n * public class TreeNode {\\n *     int val;\\n *     TreeNode left;\\n *     TreeNode right;\\n *     TreeNode() {}\\n *     TreeNode(int val) { this.val = val; }\\n *     TreeNode(int val, TreeNode left, TreeNode right) {\\n *         this.val = val;\\n *         this.left = left;\\n *         this.right = right;\\n *     }\\n * }\\n */\\nclass Solution {\\n    public List<Integer> preorderTraversal(TreeNode root) {\\n        Stack<TreeNode> stack = new Stack<>();\\n        List<Integer> list = new ArrayList<>();\\n        if(root == null)\\n        {\\n            return list;\\n        }\\n        stack.push(root);\\n        while(!stack.isEmpty())\\n        {\\n            TreeNode node = stack.pop();\\n            list.add(node.val);\\n            if(node.right != null)\\n            {\\n                stack.push(node.right);\\n            }\\n            if(node.left != null)\\n            {\\n                stack.push(node.left);\\n            }\\n        }\\n        return list;\\n\\n    }\\n}","compare_result":"11111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"binary-tree-preorder-traversal","has_notes":false,"flag_type":1,"frontend_id":703},{"id":1879473176,"question_id":100,"lang":"java","lang_name":"Java","time":"2\xc2\xa0months, 2\xc2\xa0weeks","timestamp":1767940149,"status":10,"status_display":"Accepted","runtime":"0 ms","url":"/submissions/detail/1879473176/","is_pending":"Not Pending","title":"Same Tree","memory":"42.8 MB","code":"/**\\n * Definition for a binary tree node.\\n * public class TreeNode {\\n *     int val;\\n *     TreeNode left;\\n *     TreeNode right;\\n *     TreeNode() {}\\n *     TreeNode(int val) { this.val = val; }\\n *     TreeNode(int val, TreeNode left, TreeNode right) {\\n *         this.val = val;\\n *         this.left = left;\\n *         this.right = right;\\n *     }\\n * }\\n */\\nclass Solution {\\n    public boolean isSameTree(TreeNode p, TreeNode q) {\\n        Queue<TreeNode> queuep = new LinkedList<>();\\n        Queue<TreeNode> queueq = new LinkedList<>();\\n        queuep.offer(p);\\n        queueq.offer(q);\\n        while(!queuep.isEmpty() || !queueq.isEmpty())\\n        {\\n            TreeNode nodep = queuep.poll();\\n            TreeNode nodeq = queueq.poll();\\n            if(nodep == null && nodeq == null)\\n            {\\n                continue;\\n            }\\n            if(nodep == null || nodeq == null)\\n            {\\n                return false;\\n            }\\n            if(nodep.val != nodeq.val)\\n            {\\n                return false;\\n            }\\n    