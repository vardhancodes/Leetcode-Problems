urn (ans == Integer.MAX_VALUE)?-1:ans;\\n    }\\n}","compare_result":"11110110011011000000000010010010000000010000000001100000001000011111100000001001","title_slug":"minimum-consecutive-cards-to-pick-up","has_notes":false,"flag_type":1,"frontend_id":784},{"id":1899461306,"question_id":940,"lang":"java","lang_name":"Java","time":"1\xc2\xa0month, 3\xc2\xa0weeks","timestamp":1769582409,"status":10,"status_display":"Accepted","runtime":"60 ms","url":"/submissions/detail/1899461306/","is_pending":"Not Pending","title":"Fruit Into Baskets","memory":"70.8 MB","code":"class Solution {\\n    public int totalFruit(int[] fruits) {\\n        HashMap<Integer,Integer> map = new HashMap<>();\\n        int ubc = 0;\\n        int windowStart = 0;\\n        int windowEnd = 0;\\n        int ans = 0;\\n        while(windowEnd < fruits.length)\\n        {\\n            if(!map.containsKey(fruits[windowEnd]))\\n            {\\n                ubc++;\\n            }\\n            map.put(fruits[windowEnd],map.getOrDefault(fruits[windowEnd],0)+1);\\n\\n            if(ubc > 2)\\n            {\\n                ans = Math.max(ans,windowEnd-windowStart);\\n                while(windowStart <= windowEnd && ubc > 2)\\n                {\\n                    map.put(fruits[windowStart],map.getOrDefault(fruits[windowStart],0)-1);\\n                    if(map.get(fruits[windowStart]) == 0)\\n                    {\\n                        ubc--;\\n                        map.remove(fruits[windowStart]);\\n                    }\\n                    windowStart++;\\n                }\\n            }\\n            ans = Math.max(ans,windowEnd-windowStart+1);\\n            windowEnd++;\\n        }\\n        return ans;\\n    }\\n}","compare_result":"111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"fruit-into-baskets","has_notes":false,"flag_type":1,"frontend_id":783},{"id":1899459730,"question_id":940,"lang":"java","lang_name":"Java","time":"1\xc2\xa0month, 3\xc2\xa0weeks","timestamp":1769582312,"status":11,"status_display":"Wrong Answer","runtime":"N/A","url":"/submissions/detail/1899459730/","is_pending":"Not Pending","title":"Fruit Into Baskets","memory":"N/A","code":"class Solution {\\n    public int totalFruit(int[] fruits) {\\n        HashMap<Integer,Integer> map = new HashMap<>();\\n        int ubc = 0;\\n        int windowStart = 0;\\n        int windowEnd = 0;\\n        int ans = 0;\\n        while(windowEnd < fruits.length)\\n        {\\n            if(!map.containsKey(fruits[windowEnd]))\\n            {\\n                ubc++;\\n            }\\n            map.put(fruits[windowEnd],map.getOrDefault(fruits[windowEnd],0)+1);\\n\\n            if(ubc > 2)\\n            {\\n                ans = Math.max(ans,windowEnd-windowStart);\\n                while(windowStart <= windowEnd && ubc > 2)\\n                {\\n                    map.put(fruits[windowStart],map.getOrDefault(fruits[windowStart],0)-1);\\n                    if(map.get(fruits[windowStart]) == 0)\\n                    {\\n                        ubc--;\\n                    }\\n                    windowStart++;\\n                }\\n            }\\n            ans = Math.max(ans,windowEnd-windowStart+1);\\n            windowEnd++;\\n        }\\n        return ans;\\n    }\\n}","compare_result":"111011111111111111111111111011111111111110011000111001110000000000000001100000000000000000011","title_slug":"fruit-into-baskets","has_notes":false,"flag_type":1,"frontend_id":782},{"id":1898579008,"question_id":113,"lang":"java","lang_name":"Java","time":"1\xc2\xa0month, 3\xc2\xa0weeks","timestamp":1769518592,"status":10,"status_display":"Accepted","runtime":"1 ms","url":"/submissions/detail/1898579008/","is_pending":"Not Pending","title":"Path Sum II","memory":"45.5 MB","code":"/**\\n * Definition for a binary tree node.\\n * public class TreeNode {\\n *     int val;\\n *     TreeNode left;\\n *     TreeNode right;\\n *     TreeNode() {}\\n *     TreeNode(int val) { this.val = val; }\\n *     TreeNode(int val, TreeNode left, TreeNode right) {\\n *         this.val = val;\\n *         this.left = left;\\n *         this.right = right;\\n *     }\\n * }\\n */\\nclass Solution {\\n    public List<List<Integer>> pathSum(TreeNode root, int targetSum) {\\n        List<List<Integer>> list = new ArrayList<>();\\n        List<Integer> sublist = new ArrayList<>();\\n        dfs(list,sublist,root,targetSum);\\n        return list;\\n    }\\n\\n    public static void dfs(List<List<Integer>> list,List<Integer> sublist, TreeNode root, int sum)\\n    {\\n        if(root == null)\\n        {\\n            return;\\n        }\\n        sum -= root.val;\\n        sublist.add(root.val);\\n        if(sum == 0 && isleaf(root))\\n        {\\n            list.add(new ArrayList<>(sublist));\\n        }\\n\\n        dfs(list,sublist,root.left,sum);\\n        dfs(list,sublist,root.right,sum);\\n\\n        sum += root.val;\\n        sublist.remove(sublist.size()-1);\\n    }\\n\\n    public static boolean isleaf(TreeNode root)\\n    {\\n        if(root.left == null && root.right == null)\\n        {\\n            return true;\\n        }\\n        return false;\\n    }\\n}","compare_result":"1111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"path-sum-ii","has_notes":false,"flag_type":1,"frontend_id":781},{"id":1898573297,"question_id":112,"lang":"java","lang_name":"Java","time":"1\xc2\xa0month, 3\xc2\xa0weeks","timestamp":1769518211,"status":10,"status_display":"Accepted","runtime":"0 ms","url":"/submissions/detail/1898573297/","is_pending":"Not Pending","title":"Path Sum","memory":"45 MB","code":"/**\\n * Definition for a binary tree node.\\n * public class TreeNode {\\n *     int val;\\n *     TreeNode left;\\n *     TreeNode right;\\n *     TreeNode() {}\\n *     TreeNode(int val) { this.val = val; }\\n *     TreeNode(int val, TreeNode left, TreeNode right) {\\n *         this.val = val;\\n *         this.left = left;\\n *         this.right = right;\\n *     }\\n * }\\n */\\nclass Solution {\\n    public boolean hasPathSum(TreeNode root, int targetSum) {\\n       if(root == null)\\n       {\\n            return false;\\n       }\\n       targetSum -= root.val;\\n       if(targetSum == 0 && isleaf(root))\\n       {\\n            return true;\\n       }\\n\\n       return hasPathSum(root.left,targetSum) || hasPathSum(root.right,targetSum);\\n    }\\n\\n    public static boolean isleaf(TreeNode root)\\n    {\\n        if(root.left == null && root.right == null)\\n        {\\n            return true;\\n        }\\n        return false;\\n    }\\n\\n}","compare_result":"1111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"path-sum","has_notes":false,"flag_type":1,"frontend_id":780},{"id":1898537450,"question_id":114,"lang":"java","lang_name":"Java","time":"1\xc2\xa0month, 3\xc2\xa0weeks","timestamp":1769515575,"status":10,"status_display":"Accepted","runtime":"1 ms","url":"/submissions/detail/1898537450/","is_pending":"Not Pending","title":"Flatten Binary Tree to Linked List","memory":"44.2 MB","code":"/**\\n * Definition for a binary tree node.\\n * public class TreeNode {\\n *     int val;\\n *     TreeNode left;\\n *     TreeNode right;\\n *     TreeNode() {}\\n *     TreeNode(int val) { this.val = val; }\\n *     TreeNode(int val, TreeNode left, TreeNode right) {\\n *         this.val = val;\\n *         this.left = left;\\n *         this.right = right;\\n *     }\\n * }\\n */\\nclass Solution {\\n    public void flatten(TreeNode root) {\\n        List<TreeNode> list = new ArrayList<>();\\n        preorder(root,list);\\n        for(int i = 1 ; i < list.size() ; i++)\\n        {\\n            TreeNode prev = list.get(i-1);\\n            TreeNode curr = list.get(i);\\n            prev.left = null; \\n            prev.right = curr;\\n\\n        }\\n\\n    }\\n    private void preorder(TreeNode root, List<TreeNode> list)\\n    {\\n        if(root == null)\\n        {\\n            return;\\n        }\\n\\n        list.add(root);\\n        preorder(root.left,list);\\n        preorder(root.right,list);\\n    }\\n\\n\\n}","compare_result":"111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"flatten-binary-tree-to-linked-list","has_notes":false,"flag_type":1,"frontend_id":779},{"id":1898536660,"question_id":114,"lang":"java","lang_name":"Java","time":"1\xc2\xa0month, 3\xc2\xa0weeks","timestamp":1769515511,"status":11,"status_display":"Wrong Answer","runtime":"N/A","url":"/submissions/detail/1898536660/","is_pending":"Not Pending","title":"Flatten Binary Tree to Linked List","memory":"N/A","code":"/**\\n * Definition for a binary tree node.\\n * public class TreeNode {\\n *     int val;\\n *     TreeNode left;\\n *     TreeNode right;\\n *     TreeNode() {}\\n *     TreeNode(int val) { this.val = val; }\\n *     TreeNode(int val, TreeNode left, TreeNode right) {\\n *         this.val = val;\\n *         this.left = left;\\n *         this.right = right;\\n *     }\\n * }\\n */\\nclass Solution {\\n    public void flatten(TreeNode root) {\\n        List<TreeNode> list = new ArrayList<>();\\n        preorder(root,list);\\n        for(int i = 1 ; i < list.size()-1 ; i++)\\n        {\\n            TreeNode prev = list.get(i-1);\\n            TreeNode curr = list.get(i);\\n            prev.left = null; \\n            prev.right = curr;\\n\\n        }\\n\\n    }\\n    private void preorder(TreeNode root, List<TreeNode> list)\\n    {\\n        if(root == null)\\n        {\\n            return;\\n        }\\n\\n        list.add(root);\\n        preorder(root.left,list);\\n        preorder(root.right,list);\\n    }\\n