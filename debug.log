|| ch == \'O\' || ch == \'u\' || ch == \'U\' )\\n            {\\n                list.add(ch);\\n            }\\n        }\\n        Collections.sort(list);\\n        int counter = 0;\\n        for(int i = 0 ; i < s.length() ; i++)\\n        {\\n            char ch = s.charAt(i);\\n            if(ch == \'a\' || ch == \'A\' || ch == \'e\' || ch == \'E\' || ch == \'i\' || ch == \'I\' || ch == \'o\' || ch == \'O\' || ch == \'u\' || ch == \'U\' )\\n            {\\n                ans.append(list.get(counter));\\n                counter++;\\n            }\\n            else\\n            {\\n                ans.append(ch);\\n            }\\n        }\\n        return ans.toString();\\n    }\\n}","compare_result":"","title_slug":"sort-vowels-in-a-string","has_notes":false,"flag_type":1,"frontend_id":294},{"id":1771498541,"question_id":739,"lang":"java","lang_name":"Java","time":"6\xc2\xa0months, 1\xc2\xa0week","timestamp":1757934970,"status":10,"status_display":"Accepted","runtime":"79 ms","url":"/submissions/detail/1771498541/","is_pending":"Not Pending","title":"Daily Temperatures","memory":"60.2 MB","code":"class Solution {\\n    public int[] dailyTemperatures(int[] temperatures) {\\n        Stack<Integer> stack = new Stack<>();\\n        int n = temperatures.length;\\n        int ans[] = new int[n];\\n        for(int i = n-1 ; i >= 0 ; i--)\\n        {\\n            while(!stack.isEmpty() && temperatures[stack.peek()] <= temperatures[i])\\n            {\\n                stack.pop();\\n            }\\n            if(stack.isEmpty())\\n            {\\n                ans[i] = 0;\\n            }\\n            else\\n            {\\n               ans[i] = stack.peek()-i;\\n            }\\n            stack.push(i);\\n        }\\n        return ans;\\n    }\\n}","compare_result":"111111111111111111111111111111111111111111111111","title_slug":"daily-temperatures","has_notes":false,"flag_type":1,"frontend_id":293},{"id":1771472606,"question_id":240,"lang":"java","lang_name