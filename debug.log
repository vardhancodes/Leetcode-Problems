path = path*10 + root.val;\\n        if(isleaf(root))\\n        {\\n            sum[0] += path;\\n            return;\\n        }\\n\\n        dfs(root.left,sum,path);\\n        dfs(root.right,sum,path);\\n    }\\n\\n    public static boolean isleaf(TreeNode root)\\n    {\\n        if(root.left == null && root.right == null)\\n        {\\n            return true;\\n        }\\n        return false;\\n    }\\n}","compare_result":"111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"sum-root-to-leaf-numbers","has_notes":false,"flag_type":1,"frontend_id":810},{"id":1900810918,"question_id":800,"lang":"java","lang_name":"Java","time":"1\xc2\xa0month, 3\xc2\xa0weeks","timestamp":1769682989,"status":10,"status_display":"Accepted","runtime":"5 ms","url":"/submissions/detail/1900810918/","is_pending":"Not Pending","title":"Letter Case Permutation","memory":"53.2 MB","code":"class Solution {\\n    public List<String> letterCasePermutation(String s) {\\n        List<String> list = new ArrayList<>();\\n        recur(list,s,\\"\\",0);\\n        return list;\\n    }\\n    public static void recur(List<String> list, String s, String ans, int index)\\n    {\\n        if(index == s.length())\\n        {\\n            list.add(ans);\\n            return;\\n        }\\n\\n        char ch = s.charAt(index); \\n\\n        if(!Character.isDigit(ch))\\n        {\\n            recur(list,s,ans+Character.toUpperCase(ch),index+1);\\n            recur(list,s,ans+Character.toLowerCase(ch),index+1);\\n        }\\n        else\\n        {\\n            ans += ch;\\n            recur(list,s,ans,index+1);\\n        }\\n\\n    }\\n}","compare_result":"111111111111111111111111111111111111111111111111111111111111111","title_slug":"letter-case-permutation","has_notes":false,"flag_type":1,"frontend_id":809},{"id":1900810448,"question_id":800,"lang":"java","lang_name":"Java","time":"1\xc2\xa0month, 3\xc2\xa0weeks","timestamp":1769682954,"status":10,"status_display":"Accepted","runtime":"5 ms","url":"/submissions/detail/1900810448/","is_pending":"Not Pending","title":"Letter Case Permutation","memory":"53.3 MB","code":"class Solution {\\n    public List<String> letterCasePermutation(String s) {\\n        List<String> list = new ArrayList<>();\\n        recur(list,s,\\"\\",0);\\n        return list;\\n    }\\n    public static void recur(List<String> list, String s, String ans, int index)\\n    {\\n        if(index == s.length())\\n        {\\n            list.add(ans);\\n            return;\\n        }\\n\\n        char ch = s.charAt(index); \\n\\n        if((ch >= \'a\' && ch <= \'z\') || (ch >= \'A\' && ch <= \'Z\'))\\n        {\\n            recur(list,s,ans+Character.toUpperCase(ch),index+1);\\n            recur(list,s,ans+Character.toLowerCase(ch),index+1);\\n        }\\n        else\\n        {\\n            ans += ch;\\n            recur(list,s,ans,index+1);\\n        }\\n\\n    }\\n}","compare_result":"111111111111111111111111111111111111111111111111111111111111111","title_slug":"letter-case-permutation","has_notes":false,"flag_type":1,"frontend_id":808},{"id":1900808993,"question_id":800,"lang":"java","lang_name":"Java","time":"1\xc2\xa0month, 3\xc2\xa0weeks","timestamp":1769682841,"status":10,"status_display":"Accepted","runtime":"5 ms","url":"/submissions/detail/1900808993/","is_pending":"Not Pending","title":"Letter Case Permutation","memory":"53.2 MB","code":"class Solution {\\n    public List<String> letterCasePermutation(String s) {\\n        List<String> list = new ArrayList<>();\\n        recur(list,s,\\"\\",0);\\n        return list;\\n    }\\n    public static void recur(List<String> list, String s, String ans, int index)\\n    {\\n        if(index == s.length())\\n        {\\n            list.add(ans);\\n            return;\\n        }\\n\\n        char ch = s.charAt(index); \\n\\n        if((ch >= \'a\' && ch <= \'z\') || (ch >= \'A\' && ch <= \'Z\'))\\n        {\\n        