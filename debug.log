ght == null)\\n        {\\n            return true;\\n        }\\n        return false;\\n    }\\n}","compare_result":"1111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"binary-tree-paths","has_notes":false,"flag_type":1,"frontend_id":806},{"id":1900787359,"question_id":257,"lang":"java","lang_name":"Java","time":"1\xc2\xa0month, 3\xc2\xa0weeks","timestamp":1769681291,"status":10,"status_display":"Accepted","runtime":"5 ms","url":"/submissions/detail/1900787359/","is_pending":"Not Pending","title":"Binary Tree Paths","memory":"50.2 MB","code":"/**\\n * Definition for a binary tree node.\\n * public class TreeNode {\\n *     int val;\\n *     TreeNode left;\\n *     TreeNode right;\\n *     TreeNode() {}\\n *     TreeNode(int val) { this.val = val; }\\n *     TreeNode(int val, TreeNode left, TreeNode right) {\\n *         this.val = val;\\n *         this.left = left;\\n *         this.right = right;\\n *     }\\n * }\\n */\\nclass Solution {\\n    public List<String> binaryTreePaths(TreeNode root) {\\n        List<String> list = new ArrayList<>();\\n        dfs(list,root,\\"\\");\\n        return list;\\n    }\\n    public static void dfs(List<String> list,TreeNode root, String s)\\n    {\\n        if(root == null)\\n        {\\n            return;\\n        }\\n        s += String.valueOf(root.val) + \\"->\\";\\n        if(isLeaf(root))\\n        {\\n            s = s.substring(0,s.length()-1);\\n            s = s.substring(0,s.length()-1);\\n            list.add(s);\\n            return;\\n        }\\n\\n        dfs(list,root.left,s);\\n        dfs(list,root.right,s);\\n\\n        s = s.substring(0,s.length()-1);\\n    }\\n\\n    public static boolean isLeaf(TreeNode root)\\n    {\\n        if(root.left == null && root.right == null)\\n        {\\n            return true;\\n        }\\n        return false;\\n    }\\n}","compare_result":"1111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"binary-tree-paths","has_notes":false,"flag_type":1,"frontend_id":805},{"id":1900773382,"question_id":131,"lang":"java","lang_name":"Java","time":"1\xc2\xa0month, 3\xc2\xa0weeks","timestamp":1769680349,"status":10,"status_display":"Accepted","runtime":"8 ms","url":"/submissions/detail/1900773382/","is_pending":"Not Pending","title":"Palindrome Partitioning","memory":"65.1 MB","code":"class Solution {\\n    public List<List<String>> partition(String s) {\\n        List<List<String>> list = new ArrayList<>();\\n        List<String> sublist = new ArrayList<>();\\n        recur(list,sublist,0,s);\\n        return list;\\n    }\\n    public static void recur(List<List<String>> list,  List<String> sublist, int index, String s )\\n    {\\n        if(index == s.length()  )\\n        {\\n            list.add(new ArrayList<>(sublist));\\n        }\\n\\n        for(int i = index ; i < s.length() ; i++)\\n        {\\n            if(isPalindrome(s,index,i))\\n            {\\n                sublist.add(s.substring(index,i+1));\\n                recur(list,sublist,i+1,s);\\n                sublist.remove(sublist.size()-1);\\n            }\\n        }\\n    }\\n    public static boolean isPalindrome(String s , int start , int end)\\n    {\\n        while(start < end)\\n        {\\n            if(s.charAt(start) != s.charAt(end))\\n            {\\n                return false;\\n            }\\n            start++;\\n            end--;\\n        }\\n        return true;\\n    }\\n}","compare_result":"11111111111111111111111111111111","title_slug":"palindrome-partitioning","has_notes":false,"flag_type":1,"frontend_id":804},{"id":1900690936,"question_id":46,"lang":"java","lang_name":"Java","time":"1\xc2\xa0month, 3\xc2\x