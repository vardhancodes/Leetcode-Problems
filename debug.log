m = n*(n+1)/2; \\n        int sum1 = 0;\\n        for(int i = 0 ; i< n ; i ++)\\n        {\\n            sum1+=nums[i];\\n        }\\n        return sum-sum1;\\n        \\n    }\\n}","compare_result":"11111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"missing-number","has_notes":false,"flag_type":1,"frontend_id":182},{"id":1702788822,"question_id":4,"lang":"java","lang_name":"Java","time":"8\xc2\xa0months, 1\xc2\xa0week","timestamp":1752865159,"status":10,"status_display":"Accepted","runtime":"1 ms","url":"/submissions/detail/1702788822/","is_pending":"Not Pending","title":"Median of Two Sorted Arrays","memory":"46.3 MB","code":"class Solution {\\n    public double findMedianSortedArrays(int[] nums1, int[] nums2) {\\n        if(nums1.length > nums2.length)\\n        {\\n            return findMedianSortedArrays(nums2 , nums1);\\n        }\\n        int n1 = nums1.length;\\n        int n2 = nums2.length;\\n        int start = 0 ; \\n        int end = n1;\\n\\n        while(start <= end)\\n        {\\n            int cut1 = start+(end-start)/2;\\n            int cut2 = (n1+n2)/2 - cut1;\\n            int L1 = (cut1==0)?Integer.MIN_VALUE:nums1[cut1-1];\\n            int L2 = (cut2==0)?Integer.MIN_VALUE:nums2[cut2-1];\\n            int R1 = (cut1==n1)?Integer.MAX_VALUE:nums1[cut1];\\n            int R2 = (cut2==n2)?Integer.MAX_VALUE:nums2[cut2];\\n\\n            if(L1 <= R2 && L2 <= R1)\\n            {\\n                if((n1+n2)%2 != 0)\\n                {\\n                    return (double)Math.min(R1,R2);\\n                }\\n                else\\n                {\\n                    return (double)(Math.max(L1,L2) + Math.min(R1,R2))/2;\\n                }\\n            }\\n            else if( L1 > R2)\\n            {\\n                end = cut1-1;\\n\\n            }\\n            else\\n            {\\n                start = cut1+1;\\n            }\\n\\n        }\\n    