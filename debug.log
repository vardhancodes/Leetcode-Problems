 if(len < minlen)\\n                    {\\n                        start = windowStart;\\n                        minlen = len;\\n                    }\\n                    if(map.containsKey(s.charAt(windowStart)))\\n                    {\\n                        map.put(s.charAt(windowStart),map.getOrDefault(s.charAt(windowStart),0)+1);\\n                        if(map.get(s.charAt(windowStart)) > 0)\\n                        {\\n                            ucc++;\\n                        }\\n                    }\\n                    windowStart++;\\n\\n                }\\n        \\n            }\\n            windowEnd++;\\n        }\\n        return (start == -1)?\\"\\":s.substring(start,start+minlen);\\n    }\\n}","compare_result":"1111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"minimum-window-substring","has_notes":false,"flag_type":1,"frontend_id":649},{"id":1858738361,"question_id":3,"lang":"java","lang_name":"Java","time":"3\xc2\xa0months, 1\xc2\xa0week","timestamp":1766046119,"status":10,"status_display":"Accepted","runtime":"8 ms","url":"/submissions/detail/1858738361/","is_pending":"Not Pending","title":"Longest Substring Without Repeating Characters","memory":"45.6 MB","code":"class Solution {\\n    public int lengthOfLongestSubstring(String s) {\\n        int windowStart = 0;\\n        int windowEnd = 0;\\n        int n = s.length();\\n        int ans = 0;\\n        int maxLen = 0;\\n        if(s.length() == 0)\\n        {\\n            return 0;\\n        }\\n        HashMap<Character,Integer> map = new HashMap<>();\\n        while(windowEnd < n)\\n        {\\n            char ch = s.charAt(windowEnd);\\n            map.put(ch,map.getOrDefault(ch,0)+1);\\n            if(map.get(ch) > 1)\\n            {\\n                while(windowStart < windowEnd && map.get(ch) > 1)\\n                {\\n                    map.put(s.charAt(windowStart),map.getOrDefault(s.charAt(windowStart),0)-1);\\n                    windowStart++;\\n                }\\n\\n            }\\n            else\\n            {\\n                maxLen = windowEnd-windowStart+1;\\n                ans = Math.max(ans,maxLen);\\n            }\\n            windowEnd++;\\n        }\\n        return ans;\\n    }\\n}","compare_result":"","title_slug":"longest-substring-without-repeating-characters","has_notes":false,"flag_type":1,"frontend_id":648},{"id":1858707042,"question_id":3,"lang":"java","lang_name":"Java","time":"3\xc2\xa0months, 1\xc2\xa0week","timestamp":1766043221,"status":15,"status_display":"Runtime Error","runtime":"N/A","url":"/submissions/detail/1858707042/","is_pending":"Not Pending","title":"Longest Substring Without Repeating Characters","memory":"N/A","code":"class Solution {\\n    public int lengthOfLongestSubstring(String s) {\\n        int windowStart = 0;\\n        int windowEnd = 0;\\n        int n = s.length();\\n        int ans = 0;\\n        int maxLen = 0;\\n\\n        int freq[] = new int[26];\\n        while(windowEnd < n)\\n        {\\n            char ch = s.charAt(windowEnd);\\n            freq[ch-97]++;\\n            if(freq[ch-97] > 1)\\n            {\\n                while(windowStart < windowEnd && freq[ch-97] > 1)\\n                {\\n                    freq[s.charAt(windowStart) -97]--;\\n                    windowStart++;\\n                }\\n\\n            }\\n            else\\n            {\\n                maxLen = windowEnd-windowStart+1;\\n                ans = Math.max(ans,maxLen);\\n            }\\n            windowEnd++;\\n        }\\n        return ans;\\n    }\\n}","compare_result":"","title_slug":"longest-substring-without-repeating-characters","has_notes":false,"flag_type":1,"frontend_id":647},{"id":1858076561,"question_id":1138,"lang":"java","lang_name":"Java","time":"3\xc2\xa0months, 1\xc2\xa0week","timestamp":1765979127,"status":10,"status_display":"Accepted","runtime":"4 ms","url":"/submissions/detail/1858076561/","is_pending":"Not Pending","title":"Grumpy Bookstore Owner","memory":"48.6 MB","code":"class Solution {\\n    public int maxSatisfied(int[] customers, int[] grumpy, int minutes) {\\n        //creating a window\\n        int base = 0;\\n        int max = 0;\\n        int ans = 0;\\n        int n = customers.length;\\n        for(int i = 0 ; i < minutes ; i++)\\n        {\\n            if(grumpy[i] == 1)\\n            {\\n                max += customers[i];\\n            }\\n        }\\n        ans = Math.max(ans,max);\\n        for(int i = 0 ; i < n ; i++)\\n        {\\n            if(grumpy[i] == 0)\\n            {\\n                base += customers[i];\\n            }\\n        }\\n        for(int i = 1 ; i <= n - minutes ; i++)\\n        {\\n            if(grumpy[i+minutes-1] == 1)\\n            {\\n                max += customers[i+minutes-1];\\n            }\\n            if(grumpy[i-1] == 1)\\n            {\\n                max -= customers[i-1];\\n            }  \\n            ans = Math.max(ans,max);\\n        }\\n        return ans+base;\\n        \\n    }\\n}","compare_result":"111111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"grumpy-bookstore-owner","has_notes":false,"flag_type":1,"frontend_id":646},{"id":1856216092,"question_id":209,"lang":"java","lang_name":"Java","time":"3\xc2\xa0months, 1\xc2\xa0week","timestamp":1765802075,"status":10,"status_display":"Accepted","runtime":"2 ms","url":"/submissions/detail/1856216092/","is_pending":"Not Pending","title":"Minimum Size Subarray Sum","memory":"62 MB","code":"class Solution {\\n    public int minSubArrayLen(int target, int[] nums) {\\n        int windowStart = 0;\\n        int windowEnd = 0;\\n        int n = nums.length;\\n        int sum = 0;\\n        int ans = Integer.MAX_VALUE;\\n        int check = 0;\\n        while(windowEnd < n)\\n        {\\n            check += nums[windowEnd];\\n            sum += nums[windowEnd];\\n            if(sum >= target)\\n            {\\n                int min = windowEnd-windowStart+1;\\n                ans = Math.min(min,ans);\\n                while(windowStart < windowEnd && sum >= target)\\n                {\\n                    sum -= nums[windowStart];\\n                    windowStart++;\\n                    if(sum >= target)\\n                    {\\n                        min = windowEnd - windowStart + 1;\\n                        ans = Math.min(ans,min);\\n\\n                    }\\n                }\\n            }    \\n            windowEnd++;\\n        }\\n        if(check < target)\\n        {\\n            return 0;\\n        }\\n        return ans;\\n    }\\n}","compare_result":"111111111111111111111","title_slug":"minimum-size-subarray-sum","has_notes":false,"flag_type":1,"frontend_id":645},{"id":1841852796,"question_id":84,"lang":"java","lang_name":"Java","time":"3\xc2\xa0months, 3\xc2\xa0weeks","timestamp":1764344323,"status":10,"status_display":"Accepted","runtime":"2120 ms","url":"/submissions/detail/1841852796/","is_pending":"Not Pending","title":"Largest Rectangle in Histogram","memory":"86.9 MB","code":"class Solution {\\n    public int largestRectangleArea(int[] heights) {\\n        int n = heights.length;\\n        int psmall[] = new int[n];\\n        int nsmall[] = new int[n];\\n        //for previous smaller\\n        Stack<Integer> stack = new Stack<>();\\n        for(int i = 0 ; i < n ; i++)\\n        {\\n            while(!stack.isEmpty() && heights[i] < heights[stack.peek()])\\n            {\\n                stack.pop();\\n            }\\n            if(stack.isEmpty())\\n            {\\n                psmall[i] = -1;\\n            }\\n            else\\n            {\\n                psmall[i] = stack.peek();\\n            }\\n            stack.push(i);\\n            System.out.print(psmall[i] + \\" \\" );\\n        }\\n        stack.clear();\\n        System.out.println();\\n        //for next smaller\\n        for(int i = n-1 ; i >= 0 ; i--)\\n        {\\n            while(!stack.isEmpty() && heights[i] <= heights[stack.peek()])\\n            {\\n                stack.pop();\\n            }\\n            if(stack.isEmpty())\\n            {\\n                nsmall[i] = n;\\n            }\\n            else\\n            {\\n                nsmall[i] = stack.peek();\\n            }\\n            stack.push(i);\\n            System.out.print(nsmall[i] + \\" \\" );\\n        }\\n        int max = 0;\\n        for(int i = 0 ; i < n ; i++)\\n        {\\n            int area = heights[i]*(nsmall[i] - psmall[i]-1);\\n            \\n            max = Math.max(max,area);\\n        }\\n        return max;\\n    }\\n}","compare_result":"111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"largest-rectangle-in-histogram","has_notes":false,"flag_type":1,"frontend_id":644},{"id":1841851713,"question_id":84,"lang":"java","lang_name":"Java","time":"3\xc2\xa0months, 3\xc2\xa0weeks","timestamp":1764344227,"status":11,"status_display":"Wrong Answer","runtime":"N/A","url":"/submissions/detail/1841851713/","is_pending":"Not Pending","title":"Largest Rectangle in Histogram","memory":"N/A","code":"class Solution {\\n    public int largestRectangleArea(int[] heights) {\\n        int n = heights.length;\\n        int psmall[] = new int[n];\\n        int nsmall[] = new int[n];\\n        //for previous smaller\\n        Stack<Integer> stack = new Stack<>();\\n        for(int i = 0 ; i < n ; i++)\\n        {\\n            while(!stack.isEmpty() && heights[i] < heights[stack.peek()])\\n            {\\n                stack.pop();\\n            }\\n            if(stack.isEmpty())\\n            {\\n                psmall[i] = -1;\\n            }\\n            else\\n            {\\n                psmall[