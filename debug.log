nced Binary Tree","memory":"45.6 MB","code":"/**\\n * Definition for a binary tree node.\\n * public class TreeNode {\\n *     int val;\\n *     TreeNode left;\\n *     TreeNode right;\\n *     TreeNode() {}\\n *     TreeNode(int val) { this.val = val; }\\n *     TreeNode(int val, TreeNode left, TreeNode right) {\\n *         this.val = val;\\n *         this.left = left;\\n *         this.right = right;\\n *     }\\n * }\\n */\\nclass Solution {\\n    public boolean isBalanced(TreeNode root) {\\n        boolean flag[] = new boolean[1];\\n        flag[0] = true;\\n        find(root,flag);\\n        return (flag[0] == true)?true:false;\\n    }\\n    public int find(TreeNode root,boolean []flag)\\n    {\\n        if(root == null)\\n        {\\n            return 0;\\n        }\\n\\n        int lh = find(root.left,flag);\\n        int rh = find(root.right,flag);\\n\\n        if(Math.abs(lh-rh) > 1)\\n        {\\n            flag[0] = false;\\n        } \\n\\n        return 1+Math.max(lh,rh);\\n\\n\\n    }\\n}","compare_result":"111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"balanced-binary-tree","has_notes":false,"flag_type":1,"frontend_id":727},{"id":1885859238,"question_id":222,"lang":"java","lang_name":"Java","time":"2\xc2\xa0months, 1\xc2\xa0week","timestamp":1768485638,"status":10,"status_display":"Accepted","runtime":"0 ms","url":"/submissions/detail/1885859238/","is_pending":"Not Pending","title":"Count Complete Tree Nodes","memory":"49.9 MB","code":"/**\\n * Definition for a binary tree node.\\n * public class TreeNode {\\n *     int val;\\n *     TreeNode left;\\n *     TreeNode right;\\n *     TreeNode() {}\\n *     TreeNode(int val) { this.val = val; }\\n *     TreeNode(int val, TreeNode left, TreeNode right) {\\n *         this.val = val;\\n *         this.left = left;\\n *         this.right = right;\\n *     }\\n * }\\n */\\nclass Solution {\\n    public int countNodes(TreeNode root) {\\n        if(root == null)\\n        {\\n            return 0;\\n        }\\n\\n        int lh = LeftCount(root);\\n        int rh = RightCount(root);\\n\\n        if(rh == lh)\\n        {\\n            return (int)Math.pow(2,lh)-1;\\n        }\\n        \\n        return 1+countNodes(root.right)+countNodes(root.left);\\n    }\\n    public static int LeftCount(TreeNode root)\\n    {\\n        int count = 1;\\n        while(root.left != null)\\n        {\\n            count++;\\n            root = root.left;\\n        }\\n\\n        return count;\\n    }\\n    public static int RightCount(TreeNode root)\\n    {\\n        int count = 1;\\n        while(root.right != null)\\n        {\\n            count++;\\n            root = root.right;\\n        }\\n\\n        return count;\\n    }\\n}","compare_result":"111111111111111111","title_slug":"count-complete-tree-nodes","has_notes":false,"flag_type":1,"frontend_id":726},{"id":1885858334,"question_id":222,"lang":"java","lang_name":"Java","time":"2\xc2\xa0months, 1\xc2\xa0week","timestamp":1768485580,"status":11,"status_display":"Wrong Answer","runtime":"N/A","url":"/submissions/detail/1885858334/","is_pending":"Not Pending","title":"Count Complete Tree Nodes","memory":"N/A","code":"/**\\n * Definition for a binary tree node.\\n * public class TreeNode {\\n *     int val;\\n *     TreeNode left;\\n *     TreeNode right;\\n *     TreeNode() {}\\n *     TreeNode(int val) { this.val = val; }\\n *     TreeNode(int val, TreeNode left, TreeNode right) {\\n *         this.val = val;\\n *         this.left = left;\\n *         this.right = right;\\n *     }\\n * }\\n */\\nclass Solution {\\n    public int countNodes(TreeNode root) {\\n        if(root == null)\\n        {\\n            return 0;\\n        }\\n\\n        int lh = LeftCount(root);\\n        int rh = RightCount(root);\\n\\n        if(rh == lh)\\n        {\\n            return (int)Math.pow(2,lh)-1;\\n        }\\n        \\n        return 1+lh+rh;\\n    }\\n    public static int LeftCount(TreeNode root)\\n    {\\n        int count = 1;\\n        while(root.left != null)\\n        {\\n            count++;\\n            root = root.left;\\n        }\\n\\n        return count;\\n    }\\n    public static int RightCount(TreeNode root)\\n    {\\n        int count = 1;\\n        while(root.right != null)\\n        {\\n            count++;\\n            root = root.right;\\n        }\\n\\n        return count;\\n    }\\n}","compare_result":"111010011010000000","title_slug":"count-complete-tree-nodes","has_notes":false,"flag_type":1,"frontend_id":725},{"id":1885833896,"question_id":222,"lang":"java","lang_name":"Java","time":"2\xc2\xa0months, 1\xc2\xa0week","timestamp":1768483958,"status":10,"status_display":"Accepted","runtime":"0 ms","url":"/submissions/detail/1885833896/","is_pending":"Not Pending","title":"Count Complete Tree Nodes","memory":"49.8 MB","code":"/**\\n * Definition for a binary tree node.\\n * public class TreeNode {\\n *     int val;\\n *     TreeNode left;\\n *     TreeNode right;\\n *     TreeNode() {}\\n *     TreeNode(int val) { this.val = val; }\\n *     TreeNode(int val, TreeNode left, TreeNode right) {\\n *         this.val = val;\\n *         this.left = left;\\n *         this.right = right;\\n *     }\\n * }\\n */\\nclass Solution {\\n    public int countNodes(TreeNode root) {\\n        if(root == null)\\n        {\\n            return 0;\\n        }\\n\\n        int leftcount = countNodes(root.left);\\n        int rightcount = countNodes(root.right);\\n\\n        return 1+leftcount+rightcount; \\n    }\\n}","compare_result":"111111111111111111","title_slug":"count-complete-tree-nodes","has_notes":false,"flag_type":1,"frontend_id":724},{"id":1885698312,"question_id":543,"lang":"java","lang_name":"Java","time":"2\xc2\xa0months, 1\xc2\xa0week","timestamp":1768472937,"status":10,"status_