g_name":"Java","time":"4\xc2\xa0months, 3\xc2\xa0weeks","timestamp":1761561855,"status":10,"status_display":"Accepted","runtime":"1 ms","url":"/submissions/detail/1813057997/","is_pending":"Not Pending","title":"Merge In Between Linked Lists","memory":"46.1 MB","code":"/**\\n * Definition for singly-linked list.\\n * public class ListNode {\\n *     int val;\\n *     ListNode next;\\n *     ListNode() {}\\n *     ListNode(int val) { this.val = val; }\\n *     ListNode(int val, ListNode next) { this.val = val; this.next = next; }\\n * }\\n */\\nclass Solution {\\n    public ListNode mergeInBetween(ListNode list1, int a, int b, ListNode list2) {\\n        ListNode prev = null;\\n        ListNode start = list1;\\n        ListNode temp = list1;\\n        ListNode end = list1;\\n        for(int i = 0 ; i < a ; i++)\\n        {\\n            prev = start;\\n            start = start.next;\\n        }\\n        for(int i = 0 ; i <  b ; i++)\\n        {\\n            end = end.next;\\n        }\\n        ListNode newHead = end.next;\\n        prev.next = list2;\\n        temp = list2;\\n        while(temp.next!=null)\\n        {\\n            temp = temp.next;\\n        }\\n        temp.next = newHead;\\n        return list1;\\n    }\\n}","compare_result":"1111111111111111111111111111111111111111111111111111111111111","title_slug":"merge-in-between-linked-lists","has_notes":false,"flag_type":1,"frontend_id":518},{"id":1813057343,"question_id":1765,"lang":"java","lang_name":"Java","time":"4\xc2\xa0months, 3\xc2\xa0weeks","timestamp":1761561797,"status":10,"status_display":"Accepted","runtime":"1 ms","url":"/submissions/detail/1813057343/","is_pending":"Not Pending","title":"Merge In Between Linked Lists","memory":"46.5 MB","code":"/**\\n * Definition for singly-linked list.\\n * public class ListNode {\\n *     int val;\\n *     ListNode next;\\n *     ListNode() {}\\n *     ListNode(int val) { this.val = val; }\\n *     ListNode(int val, ListNode next) { this.val = val; this.next = next; }\\n * }\\n */\\nclass Solution {\\n    public ListNode mergeInBetween(ListNode list1, int a, int b, ListNode list2) {\\n        ListNode prev = null;\\n        ListNode start = list1;\\n        ListNode temp = list1;\\n        ListNode end = list1;\\n        for(int i = 0 ; i < a ; i++)\\n        {\\n            prev = start;\\n            start = start.next;\\n        }\\n        for(int i = 0 ; i <  b ; i++)\\n        {\\n            end = end.next;\\n        }\\n        ListNode newHead = end.next;\\n        end.next = null;\\n        prev.next = list2;\\n        temp = list2;\\n        while(temp.next!=null)\\n        {\\n            temp = temp.next;\\n        }\\n        temp.next = newHead;\\n        return list1;\\n    }\\n}","compare_result":"1111111111111111111111111111111111111111111111111111111111111","title_slug":"merge-in-between-linked-lists","has_notes":false,"flag_type":1,"frontend_id":517},{"id":1813055731,"question_id":1765,"lang":"java","lang_name":"Java","time":"4\xc2\xa0months, 3\xc2\xa0weeks","timestamp":1761561645,"status":10,"status_display":"Accepted","runtime":"2 ms","url":"/submissions/detail/1813055731/","is_pending":"Not Pending","title":"Merge In Between Linked Lists","memory":"46.5 MB","code":"/**\\n * Definition for singly-linked list.\\n * public class ListNode {\\n *     int val;\\n *     ListNode next;\\n *     ListNode() {}\\n *     ListNode(int val) { this.val = val; }\\n *     ListNode(int val, ListNode next) { this.val = val; this.next = next; }\\n * }\\n */\\nclass Solution {\\n    public ListNode mergeInBetween(ListNode list1, int a, int b, ListNode list2) {\\n        ListNode prev = null;\\n        ListNode start = list1;\\n        ListNode temp = list1;\\n        ListNode end = list1;\\n        while(temp!=null)\\n        {\\n            if(a!=0)\\n            {\\n                prev = start;\\n                start = start.next;\\n                a--;\\n            }\\n            if(b!=0)\\n            {\\n                end = end.next;\\n                b--;\\n            }\\n            temp = temp.next;\\n        }\\n        ListNode newHead = end.next;\\n        end.next = null;\\n        prev.next = list2;\\n        temp = list2;\\n        while(temp.next!=null)\\n        {\\n            temp = temp.next;\\n        }\\n        temp.next = newHead;\\n        return list1;\\n    }\\n}","compare_result":"1111111111111111111111111111111111111111111111111111111111111","title_slug":"merge-in-between-linked-lists","has_notes":false,"flag_type":1,"frontend_id":516},{"id":1812503298,"question_id":725,"lang":"java","lang_name":"Java","time":"5\xc2\xa0months","timestamp":1761504128,"status":10,"status_display":"Accepted","runtime":"0 ms","url":"/submissions/detail/1812503298/","is_pending":"Not Pending","title":"Split Linked List in Parts","memory":"43.5 MB","code":"/**\\n * Definition for singly-linked list.\\n * public class ListNode {\\n *     int val;\\n *     ListNode next;\\n *     ListNode() {}\\n *     ListNode(int val) { this.val = val; }\\n *     ListNode(int val, ListNode next) { this.val = val; this.next = next; }\\n * }\\n */\\nclass Solution {\\n    public ListNode[] splitListToParts(ListNode head, int k) {\\n        ListNode ans[] = new ListNode[k];\\n        if(head == null || k == 0)\\n        {\\n            ans[0] = head;\\n            return ans;\\n        }\\n        ListNode temp = head;\\n        int size = 0;\\n        while(temp != null)\\n        {\\n            size++;\\n            temp = temp.next;\\n        }\\n        int eachsize = size/k;\\n        int extraNodes = size%k;\\n        temp = head;\\n        for(int i = 0 ; i < k ; i++)\\n        {\\n            int len = 1;\\n            if(temp==null) break;\\n            ListNode currhead = temp;\\n            ListNode prev = null;\\n            while(temp!=null && len<eachsize+1)\\n            {\\n                prev=temp;\\n                temp=temp.next;\\n                len++;\\n            }\\n            if(extraNodes>0)\\n            {\\n                prev = temp;\\n                temp = temp.next;\\n                extraNodes--;\\n            }\\n            prev.next = null;\\n            ans[i] = currhead;\\n        }\\n        return ans;\\n    }\\n}","compare_result":"1111111111111111111111111111111111111111111","title_slug":"split-linked-list-in-parts","has_notes":false,"flag_type":1,"frontend_id":515},{"id":1812149173,"question_id":1656,"lang":"java","lang_name":"Java","time":"5\xc2\xa0months","timestamp":1761477261,"status":10,"status_display":"Accepted","runtime":"128 ms","url":"/submissions/detail/1812149173/","is_pending":"Not Pending","title":"Count Good Triplets","memory":"55 MB","code":"class Solution {\\n    public int countGoodTriplets(int[] arr, int a, int b, int c) {\\n        List<List<Integer>> list = new ArrayList<List<Integer>>();\\n        List<Integer> sublist = new ArrayList<Integer>();\\n        recur(list,sublist,0,arr,a,b,c);\\n        return list.size(); \\n    }\\n    public void recur(List<List<Integer>> list , List<Integer> sublist , int ind , int[] arr, int a , int b , int c)\\n    {\\n        if(sublist.size()==3)\\n        {\\n            if(isGoodTriplet(sublist,a,b,c))\\n            {\\n                list.add(new ArrayList<Integer>(sublist));\\n            }\\n            return;\\n        }\\n\\n        for(int i = ind ; i < arr.length ; i++)\\n        {\\n            sublist.add(arr[i]);\\n            recur(list,sublist,i+1,arr,a,b,c);\\n            sublist.remove(sublist.size()-1);\\n        }\\n    }\\n    public static boolean isGoodTriplet(List<Integer> sublist ,int a , int b , int c)\\n    {\\n        int x = sublist.get(0);\\n        int y = sublist.get(1);\\n        int z = sublist.get(2);\\n\\n        if (Math.abs(x - y) <= a && Math.abs(y - z) <= b && Math.abs(x - z) <= c) {\\n            return true;\\n        }\\n        return false;\\n    }\\n}","compare_result":"11111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"count-good-triplets","has_notes":false,"flag_type":1,"frontend_id":514},{"id":1811558242,"question_id":83,"lang":"java","lang_name":"Java","time":"5\xc2\xa0months","timestamp":1761420403,"status":10,"status_display":"Accepted","runtime":"0 ms","url":"/submissions/detail/1811558242/","is_pending":"Not Pending","title":"Remove Duplicates from Sorted List","memory":"44.4 MB","code":"/**\\n * Definition for singly-linked list.\\n * public class ListNode {\\n *     int val;\\n *     ListNode next;\\n *     ListNode() {}\\n *     ListNode(int val) { this.val = val; }\\n *     ListNode(int val, ListNode next) { this.val = val; this.next = next; }\\n * }\\n */\\nclass Solution {\\n    public ListNode deleteDuplicates(ListNode head) {\\n        if(head == null || head.next == null)\\n        {\\n            return head;\\n        }\\n        ListNode temp = head;\\n        while(temp!=null && temp.next != null)\\n        {\\n            ListNode nextNode = temp.next;\\n            if(temp.val == nextNode.val)\\n            {\\n                temp.next = nextNode.next;\\n                nextNode.next = null;\\n            }\\n            else\\n            {\\n                temp = temp.next;\\n            }\\n            \\n        }\\n        return head;\\n       \\n    }\\n}","compare_result":"111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"remove-duplicates-from-sorted-list","has_notes":false,"flag_type":1,"frontend_id":513},{"id":1811557316,"question_id":83,"lang":"java","lang_name":"Java","time":"5\xc2\xa0months","timestamp":1761420316,"status":11,"status_display":"Wrong Answer","runtime":"N/A","url":"/submissions/detail/1811557316/","is_pending":"Not Pending","title":"Remove Duplicates from Sorted List","memory":"N/A","code":"/**\\n * Definition 