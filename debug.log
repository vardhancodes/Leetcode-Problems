 {   \\n            if(map.getOrDefault(nums[windowEnd],0) == 0)\\n            {\\n                sum += nums[windowEnd];\\n            }\\n            map.put(nums[windowEnd],map.getOrDefault(nums[windowEnd],0)+1);\\n            if(sum >= k)\\n            {\\n                curr = windowEnd-windowStart+1;\\n                ans = Math.min(ans,curr);\\n                while(windowStart <= windowEnd && sum >= k)\\n                {\\n                    if(map.getOrDefault(nums[windowStart],0) == 1)\\n                    {\\n                        sum -= nums[windowStart];\\n                    }\\n                    map.put(nums[windowStart],map.getOrDefault(nums[windowStart],0)-1);\\n                    curr = windowEnd-windowStart+1;\\n                    windowStart++;\\n                }\\n                ans = Math.min(ans,curr);\\n            }\\n            windowEnd++;\\n        }\\n        return (ans == Integer.MAX_VALUE)?-1:ans;\\n    }\\n}","compare_result":"","title_slug":"minimum-subarray-length-with-distinct-sum-at-least-k","has_notes":false,"flag_type":1,"frontend_id":687},{"id":1874518191,"question_id":4152,"lang":"java","lang_name":"Java","time":"2\xc2\xa0months, 3\xc2\xa0weeks","timestamp":1767549581,"status":11,"status_display":"Wrong Answer","runtime":"N/A","url":"/submissions/detail/1874518191/","is_pending":"Not Pending","title":"Minimum Subarray Length With Distinct Sum At Least K","memory":"N/A","code":"class Solution {\\n    public int minLength(int[] nums, int k) {\\n        int windowStart = 0;\\n        int windowEnd = 0;\\n        int ans = Integer.MAX_VALUE;\\n        int curr = 0;\\n        int sum = 0;\\n        HashMap<Integer,Integer> map = new HashMap<>();\\n        while(windowEnd < nums.length)\\n        {   \\n            if(!map.containsKey(nums[windowEnd]))\\n            {\\n                sum += nums[windowEnd];\\n            }\\n            map.put(nums[windowEnd],map.getOrDefault(nums[windowEnd],0)+1);\\n            if