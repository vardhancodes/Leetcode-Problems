st<List<Integer>> verticalTraversal(TreeNode root) {\\n        Queue<CustomNode> queue = new LinkedList<>();\\n        TreeMap<Integer,TreeMap<Integer,List<Integer>>> map = new TreeMap<>();\\n        queue.offer(new CustomNode(root,0,0));\\n        while(!queue.isEmpty())\\n        {\\n            int levelsize = queue.size();\\n            for(int i = 0 ; i < levelsize ; i++)\\n            {\\n                CustomNode cus = queue.poll();\\n                if(map.containsKey(cus.col))\\n                {\\n                    if(map.get(cus.col).containsKey(cus.row))\\n                    {\\n                        map.get(cus.col).get(cus.row).add(cus.node.val);\\n                    }\\n                    else\\n                    {\\n                        List<Integer> sublist = new ArrayList<>(); \\n                        sublist.add(cus.node.val);\\n                        map.get(cus.col).put(cus.row, sublist);\\n                    }\\n                }\\n                else\\n                {\\n                    TreeMap<Integer,List<Integer>> inmap = new TreeMap<>();\\n                    List<Integer> sublist = new ArrayList<>();\\n                    sublist.add(cus.node.val);\\n                    inmap.put(cus.row,sublist);\\n                    map.put(cus.col,inmap);\\n                }\\n                if(cus.node.left != null)\\n                {\\n                    queue.offer(new CustomNode(cus.node.left,cus.col-1,cus.row+1));\\n                }\\n                if(cus.node.right != null)\\n                {\\n                    queue.offer(new CustomNode(cus.node.right,cus.col+1,cus.row+1));\\n                }\\n            }\\n        }\\n        List<List<Integer>> list = new ArrayList<>();\\n        for(Map.Entry<Integer,TreeMap<Integer,List<Integer>>> column : map.entrySet())\\n        {\\n            List<Integer> columnlist = new ArrayList<>();\\n            for(Map.Entry<Integer,List<Integer>> row : column.getValue().entrySet())\\n            {\\n                List<Integer> rowlist = row.getValue();\\n                Collections.sort(rowlist);\\n                columnlist.addAll(rowlist);\\n            }\\n            list.add(columnlist);\\n        }\\n        return list;\\n\\n    }\\n}\\nclass CustomNode{\\n    TreeNode node;\\n    int col;\\n    int row;\\n    CustomNode(TreeNode node , int col , int row)\\n    {\\n        this.node = node;\\n        this.col = col;\\n        this.row = row;\\n    }\\n\\n}","compare_result":"1111111111111111111111111111111111","title_slug":"vertical-order-traversal-of-a-binary-tree","has_notes":false,"flag_type":1,"frontend_id":753},{"id":1892960380,"question_id":28,"lang":"java","lang_name":"Java","time":"2\xc2\xa0months","timestamp":1769064173,"status":10,"status_display":"Accepted","runtime":"0 ms","url":"/submissions/detail/1892960380/","is_pending":"Not Pending","title":"Find the Index of the First Occurrence in a String","memory":"43 MB","code":"class Solution {\\n    public int strStr(String haystack, String needle) {\\n        int ans = -1;\\n        int n = haystack.length(); \\n        int m = needle.length();\\n        for(int i = 0 ; i <= n-m ; i++)\\n        {\\n            if(needle.equals(haystack.substring(i,i+m)))\\n            {\\n                ans = i;\\n                return i;\\n            }\\n        }\\n        return ans;\\n    }\\n}","compare_result":"1111111111111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"find-the-index-of-the-first-occurrence-in-a-string","has_notes":false,"flag_type":1,"frontend_id":752}],"has_next":true,"last_key":""}'
