display":"Accepted","runtime":"2 ms","url":"/submissions/detail/1800607850/","is_pending":"Not Pending","title":"Two Sum II - Input Array Is Sorted","memory":"47.1 MB","code":"class Solution {\\n    public int[] twoSum(int[] numbers, int target) {\\n        int ans[] = new int[2];\\n        int start = 0;\\n        int end = numbers.length-1;\\n        while(start < end)\\n        {\\n            if(numbers[start] + numbers[end] == target)\\n            {\\n                ans[0] = start+1;\\n                ans[1] = end+1;\\n                break;\\n            }\\n            else if(numbers [start] + numbers [end] < target)\\n            {\\n                start++;\\n            }\\n            else\\n            {\\n                end--;\\n            }\\n           \\n        }\\n        return ans;\\n        \\n    }\\n}","compare_result":"111111111111111111111111","title_slug":"two-sum-ii-input-array-is-sorted","has_notes":false,"flag_type":1,"frontend_id":435},{"id":1800584090,"question_id":75,"lang":"java","lang_name":"Java","time":"5\xc2\xa0months, 1\xc2\xa0week","timestamp":1760376793,"status":10,"status_display":"Accepted","runtime":"0 ms","url":"/submissions/detail/1800584090/","is_pending":"Not Pending","title":"Sort Colors","memory":"42.2 MB","code":"class Solution {\\n    public void sortColors(int[] nums) {\\n        int c0 = 0;\\n        int c1 = 0;\\n        int c2 = 0;\\n        for(int i = 0 ; i < nums.length ; i++)\\n        {\\n            if(nums[i] == 0)\\n            {\\n                c0++;\\n            }\\n            else if(nums[i] == 1)\\n            {\\n                c1++;\\n            }\\n            else\\n            {\\n                c2++;\\n            }\\n        }\\n        int index = 0;\\n        while(c0!=0)\\n        {\\n            nums[index] = 0;\\n            c0--;\\n            index++;\\n        }\\n        while(c1!=0)\\n        {\\n            nums[index] = 1;\\n            c1--;\\n            index++;\\n        }\\n        while(c2!=0)\\n        {\\n            nums[index] = 2;\\n            c2--;\\n            index++;\\n        }\\n\\n    }\\n}","compare_result":"11111111111111111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"sort-colors","has_notes":false,"flag_type":1,"frontend_id":434},{"id":1800378063,"question_id":1353,"lang":"java","lang_name":"Java","time":"5\xc2\xa0months, 1\xc2\xa0week","timestamp":1760365211,"status":10,"status_display":"Accepted","runtime":"2 ms","url":"/submissions/detail/1800378063/","is_pending":"Not Pending","title":"Find Resultant Array After Removing Anagrams","memory":"45 MB","code":"class Solution {\\n    public List<String> removeAnagrams(String[] words) {\\n        List<String> list = new ArrayList<String>();\\n        list.add(words[0]);\\n        for(int i = 1 ; i < words.length ; i++)\\n        {\\n            if(!isAnagram(words[i],words[i-1]))\\n            {\\n                list.add(words[i]);\\n            }\\n        }\\n\\n        return list;\\n    }\\n\\n    public static boolean isAnagram(String s, String s1)\\n    {\\n        if(s.length() != s1.length())\\n        {\\n            return false;\\n        }\\n        int freq[] = new int[26];\\n        for(int i = 0 ; i < s.length() ; i++)\\n        {\\n            freq[s.charAt(i)-\'a\']++;\\n            freq[s1.charAt(i)-\'a\']--;\\n        }\\n\\n        for(int i = 0 ; i < freq.length ; i++)\\n        {\\n            if(freq[i] > 0)\\n            {\\n                return false;\\n            }\\n        }\\n        return true;\\n    }\\n}","compare_result":"111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"find-resultant-array-after-removing-anagrams","has_notes":false,"flag_type":1,"frontend_id":433},{"id":1799459815,"question_id":4003,"lang":"java","lang_name":"Java","time":"5\xc2\xa0months, 2\xc2\xa0weeks","timestamp":1760282432,"status":10,"status_display":"Accepted","runtime":"2 ms","url":"/submissions/detail/1799459815/","is_pending":"Not Pending","title":"Longest Fibonacci Subarray","memory":"58.1 MB","code":"class Solution {\\n    public int longestSubarray(int[] nums) {\\n        if(nums.length == 1)\\n        {\\n            return 1;\\n        }\\n        if(nums.length == 2)\\n        {\\n            return 2;\\n        }\\n        int curr = 2;\\n        int max = 2;\\n        for(int i = 2 ; i < nums.length ; i++)\\n            {\\n               if(nums[i] == nums[i-1]+nums[i-2])\\n               {\\n                   curr++;\\n               }\\n                if(nums[i] != nums[i-1]+nums[i-2])\\n                {\\n                    curr = 2;\\n                }\\n                max = Math.max(curr,max);\\n                \\n            }\\n        return max;\\n    }\\n}","compare_result":"","title_slug":"longest-fibonacci-subarray","has_notes":false,"flag_type":1,"frontend_id":432}],"has_next":true,"last_key":""}'
