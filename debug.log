i)-97] += 1;\\n            freq[t.charAt(i)-97] -= 1;\\n        }\\n\\n        for(int i = 0 ; i < freq.length ; i++)\\n        {\\n            if(freq[i] != 0 )\\n            {\\n                return false;\\n            }\\n        }\\n\\n        return true;\\n        \\n    }\\n}","compare_result":"11111111111111111111111111111111111111111111111111111","title_slug":"valid-anagram","has_notes":false,"flag_type":1,"frontend_id":217},{"id":1723025030,"question_id":151,"lang":"java","lang_name":"Java","time":"7\xc2\xa0months, 3\xc2\xa0weeks","timestamp":1754310438,"status":10,"status_display":"Accepted","runtime":"4 ms","url":"/submissions/detail/1723025030/","is_pending":"Not Pending","title":"Reverse Words in a String","memory":"43 MB","code":"class Solution {\\n    public String reverseWords(String s) {\\n        StringBuilder res = new StringBuilder(\\"\\");\\n    int startindex = s.length()-1;\\n    while (startindex>=0)\\n    {\\n        //adding the condition of startindex>=0 is important in the while loop to prevent index out bounds.\\n        while (startindex>=0 && s.charAt(startindex) == \' \')\\n        {\\n            startindex--;\\n        }\\n        if(startindex < 0)\\n        {\\n            break;\\n        }\\n        int endindex = startindex;\\n        while(startindex>=0 && s.charAt(startindex) != \' \')\\n        {\\n            startindex--;\\n        }\\n        if(res.length() == 0)\\n        {\\n            res.append(s.substring(startindex+1, endindex+1));\\n        }\\n        else\\n        {\\n            res.append(\\" \\");\\n            res.append(s.substring(startindex+1, endindex+1));\\n        }\\n    }\\n    return res.toString();\\n\\n\\n\\n        \\n    }\\n}","compare_result":"11111111111111111111111111111111111111111111111111111111111111","title_slug":"reverse-words-in-a-string","has_notes":false,"flag_type":1,"frontend_id":216},{"id":1722909119,"question_id":151,"lang":"java","lang_name":"Java","time":"7\xc2\xa0months, 3\xc2\xa0weeks","timestamp":1754302292,"status":10,"status_display":"Accepted","runtime":"11 ms","url":"/submissions/detail/1722909119/","is_pending":"Not Pending","title":"Reverse Words in a String","memory":"44.8 MB","code":"class Solution {\\n    public String reverseWords(String s) {\\n        String[] ans = s.split(\\" \\");\\n        String result =\\"\\";\\n        for(int i = 0 ; i < ans.length ; i++)\\n        {\\n            if(ans[i] == \\"\\")\\n            {\\n                continue;\\n            }\\n            else\\n            {\\n                if(i == ans.length-1)\\n                {result = ans[i]+result;\\n                }\\n                else\\n                {result = \\" \\"+ans[i]+result;\\n                }\\n\\n            \\n            }\\n        }\\n        return result;\\n\\n\\n        \\n    }\\n}","compare_result":"11111111111111111111111111111111111111111111111111111111111111","title_slug":"reverse-words-in-a-string","has_notes":false,"flag_type":1,"frontend_id":215},{"id":1721864080,"question_id":1,"lang":"java","lang_name":"Java","time":"7\xc2\xa0months, 3\xc2\xa0weeks","timestamp":1754224347,"status":10,"status_display":"Accepted","runtime":"45 ms","url":"/submissions/detail/1721864080/","is_pending":"Not Pending","title":"Two Sum","memory":"45.1 MB","code":"class Solution {\\n    public int[] twoSum(int[] nums, int target) { \\n        int []ans = new int[2]; \\n        for(int i =0 ; i < nums.length-1 ; i++ )\\n        {\\n            for(int j = i+1  ; j < nums.length ; j++)\\n            {\\n                if((nums[i]+nums[j] == target))\\n                {\\n                    ans[0] = i;\\n                    ans[1] = j;\\n                    return ans;\\n                    \\n                }\\n            }\\n        }\\n        return ans;\\n\\n        \\n        \\n    }\\n\\n   \\n}","compare_result":"111111111111111111111111111111111111111111111111111111111111111","title_slug":"two-sum","has_notes":false,"flag_type":1,"frontend_id":214},{"id":1715007880,"question_id":4,"lang":"java","lang_name":"Java","time":"7\xc2\xa0months, 3\xc2\xa0weeks","timestamp":1753730870,"status":10,"status_display":"Accepted","runtime":"1 ms","url":"/submissions/detail/1715007880/","is_pending":"Not Pending","title":"Median of Two Sorted Arrays","memory":"46.1 MB","code":"class Solution {\\n    public double findMedianSortedArrays(int[] nums1, int[] nums2) {\\n        if(nums1.length > nums2.length)\\n        {\\n            return findMedianSortedArrays(nums2 , nums1);\\n        }\\n        int n1 = nums1.length;\\n        int n2 = nums2.length;\\n        int start = 0 ; \\n        int end = n1;\\n\\n        while(start <= end)\\n        {\\n            int cut1 = start+(end-start)/2;\\n            int cut2 = (n1+n2)/2 - cut1;\\n            int L1 = (cut1==0)?Integer.MIN_VALUE:nums1[cut1-1];\\n            int L2 = (cut2==0)?Integer.MIN_VALUE:nums2[cut2-1];\\n            int R1 = (cut1==n1)?Integer.MAX_VALUE:nums1[cut1];\\n            int R2 = (cut2==n2)?Integer.MAX_VALUE:nums2[cut2];\\n\\n            if(L1 <= R2 && L2 <= R1)\\n            {\\n                if((n1+n2)%2 != 0)\\n                {\\n                    return (double)Math.min(R1,R2);\\n                }\\n                else\\n                {\\n                    return (double)(Math.max(L1,L2) + Math.min(R1,R2))/2;\\n                }\\n            }\\n            else if( L1 > R2)\\n            {\\n                end = cut1-1;\\n\\n            }\\n            else\\n            {\\n                start = cut1+1;\\n            }\\n\\n        }\\n        return 0.0;\\n        \\n    }\\n}","compare_result":"","title_slug":"median-of-two-sorted-arrays","has_notes":false,"flag_type":1,"frontend_id":213},{"id":1713820177,"question_id":1,"lang":"java","lang_name":"Java","time":"7\xc2\xa0months, 3\xc2\xa0weeks","timestamp":1753647169,"status":10,"status_display":"Accepted","runtime":"45 ms","url":"/submissions/detail