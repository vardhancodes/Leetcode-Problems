st , List<Integer> sublist)\\n    {\\n        if(sublist.size() == k)\\n        {\\n            list.add(new ArrayList<Integer>(sublist));\\n            return;\\n        }\\n\\n        for(int i = ind+1 ; i <=n ; i++)\\n        {\\n            sublist.add(i);\\n            recur(i,n,k,list,sublist);\\n            sublist.remove(sublist.size()-1);\\n        }\\n\\n    }\\n}","compare_result":"111111111111111111111111111","title_slug":"combinations","has_notes":false,"flag_type":1,"frontend_id":363},{"id":1790004489,"question_id":22,"lang":"java","lang_name":"Java","time":"5\xc2\xa0months, 3\xc2\xa0weeks","timestamp":1759483131,"status":10,"status_display":"Accepted","runtime":"18 ms","url":"/submissions/detail/1790004489/","is_pending":"Not Pending","title":"Generate Parentheses","memory":"45.5 MB","code":"class Solution {\\n    public List<String> generateParenthesis(int n) {\\n        List<String> list = new ArrayList<String>();\\n        recur(n,list,\\"\\");\\n        return list;\\n    }\\n    public void recur(int n , List<String> list , String s )\\n    {\\n        if(s.length() == n*2)\\n        {\\n            if(isValid(s))\\n            {\\n                list.add(s);\\n            }\\n            return;\\n            \\n        }\\n\\n        s = s + \\"(\\";\\n        recur(n,list,s);\\n        s=s.substring(0,s.length()-1);\\n        s=s+\\")\\";\\n        recur(n,list,s);\\n    }\\n\\n    public static boolean isValid(String s)\\n    {\\n        Stack<Character> stack = new Stack<>();\\n        for(int i = 0 ; i < s.length() ; i++)\\n        {\\n            char ch = s.charAt(i);\\n            if(ch == \'(\' )\\n            {\\n                stack.push(ch);\\n            }\\n            else\\n            {\\n                if(stack.isEmpty() && ch == \')\')\\n                {\\n                    return false;\\n                }\\n                else\\n                {\\n                    stack.pop();\\n                }\\n            }\\n        }\\n\\n        return stack.isEmpty();\\n\\n    }\\n}","compare_result":"11111111","title_slug":"generate-parentheses","has_notes":false,"flag_type":1,"frontend_id":362},{"id":1789218997,"question_id":3453,"lang":"java","lang_name":"Java","time":"5\xc2\xa0months, 3\xc2\xa0weeks","timestamp":1759411219,"status":10,"status_display":"Accepted","runtime":"3 ms","url":"/submissions/detail/1789218997/","is_pending":"Not Pending","title":"Generate Binary Strings Without Adjacent Zeros","memory":"46.1 MB","code":"class Solution {\\n    public List<String> validStrings(int n) {\\n        List<String> list = new ArrayList<String>();\\n        recur(n,\\"\\",list);\\n        return list;\\n    }\\n    public void recur(int n , String s ,List<String> list )\\n    {\\n        if(s.length() == n)\\n        {\\n            list.add(s);\\n            return;\\n        }\\n\\n        recur(n,s+\\"1\\",list);\\n        if(s.length() == 0 || s.charAt(s.length()-1) != \'0\')\\n        {\\n            recur(n,s+\\"0\\",list);\\n        }\\n    }\\n\\n}","compare_result":"11111111111111111111","title_slug":"generate-binary-strings-without-adjacent-zeros","has_notes":false,"flag_type":1,"frontend_id":361},{"id":1789209558,"question_id":3453,"lang":"java","lang_name":"Java","time":"5\xc2\xa0months, 3\xc2\xa0weeks","timestamp":1759410552,"status":10,"status_display":"Accepted","runtime":"54 ms","url":"/submissions/detail/1789209558/","is_pending":"Not Pending","title":"Generate Binary Strings Without Adjacent Zeros","memory":"45.4 MB","code":"class Solution {\\n    public List<String> validStrings(int n) {\\n        List<String> list = new ArrayList<String>();\\n        recur(n,\\"\\",list);\\n        return list;\\n    }\\n    public void recur(int n , String s ,List<String> list )\\n    {\\n        if(s.length() == n)\\n        {\\n            if(isValid(s))\\n            {\\n                list.add(s);\\n\\n            }\\n            return;\\n        }\\n\\n        s=s+\\"0\\