   }\\n * }\\n */\\nclass Solution {\\n    public boolean findTarget(TreeNode root, int k) {\\n        HashSet<Integer> set = new HashSet<>();\\n        return dfs(root,k,set);\\n    }\\n\\n    public static boolean dfs(TreeNode root, int target , HashSet<Integer> set)\\n    {\\n        if(root == null)\\n        {\\n            return false;\\n        }\\n\\n        if(set.contains(target-root.val))\\n        {\\n            return true;\\n        }\\n\\n        set.add(root.val);\\n\\n        return dfs(root.left,target,set) || dfs(root.right,target,set);\\n    }\\n}","compare_result":"","title_slug":"two-sum-iv-input-is-a-bst","has_notes":false,"flag_type":1,"frontend_id":875},{"id":1921172926,"question_id":653,"lang":"java","lang_name":"Java","time":"1\xc2\xa0month, 1\xc2\xa0week","timestamp":1771255412,"status":11,"status_display":"Wrong Answer","runtime":"N/A","url":"/submissions/detail/1921172926/","is_pending":"Not Pending","title":"Two Sum IV - Input is a BST","memory":"N/A","code":"/**\\n * Definition for a binary tree node.\\n * public class TreeNode {\\n *     int val;\\n *     TreeNode left;\\n *     TreeNode right;\\n *     TreeNode() {}\\n *     TreeNode(int val) { this.val = val; }\\n *     TreeNode(int val, TreeNode left, TreeNode right) {\\n *         this.val = val;\\n *         this.left = left;\\n *         this.right = right;\\n *     }\\n * }\\n */\\nclass Solution {\\n    public boolean findTarget(TreeNode root, int k) {\\n        HashSet<Integer> set = new HashSet<>();\\n        return dfs(root,k,set);\\n    }\\n\\n    public static boolean dfs(TreeNode root, int target , HashSet<Integer> set)\\n    {\\n        if(root == null)\\n        {\\n            return false;\\n        }\\n\\n        if(set.contains(Math.abs(target-root.val)))\\n        {\\n            return true;\\n        }\\n\\n        set.add(root.val);\\n\\n        return dfs(root.left,target,set) || dfs(root.right,target,set);\\n    }\\n}","compare_result":"","title_slug":"two-sum-iv-input-is-a-bst","has_notes":false,"flag_type":1,"frontend_id":874},{"id":1921168312,"question_id":98,"lang":"java","lang_name":"Java","time":"1\xc2\xa0month, 1\xc2\xa0week","timestamp":1771255132,"status":10,"status_display":"Accepted","runtime":"0 ms","url":"/submissions/detail/1921168312/","is_pending":"Not Pending","title":"Validate Binary Search Tree","memory":"45 MB","code":"/**\\n * Definition for a binary tree node.\\n * public class TreeNode {\\n *     int val;\\n *     TreeNode left;\\n *     TreeNode right;\\n *     TreeNode() {}\\n *     TreeNode(int val) { this.val = val; }\\n *     TreeNode(int val, TreeNode left, TreeNode right) {\\n *         this.val = val;\\n *         this.left = left;\\n *         this.right = right;\\n *     }\\n * }\\n */\\nclass Solution {\\n    public boolean isValidBST(TreeNode root) {\\n        return dfs(root,Long.MIN_VALUE,Long.MAX_VALUE);\\n    }\\n\\n    public static boolean dfs(TreeNode root, long min, long max)\\n    {\\n        if(root == null)\\n        {\\n            return true;\\n        }\\n\\n        if(root.val >= max || root.val <= min)\\n        {\\n            return false;\\n        }\\n\\n        return dfs(root.left,min,root.val) && dfs(root.right,root.val,max);\\n    }\\n\\n}","compare_result":"11111111111111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"validate-binary-search-tree","has_notes":false,"flag_type":1,"frontend_id":873},{"id":1921167034,"question_id":98,"lang":"java","lang_name":"Java","time":"1\xc2\xa0month, 1\xc2\xa0week","timestamp":1771255053,"status":11,"status_display":"Wrong Answer","runtime":"N/A","url":"/submissions/detail/1921167034/","is_pending":"Not Pending","title":"Validate Binary Search Tree","memory":"N/A","code":"/**\\n * Definition for a binary tree node.\\n * public class TreeNode {\\n *     int val;\\n *     TreeNode left;\\n *     TreeNode right;\\n *     TreeNode() {}\\n *     TreeNode(int val) { this.val = val; }\\n *     TreeNode(int val, TreeNode left, TreeNode right) {\\n *         this.val = val;\\n *         this.left = left;\\n *         this.right = right;\\n *     }\\n * }\\n */\\nclass Solution {\\n    public boolean isValidBST(TreeNode root) {\\n        return dfs(root,Integer.MIN_VALUE,Integer.MAX_VALUE);\\n    }\\n\\n    public static boolean dfs(TreeNode root, int min, int max)\\n    {\\n        if(root == null)\\n        {\\n            return true;\\n        }\\n\\n        if(root.val >= max || root.val <= min)\\n        {\\n            return false;\\n        }\\n\\n        return dfs(root.left,min,root.val) && dfs(root.right,root.val,max);\\n    }\\n\\n}","compare_result":"11111111111111111111111111111111111111111111111111111111111111001111010101110011110111","title_slug":"validate-binary-search-tree","has_notes":false,"flag_type":1,"frontend_id":872}],"has_next":true,"last_key":""}'
