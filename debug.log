rry != 0)\\n        {\\n            int val1 = (l1 == null)?0:l1.val;\\n            int val2 = (l2 == null)?0:l2.val;\\n            int value = val1 + val2 + carry;\\n            ListNode newNode = new ListNode(value%10);\\n            carry = value/10;\\n            if(head == null)\\n            {\\n                head = newNode;\\n                temp = newNode;\\n            }\\n            else\\n            {\\n                temp.next = newNode;\\n                temp = newNode;\\n            }\\n            if(l1!=null)\\n            {\\n                l1=l1.next;\\n            }\\n            if(l2!=null)\\n            {\\n                l2 = l2.next;\\n            }\\n        }\\n        return head;\\n    }\\n}","compare_result":"","title_slug":"add-two-numbers","has_notes":false,"flag_type":1,"frontend_id":767},{"id":1895594235,"question_id":526,"lang":"java","lang_name":"Java","time":"2\xc2\xa0months","timestamp":1769276262,"status":10,"status_display":"Accepted","runtime":"626 ms","url":"/submissions/detail/1895594235/","is_pending":"Not Pending","title":"Beautiful Arrangement","memory":"42 MB","code":"class Solution {\\n    public int countArrangement(int n) {\\n        List<Integer> list = new ArrayList<>();\\n        int []count = new int[1];\\n        recur(list,n,count);\\n        return count[0];\\n    }\\n\\n    public static void recur(List<Integer> list, int n, int[] count)\\n    {\\n        if(list.size() == n)\\n        {\\n            \\n            count[0]++;\\n            return;\\n        }\\n        for(int i = 1 ; i <= n ; i++)\\n        {\\n            if(!list.contains(i) && (i%(list.size()+1) == 0 || (list.size()+1)%i == 0))\\n            {\\n                list.add(i);\\n                recur(list,n,count);\\n                list.remove(list.size()-1);\\n            }\\n        }\\n    }\\n\\n        // public static boolean isBeautiful(List<Integer> list)\\n        // {\\n        //     for(int i = 0 ; i < list.size() ; i++)