r> sublist = new ArrayList<>(levelsize);\\n            for(int i = 0 ; i < levelsize ; i++)\\n            {\\n                TreeNode node = queue.poll();\\n                sublist.add(node.val);\\n                if(node.left != null)\\n                {\\n                    queue.offer(node.left);\\n                }\\n                if(node.right != null)\\n                {\\n                    queue.offer(node.right);\\n                }\\n            }\\n            list.add(sublist);\\n            \\n        }\\n        return list;\\n    }\\n}","compare_result":"11111111111111111111111111111111111","title_slug":"binary-tree-level-order-traversal","has_notes":false,"flag_type":1,"frontend_id":667},{"id":1863370247,"question_id":4138,"lang":"java","lang_name":"Java","time":"3\xc2\xa0months","timestamp":1766499634,"status":10,"status_display":"Accepted","runtime":"23 ms","url":"/submissions/detail/1863370247/","is_pending":"Not Pending","title":"Minimum Deletion Cost to Make All Characters Equal","memory":"112.1 MB","code":"class Solution {\\n    public long minCost(String s, int[] cost) {\\n        HashMap<Character,Long> map = new HashMap<>();\\n        long total = 0;\\n        for(int i = 0 ; i < s.length() ; i++)\\n        {\\n            char ch = s.charAt(i);\\n            map.put(ch,map.getOrDefault(ch,0L)+cost[i]);\\n            total += cost[i];\\n        }\\n        long max = 0;\\n        if(map.size() == 1)\\n        {\\n            return 0;\\n        }\\n        for(Map.Entry<Character,Long> entry : map.entrySet())\\n        {\\n            if(entry.getValue()>max)\\n            {\\n                max = entry.getValue();\\n            }\\n        }\\n        return total - max;\\n    }\\n}","compare_result":"","title_slug":"minimum-deletion-cost-to-make-all-characters-equal","has_notes":false,"flag_type":1,"frontend_id":666},{"id":1863359218,"question_id":4138,"lang":"java","lang_name":"Java","time":"3\xc2\xa0months","timestamp":1766498814,"