00);\\n        int ans = 0;\\n        int index = 0;\\n        for(int i = 0 ; i < s.length()-1 ; i++)\\n        {\\n            char ch = s.charAt(i);\\n            char nextchar = s.charAt(i+1);\\n            if((ch == \'I\' && (nextchar == \'V\' || nextchar == \'X\')) \\n            || (ch == \'X\' && (nextchar == \'L\' || nextchar == \'C\')) \\n            || (ch == \'C\' && (nextchar == \'D\' || nextchar == \'M\')))\\n            {\\n                ans+=map.get(nextchar)-map.get(ch);\\n                i++;\\n                index++;\\n            }\\n            else\\n            {\\n                ans+=map.get(ch);\\n            }\\n            index++;\\n        }\\n        \\n        return (index == s.length())?ans:ans+(map.get(s.charAt(s.length()-1)));\\n\\n\\n    }\\n}","compare_result":"","title_slug":"roman-to-integer","has_notes":false,"flag_type":1,"frontend_id":580},{"id":1825821646,"question_id":13,"lang":"java","lang_name":"Java","time":"4\xc2\xa0months, 2\xc2\xa0weeks","timestamp":1762764865,"status":11,"status_display":"Wrong Answer","runtime":"N/A","url":"/submissions/detail/1825821646/","is_pending":"Not Pending","title":"Roman to Integer","memory":"N/A","code":"class Solution {\\n    public int romanToInt(String s) {\\n        // Create a map for Roman numeral values\\n        HashMap<Character, Integer> map = new HashMap<>();\\n        map.put(\'I\', 1);\\n        map.put(\'V\', 5);\\n        map.put(\'X\', 10);\\n        map.put(\'L\', 50);\\n        map.put(\'C\', 100);\\n        map.put(\'D\', 500);\\n        map.put(\'M\', 1000);\\n        \\n        int ans = 0;\\n\\n        // Loop through the string, checking if subtraction is needed\\n        for (int i = 0; i < s.length() - 1; i++) {\\n            char ch = s.charAt(i);\\n            char nextchar = s.charAt(i + 1);\\n            \\n            // Keep the original condition for subtraction\\n            if ((ch == \'I\' && (nextchar == \'V\' || nextchar == \'X\')) \\n                || (ch == \'X\' && (nextchar == \'L\' || nextchar == \'C\')) \\n                || (ch == \'C\' && (nextchar == \'D\' || nextchar == \'M\'))) {\\n                \\n                ans += map.get(nextchar) - map.get(ch);\\n                i++;  // Increment i here because we are skipping the next character\\n            } else {\\n                ans += map.get(ch);\\n            }\\n        }\\n\\n        // Add the value of the last character\\n        ans += map.get(s.charAt(s.length() - 1));\\n\\n        return ans;\\n    }\\n}\\n","compare_result":"","title_slug":"roman-to-integer","has_notes":false,"flag_type":1,"frontend_id":579},{"id":1825818320,"question_id":13,"lang":"java","lang_name":"Java","time":"4\xc2\xa0months, 2\xc2\xa0weeks","timestamp":1762764558,"status":10,"status_display":"Accepted","runtime":"4 ms","url":"/submissions/detail/1825818320/","is_pending":"Not Pending","title":"Roman to Integer","memory":"46.6 MB","code":"class Solution {\\n    public int romanToInt(String s) {\\n        HashMap<Character, Integer> map = new HashMap<>();\\n        map.put(\'I\',1);\\n        map.put(\'V\',5);\\n        map.put(\'X\',10);\\n        map.put(\'L\',50);\\n        map.put(\'C\',100);\\n        map.put(\'D\',500);\\n        map.put(\'M\',1000);\\n        int ans = 0;\\n        int index = 0;\\n        for(int i = 0 ; i < s.length()-1 ; i++)\\n        {\\n            char ch = s.charAt(i);\\n            char nextchar = s.charAt(i+1);\\n            if((ch == \'I\' && (nextchar == \'V\' || nextchar == \'X\')) \\n            || (ch == \'X\' && (nextchar == \'L\' || nextchar == \'C\')) \\n            || (ch == \'C\' && (nextchar == \'D\' || nextchar == \'M\')))\\n            {\\n                ans+=map.get(nextchar)-map.get(ch);\\n                i++;\\n                index++;\\n            }\\n            else\\n            {\\n                ans+=map.get(ch);\\n            }\\n            index++;\\n        }\\n        \\n        return (index == s.l