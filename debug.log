 sublist, int index )\\n    {\\n        if(target == 0)\\n        {\\n            list.add(new ArrayList<>(sublist));\\n            return;\\n        }\\n\\n        if(target < 0)\\n        {\\n            return;\\n        }\\n\\n        for(int i = index ; i < candidates.length ; i++)\\n        {\\n            if(target >= candidates[i])\\n            {\\n                sublist.add(candidates[i]);\\n                recur(candidates,target-candidates[i],list,sublist,i);\\n                sublist.remove(sublist.size()-1);\\n            }\\n        }\\n\\n    }\\n}","compare_result":"1111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"combination-sum","has_notes":false,"flag_type":1,"frontend_id":745},{"id":1889771431,"question_id":22,"lang":"java","lang_name":"Java","time":"2\xc2\xa0months, 1\xc2\xa0week","timestamp":1768820495,"status":10,"status_display":"Accepted","runtime":"17 ms","url":"/submissions/detail/1889771431/","is_pending":"Not Pending","title":"Generate Parentheses","memory":"47.2 MB","code":"class Solution {\\n    public List<String> generateParenthesis(int n) {\\n        List<String> list = new ArrayList<>();\\n        recur(n,list,\\"\\");\\n        return list;\\n    }\\n    public static void recur(int n , List<String> list , String ans)\\n    {\\n        if(ans.length() == n*2)\\n        {\\n            if(isValid(ans))\\n            {\\n                list.add(ans);   \\n            }\\n            return;\\n        }\\n        \\n        recur(n,list,ans+\\"(\\");\\n        recur(n,list,ans+\\")\\");\\n    }\\n\\n    public static boolean isValid(String ans)\\n    {\\n        Stack<Character> stack = new Stack<>();\\n        for(int i = 0 ; i < ans.length() ; i++)\\n        {\\n            char ch = ans.charAt(i);\\n            if(ch == \'(\')\\n            {\\n                stack.push(ch);\\n            }\\n            else\\n            {\\n                if(ch == \')\' && stack.isEmpty())\\n                {\\n                    return false;\\n                }\\n                else\\n                {\\n                    stack.pop();\\n                }\\n            }\\n        }\\n\\n        return stack.isEmpty();\\n    }\\n}","compare_result":"11111111","title_slug":"generate-parentheses","has_notes":false,"flag_type":1,"frontend_id":744},{"id":1889757315,"question_id":17,"lang":"java","lang_name":"Java","time":"2\xc2\xa0months, 1\xc2\xa0week","timestamp":1768819328,"status":10,"status_display":"Accepted","runtime":"3 ms","url":"/submissions/detail/1889757315/","is_pending":"Not Pending","title":"Letter Combinations of a Phone Number","memory":"49.8 MB","code":"class Solution {\\n    public List<String> letterCombinations(String digits) {\\n        HashMap<Character,String> map = new HashMap<>();\\n        List<String> list = new ArrayList<>();\\n        map.put(\'2\',\\"abc\\");\\n        map.put(\'3\',\\"def\\");\\n        map.put(\'4\',\\"ghi\\");\\n        map.put(\'5\',\\"jkl\\");\\n        map.put(\'6\',\\"mno\\");\\n        map.put(\'7\',\\"pqrs\\");\\n        map.put(\'8\',\\"tuv\\");\\n        map.put(\'9\',\\"wxyz\\");\\n        \\n        recur(digits,map,list,0,\\"\\");\\n        return list;\\n    }\\n    public static void recur(String digits , HashMap<Character,String> map, List<String> list, int index, String ans)\\n    {\\n        if(ans.length() == digits.length())\\n        {\\n            list.add(ans);\\n            return;\\n        }\\n\\n\\n        for(int i = 0 ; i < map.get(digits.charAt(index)).length() ; i++)\\n        {\\n            recur(digits,map,list,index+1,ans+map.get(digits.charAt(index)).charAt(i));\\n        }\\n    } \\n}","compare_result":"111111111111111111111111","title_slug":"letter-combinations-of-a-phone-number","has_notes":false,"flag_type":1,"frontend_id":743},{"id":1889726207,"question_id":322,"lang":"java","lang_nam