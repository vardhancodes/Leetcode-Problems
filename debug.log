 to Obtain Zero","memory":"42.2 MB","code":"class Solution {\\n    public int countOperations(int num1, int num2) {\\n        int count = 0;\\n        if(num1 == num2 && num1 != 0 && num2!= 0)\\n        {\\n            return 1;\\n        }\\n        while(num1!= 0 && num2!= 0)\\n        {\\n            if(num1 < num2)\\n            {\\n                num2 = num2-num1;\\n            }\\n            else\\n            {\\n                num1 = num1-num2;\\n            }\\n            count++;\\n        }\\n        return count;\\n    }\\n}","compare_result":"11111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"count-operations-to-obtain-zero","has_notes":false,"flag_type":1,"frontend_id":576},{"id":1825058798,"question_id":2288,"lang":"java","lang_name":"Java","time":"4\xc2\xa0months, 2\xc2\xa0weeks","timestamp":1762689174,"status":11,"status_display":"Wrong Answer","runtime":"N/A","url":"/submissions/detail/1825058798/","is_pending":"Not Pending","title":"Count Operations to Obtain Zero","memory":"N/A","code":"class Solution {\\n    public int countOperations(int num1, int num2) {\\n        int count = 0;\\n        if(num1 == num2)\\n        {\\n            return 1;\\n        }\\n        while(num1!= 0 && num2!= 0)\\n        {\\n            if(num1 < num2)\\n            {\\n                num2 = num2-num1;\\n            }\\n            else\\n            {\\n                num1 = num1-num2;\\n            }\\n            count++;\\n        }\\n        return count;\\n    }\\n}","compare_result":"11111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111110111111111111111111111111111111111111111111111111","title_slug":"count-operations-to-obtain-zero","has_notes":false,"flag_type":1,"frontend_id":575},{"id":1823156145,"question_id":299,"lang":"java","lang_name":"Java","time":"4\xc2\xa0months, 2\xc2\xa0weeks","timestamp":1762507180,"status":11,"status_display":"Wrong Answer","runtime":"N/A","url":"/submissions/detail/1823156145/","is_pending":"Not Pending","title":"Bulls and Cows","memory":"N/A","code":"class Solution {\\n    public String getHint(String secret, String guess) {\\n        String ans = \\"\\";\\n        int bulls = 0;\\n        int cows = 0;\\n        HashMap<Character,Integer> map = new HashMap<>();\\n        for(int i = 0 ; i < secret.length() ; i++)\\n        {\\n            map.put(secret.charAt(i),map.getOrDefault(secret.charAt(i),0)+1);\\n        }\\n        for(int i = 0; i < secret.length(); i++)\\n        {\\n            char ch1 = guess.charAt(i);\\n            char ch2 = secret.charAt(i);\\n            if(ch1 == ch2)\\n            {\\n                bulls++;\\n                map.put(ch1,map.getOrDefault(ch1,0)-1);\\n            }\\n            else\\n            {\\n                if(map.containsKey(ch1) && map.get(ch1) > 0)\\n                {\\n                    map.put(ch1,map.getOrDefault(ch1,0)-1);\\n                    cows++;\\n                    if(map.get(ch1) == 0)\\n                    {\\n                        map.remove(ch1);\\n                    }\\n                }\\n            }\\n\\n        }\\n        ans = Integer.toString(bulls) + \\"A\\" + Integer.toString(cows) + \\"B\\";\\n        return ans;\\n        \\n    }\\n}","compare_result":"11111111111111111111111101111111111101111111111111111101111111111111111110000100110101010010011001010101011000011100010000000000000000000000000000000000","title_slug":"bulls-and-cows","has_notes":false,"flag_type":1,"frontend_id":574},{"id":1823137953,"question_id":17,"lang":"java","lang_name":"Java","time":"4\xc2\xa0months, 2\xc2\xa0weeks","timestamp":1762505232,"status":10,"status_display":"Accepted","runtime":"3 ms","url":"/submissions/detail/1823137953/","is_pending":"Not Pending","title":"Letter Combinations of a Phone Number","memory":"48.2 MB","code":"class Solution {\\n    public List<String> letterCombinations(String digits) {\\n        List<String> list = new ArrayList<>();\\n        HashMap<String,String> map = new HashMap<>();\\n        map.put(\\"2\\",\\"abc\\");\\n        map.put(\\"3\\",\\"def\\");\\n        map.put(\\"4\\",\\"ghi\\");\\n        map.put(\\"5\\",\\"jkl\\");\\n        map.put(\\"6\\",\\"mno\\");\\n        map.put(\\"7\\",\\"pqrs\\");\\n        map.put(\\"8\\",\\"tuv\\");\\n        map.put(\\"9\\",\\"wxyz\\");\\n        String ans = \\"\\";\\n        recur(list,map,0,ans,digits);\\n        return list;\\n    }\\n    public static void recur(List<String> list, HashMap<String,String> map, int ind, String ans, String digits)\\n    {\\n        if(ans.length() == digits.length())\\n        {\\n            list.add(ans);\\n            return;\\n        }\\n        String s1 = map.get(String.valueOf(digits.charAt(ind)));\\n        for(int i = 0 ; i < s1.length() ; i++)\\n        {\\n            recur(list,map,ind+1,ans+s1.charAt(i),digits);\\n        }\\n    }\\n}","compare_result":"111111111111111111111111","title_slug":"letter-combinations-of-a-phone-number","has_notes":false,"flag_type":1,"frontend_id":573},{"id":1822679718,"question_id":4051,"lang":"java","lang_name":"Java","time":"4\xc2\xa0months, 2\xc2\xa0weeks","timestamp":1762452777,"status":10,"status_display":"Accepted","runtime":"1 ms","url":"/submissions/detail/1822679718/","is_pending":"Not Pending","title":"Remove Zeros in Decimal Representation","memory":"42.6 MB","code":"class Solution {\\n    public long removeZeros(long n) {\\n        long temp = 0;\\n        long count = 1;\\n        while(n!=0)\\n        {\\n            if(n%10 != 0)\\n            {\\n                temp = (n%10)*count + temp;\\n                count=count*10;\\n                \\n            }\\n            n=n/10;\\n        }\\n        return temp;\\n    }\\n}","compare_result":"","title_slug":"remove-zeros-in-decimal-representation","has_notes":false,"flag_type":1,"frontend_id":572}],"has_next":true,"last_key":""}'
