ubmissions/detail/1814098859/","is_pending":"Not Pending","title":"Delete Nodes From Linked List Present in Array","memory":"67.9 MB","code":"/**\\n * Definition for singly-linked list.\\n * public class ListNode {\\n *     int val;\\n *     ListNode next;\\n *     ListNode() {}\\n *     ListNode(int val) { this.val = val; }\\n *     ListNode(int val, ListNode next) { this.val = val; this.next = next; }\\n * }\\n */\\nclass Solution {\\n    public ListNode modifiedList(int[] nums, ListNode head) {\\n        HashMap<Integer,Integer> map = new HashMap<Integer,Integer>();\\n        for(int i = 0 ; i < nums.length ; i++)\\n        {\\n            map.put(nums[i],map.getOrDefault(nums[i],0)+1);\\n        }\\n        ListNode newHead = new ListNode(-1);\\n        ListNode temp = head;\\n        ListNode tail = newHead;\\n        while(temp!=null)\\n        {\\n            if(map.containsKey(temp.val))\\n            {\\n                temp = temp.next;\\n                continue;\\n            }\\n            else\\n            {\\n                ListNode nextNode = temp.next;\\n                tail.next = temp;\\n                tail = tail.next;\\n                temp.next = null;\\n                temp = nextNode;\\n            }\\n        }\\n        return newHead.next;\\n\\n    }\\n}","compare_result":"","title_slug":"delete-nodes-from-linked-list-present-in-array","has_notes":false,"flag_type":1,"frontend_id":527},{"id":1814026536,"question_id":2128,"lang":"java","lang_name":"Java","time":"4\xc2\xa0months, 3\xc2\xa0weeks","timestamp":1761654722,"status":10,"status_display":"Accepted","runtime":"0 ms","url":"/submissions/detail/1814026536/","is_pending":"Not Pending","title":"Reverse Prefix of Word","memory":"41.8 MB","code":"class Solution {\\n    public String reversePrefix(String word, char ch) {\\n        StringBuilder s1 = new StringBuilder(word);\\n        int pointer = 0;\\n        for(int i = 0 ; i < s1.length() ; i++)\\n        {\\n            if(ch == s1.charAt(i))\\n            {\\n                pointer = i;\\n                break;\\n            }\\n        }\\n        reverse(s1,pointer);\\n        return s1.toString();\\n    }\\n        \\n    public static StringBuilder reverse(StringBuilder s1 , int i)\\n    {\\n        int start = 0;\\n        int end = i;\\n        while(start < end)\\n        {\\n            char firstchar = s1.charAt(start);\\n            char lastchar = s1.charAt(end);\\n            s1.setCharAt(start,lastchar);\\n            s1.setCharAt(end,firstchar);\\n            start++;\\n            end--;\\n        }\\n        return s1;\\n    }\\n    \\n    \\n}","compare_result":"1111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"reverse-prefix-of-word","has_notes":false,"flag_type":1,"frontend_id":526},{"id":1813927656,"question_id":1072,"lang":"java","lang_name":"Java","time":"4\xc2\xa0months, 3\xc2\xa0weeks","timestamp":1761645615,"status":10,"status_display":"Accepted","runtime":"27 ms","url":"/submissions/detail/1813927656/","is_pending":"Not Pending","title":"Next Greater Node In Linked List","memory":"47 MB","code":"/**\\n * Definition for singly-linked list.\\n * public class ListNode {\\n *     int val;\\n *     ListNode next;\\n *     ListNode() {}\\n *     ListNode(int val) { this.val = val; }\\n *     ListNode(int val, ListNode next) { this.val = val; this.next = next; }\\n * }\\n */\\nclass Solution {\\n    public int[] nextLargerNodes(ListNode head) {\\n        ListNode temp = head;\\n        List<Integer> list = new ArrayList<>();\\n        while(temp!=null)\\n        {\\n            list.add(temp.val);\\n            temp = temp.next;\\n        }\\n        int[] ans = new int[list.size()];\\n        Stack<Integer> stack = new Stack<>();\\n        for(int i = list.size()-1 ; i >=0 ; i--)\\n        {\\n            while(!stack.isEmpty() && stack.peek()<=list.get(i))\\n            {\\n                stack.pop();\\n            }\\n            if(!stack.isEmpty())\\n            {\\n                ans[i] = stack.peek(); \\n            }\\n            else\\n            {\\n                ans[i] = 0;\\n            }\\n            stack.push(list.get(i));\\n        }\\n        return ans;\\n    }\\n}","compare_result":"1111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"next-greater-node-in-linked-list","has_notes":false,"flag_type":1,"frontend_id":525},{"id":1813172361,"question_id":143,"lang":"java","lang_name":"Java","time":"4\xc2\xa0months, 3\xc2\xa0weeks","timestamp":1761572048,"status":10,"status_display":"Accepted","runtime":"2 ms","url":"/submissions/detail/1813172361/","is_pending":"Not Pending","title":"Reorder List","memory":"48.6 MB","code":"/**\\n * Definition for singly-linked list.\\n * public class ListNode {\\n *     int val;\\n *     ListNode next;\\n *     ListNode() {}\\n *     ListNode(int val) { this.val = val; }\\n *     ListNode(int val, ListNode next) { this.val = val; this.next = next; }\\n * }\\n */\\nclass Solution {\\n    public void reorderList(ListNode head) {\\n        if(head == null || head.next == null)\\n        {\\n            return;\\n        }\\n        ListNode fast = head;\\n        ListNode slow = head;\\n        while(fast!=null && fast.next!=null)\\n        {\\n            slow = slow.next;\\n            fast = fast.next.next;\\n        }\\n        ListNode newHead = slow.next;\\n        slow.next = null;\\n        newHead = reverse(newHead);\\n        ListNode t1 = head;\\n        ListNode t2 = newHead;\\n        while(t2!=null)\\n        {\\n            ListNode m1 = t1.next;\\n            ListNode m2 = t2.next;\\n            t2.next = m1;\\n            t1.next = t2;\\n            t1 = m1;\\n            t2 = m2;\\n        }\\n        \\n    }\\n    public static ListNode reverse(ListNode head)\\n    {\\n        ListNode prev = null;\\n        ListNode curr = head;\\n        while(curr!=null)\\n        {\\n            ListNode nextNode = curr.next;\\n            curr.next = prev;\\n            prev = curr;\\n            curr = nextNode;\\n        }\\n        return prev;\\n    }\\n}","compare_result":"111111111111","title_slug":"reorder-list","has_notes":false,"flag_type":1,"frontend_id":524},{"id":1813118374,"question_id":2299,"lang":"java","lang_name":"Java","time":"4\xc2\xa0months, 3\xc2\xa0weeks","timestamp":1761567596,"status":10,"status_display":"Accepted","runtime":"5 ms","url":"/submissions/detail/1813118374/","is_pending":"Not Pending","title":"Merge Nodes in Between Zeros","memory":"83.4 MB","code":"/**\\n * Definition for singly-linked list.\\n * public class ListNode {\\n *     int val;\\n *     ListNode next;\\n *     ListNode() {}\\n *     ListNode(int val) { this.val = val; }\\n *     ListNode(int val, ListNode next) { this.val = val; this.next = next; }\\n * }\\n */\\nclass Solution {\\n    public ListNode mergeNodes(ListNode head) {\\n        ListNode temp = head.next;;\\n        ListNode newHead = null;\\n        ListNode tail = null;\\n        int sum = 0;\\n        while(temp!=null)\\n        {\\n            if(temp.val==0)\\n            {\\n                if(newHead == null)\\n                {\\n                    newHead = new ListNode(sum);\\n                    tail = newHead;\\n                }\\n                else\\n                {\\n                    tail.next = new ListNode(sum);\\n                    tail = tail.next;\\n                }\\n                sum=0;\\n            }\\n            else\\n            {\\n                sum+=temp.val;\\n            }\\n            temp = temp.next;\\n\\n        }\\n        return newHead;\\n        \\n    }\\n}","compare_result":"111111111111111111111111111111111111111","title_slug":"merge-nodes-in-between-zeros","has_notes":false,"flag_type":1,"frontend_id":523},{"id":1813079103,"question_id":2236,"lang":"java","lang_name":"Java","time":"4\xc2\xa0months, 3\xc2\xa0weeks","timestamp":1761563840,"status":10,"status_display":"Accepted","runtime":"5 ms","url":"/submissions/detail/1813079103/","is_pending":"Not Pending","title":"Maximum Twin Sum of a Linked List","memory":"67 MB","code":"/**\\n * Definition for singly-linked list.\\n * public class ListNode {\\n *     int val;\\n *     ListNode next;\\n *     ListNode() {}\\n *     ListNode(int val) { this.val = val; }\\n *     ListNode(int val, ListNode next) { this.val = val; this.next = next; }\\n * }\\n */\\nclass Solution {\\n    public int pairSum(ListNode head) {\\n        ListNode prev = null;\\n        ListNode fast = head;\\n        ListNode slow = head;\\n        ListNode temp = null;\\n        ListNode newHead = null;\\n        while(fast!=null)\\n        {\\n            prev = slow;\\n            if(newHead == null)\\n            {\\n                newHead = new ListNode(prev.val);\\n                temp = newHead;\\n            }\\n            else\\n            {\\n                newHead = new ListNode(prev.val);\\n                newHead.next = temp;\\n                temp = newHead;\\n            }\\n            slow = slow.next;\\n            fast = fast.next.next;\\n        }\\n        int ans = 0;\\n        while(temp!=null && slow != null)\\n        {\\n            int sum = temp.val+slow.val;\\n            ans = Math.max(ans,sum);\\n            temp=temp.next;\\n            slow=slow.next;\\n\\n        }\\n        return ans;\\n\\n    }\\n}","compare_result":"1111111111111111111111111111111111111111111111","title_slug":"maximum-twin-sum-of-a-linked-list","has_notes":false,"flag_type":1,"frontend_id":522},{"id":1813072090,"question_id":528,"lang":"java","lang_name":"Java","time":"4\xc2\xa0months, 3\xc2\xa0weeks","timestamp":1761563180,"status":10,"status_display":"Accepted","runtime":"1 ms","url":"/submissions/detail/1813072090/","is_pending":"Not Pending","title":"Swapping Nodes in a Linked List","memory":"58.9 MB","code":"/**\\n * Definition for singly-linked list.\\n * public class ListNode {\\n *     int val;\\n *     ListNode next;\\n *     ListNode() {}\\n *     ListNode(int val) { this.val = val; }\\n *     ListNode(int val, ListNode next) { this.val = val; this.next = next; }\\n * }\\n */\\nclass Solution {\\n    public ListNode swapNodes(ListNode head, int k) {\\n        if (head == null || head.next == null) return head;\\n\\n        ListNode first = head;\\n        ListNode second = head;\\n        ListNode prev1 = null;\\n\\n        for (int i = 0; i < k - 1; i++) {\\n            prev1 = first;\\n            first = first.next;\\n        }\\n\\n        ListNode nextNode1 = first.next;\\n        ListNode temp = first;\\n        ListNode prev2 = null;\\n\\n        while (temp.next != null) {\\n            prev2 = second;\\n            second = second.next;\\n            temp = temp.next;\\n        }\\n\\n        if (first == second) return head;\\n\\n        ListNode nextNode2 = second.next;\\n\\n        if (first.next == second) {\\n            if (prev1 != null) prev1.next = second;\\n            else head = second;\\n            second.next = first;\\n            first.next = nextNode2;\\n            return head;\\n        }\\n\\n        if (second.next == first) {\\n            if (prev2 != null) prev2.next = first;\\n            else head = first;\\n            first.next = second;\\n            second.next = nextNode1;\\n            return head;\\n        }\\n\\n        if (prev1 != null) prev1.next = second;\\n        else head = second;\\n\\n        if (prev2 != null) prev2.next = first;\\n        else head = first;\\n\\n        first.next = nextNode2;\\n        second.next = nextNode1;\\n\\n        return head;\\n    }\\n\\n}\\n","compare_result":"111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"swapping-nodes-in-a-linked-list","has_notes":false,"flag_type":1,"frontend_id":521},{"id":1813070861,"quest