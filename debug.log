292610/","is_pending":"Not Pending","title":"Custom Sort String","memory":"41.9 MB","code":"class Solution {\\n    public String customSortString(String order, String s) {\\n        HashMap<Character,Integer> map = new HashMap<>();\\n        StringBuilder ans = new StringBuilder();\\n        for(int i = 0 ; i < s.length() ; i++)\\n        {\\n            char ch = s.charAt(i);\\n            map.put(ch,map.getOrDefault(ch,0)+1);\\n        }\\n        for(int i = 0 ; i < order.length() ; i++)\\n        {\\n            char ch = order.charAt(i);\\n            if(map.containsKey(ch))\\n            {\\n                int count = map.get(ch);\\n                while(count!=0)\\n                {\\n                    ans.append(ch);\\n                    count--;\\n                }\\n                map.remove(ch);\\n            }\\n        }\\n        for(Map.Entry<Character,Integer> entry : map.entrySet())\\n        {\\n            int count = entry.getValue();\\n            char ch = entry.getKey();\\n            while(count!=0)\\n            {\\n                ans.append(ch);\\n                count--;\\n            }\\n        }\\n        return ans.toString();\\n    }\\n}","compare_result":"11111111111111111111111111111111111111111","title_slug":"custom-sort-string","has_notes":false,"flag_type":1,"frontend_id":538},{"id":1815386077,"question_id":1236,"lang":"java","lang_name":"Java","time":"4\xc2\xa0months, 3\xc2\xa0weeks","timestamp":1761767458,"status":10,"status_display":"Accepted","runtime":"0 ms","url":"/submissions/detail/1815386077/","is_pending":"Not Pending","title":"N-th Tribonacci Number","memory":"40.6 MB","code":"class Solution {\\n    public int tribonacci(int n) {\\n        if(n<3)\\n        {\\n            return (n==0)?0:1;\\n        }\\n        int a = 0;\\n        int b = 1;\\n        int c = 1;\\n        for(int i = 3 ; i <=n ; i++)\\n        {\\n            int temp1 = b;\\n            int temp2 = a;\\n            a = b;\\n            b = c;