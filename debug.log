-operations-i","has_notes":false,"flag_type":1,"frontend_id":486},{"id":1809383770,"question_id":142,"lang":"java","lang_name":"Java","time":"5\xc2\xa0months","timestamp":1761220104,"status":10,"status_display":"Accepted","runtime":"0 ms","url":"/submissions/detail/1809383770/","is_pending":"Not Pending","title":"Linked List Cycle II","memory":"44.2 MB","code":"/**\\n * Definition for singly-linked list.\\n * class ListNode {\\n *     int val;\\n *     ListNode next;\\n *     ListNode(int x) {\\n *         val = x;\\n *         next = null;\\n *     }\\n * }\\n */\\npublic class Solution {\\n    public ListNode detectCycle(ListNode head) {\\n        if(head == null || head.next == null)\\n        {\\n            return null;\\n        }\\n        ListNode fast = head;\\n        ListNode slow = head;\\n        while(fast!=null && fast.next!= null)\\n        {\\n            fast = fast.next.next;\\n            slow = slow.next;\\n            if(fast == slow)\\n            {\\n                break;\\n            }\\n        }\\n        if(slow != fast)\\n        {\\n            return null;\\n        }\\n\\n        slow = head;\\n        while(slow!=fast)\\n        {\\n            slow = slow.next;\\n            fast = fast.next;\\n        }\\n\\n        return slow;\\n    }\\n}","compare_result":"111111111111111111","title_slug":"linked-list-cycle-ii","has_notes":false,"flag_type":1,"frontend_id":485},{"id":1809383262,"question_id":142,"lang":"java","lang_name":"Java","time":"5\xc2\xa0months","timestamp":1761220057,"status":15,"status_display":"Runtime Error","runtime":"N/A","url":"/submissions/detail/1809383262/","is_pending":"Not Pending","title":"Linked List Cycle II","memory":"N/A","code":"/**\\n * Definition for singly-linked list.\\n * class ListNode {\\n *     int val;\\n *     ListNode next;\\n *     ListNode(int x) {\\n *         val = x;\\n *         next = null;\\n *     }\\n * }\\n */\\npublic class Solution {\\n    public ListNode detectCycle(ListNode head) {\\n        if(head == null || head.next == null)\\n        {\\n            return null;\\n        }\\n        ListNode fast = head;\\n        ListNode slow = head;\\n        while(fast!=null && fast.next!= null)\\n        {\\n            fast = fast.next.next;\\n            slow = slow.next;\\n            if(fast == slow)\\n            {\\n                break;\\n            }\\n        }\\n\\n        slow = head;\\n        while(slow!=fast)\\n        {\\n            slow = slow.next;\\n            fast = fast.next;\\n        }\\n\\n        return slow;\\n    }\\n}","compare_result":"111110000000000000","title_slug":"linked-list-cycle-ii","has_notes":false,"flag_type":1,"frontend_id":484},{"id":1808879495,"question_id":2573,"lang":"java","lang_name":"Java","time":"5\xc2\xa0months","timestamp":1761164590,"status":10,"status_display":"Accepted","runtime":"7 ms","url":"/submissions/detail/1808879495/","is_pending":"Not Pending","title":"Remove Nodes From Linked List","memory":"62.8 MB","code":"/**\\n * Definition for singly-linked list.\\n * public class ListNode {\\n *     int val;\\n *     ListNode next;\\n *     ListNode() {}\\n *     ListNode(int val) { this.val = val; }\\n *     ListNode(int val, ListNode next) { this.val = val; this.next = next; }\\n * }\\n */\\nclass Solution {\\n    public ListNode removeNodes(ListNode head) {\\n        if(head == null)\\n        {\\n            return head;\\n        }\\n        head = reverse(head);\\n        ListNode temp = head;\\n        ArrayList<Integer> list = new ArrayList<>();\\n        int maxsofar = 0;\\n        while(temp!=null)\\n        {\\n            if(temp.val >= maxsofar)\\n            {\\n                list.add(temp.val);\\n                maxsofar = temp.val;\\n            }\\n            temp = temp.next;\\n        }\\n        ListNode head2 = null;\\n        ListNode temp2 = null;\\n        for(int i = list.size()-1 ; i>=0 ; i--)\\n        {\\n            ListNode newNode = new ListNode(list.get(