            if(dup > 0)\\n            {\\n                ans = Math.max(ans,windowEnd-windowStart);\\n                while(dup > 0)\\n                {\\n                    if(map.get(s.charAt(windowStart)) == 2)\\n                    {\\n                        dup--;\\n                    }\\n                    map.put(s.charAt(windowStart),map.getOrDefault(s.charAt(windowStart),0)-1);\\n                    windowStart++;\\n                }\\n            }\\n\\n            ans = Math.max(ans,windowEnd-windowStart+1);\\n            windowEnd++;\\n\\n        }\\n\\n        return ans;\\n\\n    }\\n}","compare_result":"","title_slug":"longest-substring-without-repeating-characters","has_notes":false,"flag_type":1,"frontend_id":959},{"id":1944908127,"question_id":3,"lang":"java","lang_name":"Java","time":"2\xc2\xa0weeks, 1\xc2\xa0day","timestamp":1773226179,"status":11,"status_display":"Wrong Answer","runtime":"N/A","url":"/submissions/detail/1944908127/","is_pending":"Not Pending","title":"Longest Substring Without Repeating Characters","memory":"N/A","code":"class Solution {\\n    public int lengthOfLongestSubstring(String s) {\\n       int dup = 0;\\n       HashMap<Character,Integer> map = new HashMap<>();\\n       int windowStart = 0;\\n       int windowEnd = 0;\\n       int ans = Integer.MIN_VALUE;\\n\\n       while(windowEnd < s.length())\\n       {\\n            map.put(s.charAt(windowEnd),map.getOrDefault(s.charAt(windowEnd),0)+1);\\n            if(map.get(s.charAt(windowEnd)) == 2)\\n            {\\n                dup++;\\n            }\\n\\n            if(dup > 0)\\n            {\\n                ans = Math.max(ans,windowEnd-windowStart);\\n                while(dup > 0)\\n                {\\n                    if(map.get(s.charAt(windowStart)) == 2)\\n                    {\\n                        dup--;\\n                    }\\n                    map.put(s.charAt(windowStart),map.getOrDefault(s.charAt(windowStart),0)-1);\\n                    windowStart++;\\n                }\\n            }\\n\\n            ans = Math.max(ans,windowEnd-windowStart+1);\\n            windowEnd++;\\n\\n        }\\n\\n        return ans;\\n\\n    }\\n}","compare_result":"","title_slug":"longest-substring-without-repeating-characters","has_notes":false,"flag_type":1,"frontend_id":958},{"id":1944890613,"question_id":345,"lang":"java","lang_name":"Java","time":"2\xc2\xa0weeks, 1\xc2\xa0day","timestamp":1773224868,"status":10,"status_display":"Accepted","runtime":"6 ms","url":"/submissions/detail/1944890613/","is_pending":"Not Pending","title":"Reverse Vowels of a String","memory":"47.1 MB","code":"class Solution {\\n    public String reverseVowels(String s) {\\n        int start = 0;\\n        int end = s.length()-1;\\n        StringBuilder sb = new StringBuilder(s);\\n        HashSet<Character> set = new HashSet<>();\\n        set.add(\'a\');\\n        set.add(\'A\');\\n        set.add(\'e\');\\n        set.add(\'E\');\\n        set.add(\'i\');\\n        set.add(\'I\');\\n        set.add(\'O\');\\n        set.add(\'o\');\\n        set.add(\'U\');\\n        set.add(\'u\');\\n\\n       \\n\\n        while(start <= end)\\n        {\\n            char chSt = sb.charAt(start);\\n            char chEn = sb.charAt(end);\\n\\n            if(set.contains(chSt) && set.contains(chEn))\\n            {\\n                swap(start,end,sb);\\n                start++;\\n                end--;\\n            }\\n            else if(!set.contains(chSt))\\n            {\\n                start++;\\n            }\\n\\n            else\\n            {\\n                end--;\\n            }\\n\\n        }\\n\\n         return sb.toString();\\n    }\\n\\n    public static void swap(int start, int end , StringBuilder sb)\\n    {\\n        char temp = sb.charAt(start);\\n        sb.setCharAt(start,sb.charAt(end));\\n        sb.setCharAt(end,temp);\\n    }\\n}","compare_result":"","title_slug":"reverse-vowels-of-a-string","has_notes":false,"flag_type":1,"frontend_id":957},{"id":1944883138,"question_id":1019,"lang":"java","lang_name":"Java","time":"2\xc2\xa0weeks, 1\xc2\xa0day","timestamp":1773224337,"status":10,"status_display":"Accepted","runtime":"10 ms","url":"/submissions/detail/1944883138/","is_pending":"Not Pending","title":"Squares of a Sorted Array","memory":"47.5 MB","code":"class Solution {\\n    public int[] sortedSquares(int[] nums) {\\n        for(int i = 0 ; i < nums.length ; i++)\\n        {\\n            nums[i] = nums[i]*nums[i];\\n        }\\n\\n        Arrays.sort(nums);\\n        return nums;\\n    }\\n}","compare_result":"11111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"squares-of-a-sorted-array","has_notes":false,"flag_type":1,"frontend_id":956},{"id":1944547233,"question_id":167,"lang":"java","lang_name":"Java","time":"2\xc2\xa0weeks, 2\xc2\xa0days","timestamp":1773201474,"status":10,"status_display":"Accepted","runtime":"2 ms","url":"/submissions/detail/1944547233/","is_pending":"Not Pending","title":"Two Sum II - Input Array Is Sorted","memory":"48.6 MB","code":"class Solution {\\n    public int[] twoSum(int[] numbers, int target) {\\n        int start = 0;\\n        int end = numbers.length-1;\\n        int ans[] = new int[2];\\n\\n        while(start < end)\\n        {\\n            if(numbers[start] + numbers[end] == target)\\n            {\\n                ans[0] = start+1;\\n                ans[1] = end+1;\\n                break;\\n            }\\n\\n            else if(numbers[start] + numbers[end] > target)\\n            {\\n                end--;\\n            }\\n\\n            else\\n            {\\n                start++;\\n            }\\n        }\\n\\n        return ans;\\n        \\n    }\\n}","compare_result":"111111111111111111111111","title_slug":"two-sum-ii-input-array-is-sorted","has_notes":false,"flag_type":1,"frontend_id":955},{"id":1943739347,"question_id":46,"lang":"java","lang_name":"Java","time":"2\xc2\xa0weeks, 2\xc2\xa0days","timestamp":1773132892,"status":10,"status_display":"Accepted","runtime":"0 ms","url":"/submissions/detail/1943739347/","is_pending":"Not Pending","title":"Permutations","memory":"45.6 MB","code":"class Solution {\\n    public List<List<Integer>> permute(int[] nums) {\\n        List<List<Integer>> list = new ArrayList<>();\\n        recur(list,nums,0);\\n        return list;\\n    }\\n    public static void recur(List<List<Integer>> list, int[] nums , int index )\\n    {\\n       if(index == nums.length)\\n       {\\n            List<Integer> sublist = new ArrayList<>();\\n            for(int i = 0 ; i < nums.length ; i++)\\n            {\\n                sublist.add(nums[i]);\\n            }\\n            list.add(sublist);\\n            return;\\n       }\\n\\n       for(int i = index ; i < nums.length ; i++)\\n       {\\n            swap(nums,index,i);\\n            recur(list,nums,index+1);\\n            swap(nums,index,i);\\n       }\\n    }\\n\\n    public static void swap(int[] nums, int start , int end)\\n    {\\n        int temp = nums[start];\\n        nums[start] = nums[end];\\n        nums[end] = temp;\\n    }\\n\\n    \\n}","compare_result":"11111111111111111111111111","title_slug":"permutations","has_notes":false,"flag_type":1,"frontend_id":954},{"id":1943718306,"question_id":26,"lang":"java","lang_name":"Java","time":"2\xc2\xa0weeks, 2\xc2\xa0days","timestamp":1773131316,"status":10,"status_display":"Accepted","runtime":"0 ms","url":"/submissions/detail/1943718306/","is_pending":"Not Pending","title":"Remove Duplicates from Sorted Array","memory":"46.9 MB","code":"class Solution {\\n    public int removeDuplicates(int[] nums) {\\n        int index = 0;\\n        int ans = 1;\\n       for(int i = 0 ; i < nums.length ; i++)\\n       {\\n            if(nums[i] != nums[index])\\n            {\\n                index++;\\n                nums[index] = nums[i];\\n                ans++;\\n            }\\n       }\\n\\n       return ans;\\n    }\\n}","compare_result":"","title_slug":"remove-duplicates-from-sorted-array","has_notes":false,"flag_type":1,"frontend_id":953},{"id":1943561423,"question_id":344,"lang":"java","lang_name":"Java","time":"2\xc2\xa0weeks, 3\xc2\xa0days","timestamp":1773120067,"status":10,"status_display":"Accepted","runtime":"0 ms","url":"/submissions/detail/1943561423/","is_pending":"Not Pending","title":"Reverse String","memory":"48.4 MB","code":"class Solution {\\n    public void reverseString(char[] s) {\\n        int start = 0;\\n        int end = s.length-1;\\n        while(start < end)\\n        {\\n            char firstchar = s[start];\\n            char lastchar = s[end];\\n            s[start] = lastchar;\\n            s[end] = firstchar;\\n            start++;\\n            end--;\\n\\n        }\\n        \\n    }\\n\\n    \\n\\n}","compare_result":"","title_slug":"reverse-string","has_notes":false,"flag_type":1,"frontend_id":952}],"has_next":true,"last_key":""}'
