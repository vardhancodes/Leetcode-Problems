ay":"Accepted","runtime":"1 ms","url":"/submissions/detail/1803576190/","is_pending":"Not Pending","title":"Transpose Matrix","memory":"44.5 MB","code":"class Solution {\\n    public int[][] transpose(int[][] matrix) {\\n        int ans[][] = new int[matrix[0].length][matrix.length];\\n        for(int i = 0; i < matrix.length ; i++)\\n        {\\n            for(int j = 0 ; j < matrix[i].length ; j++)\\n            {\\n                ans[j][i] = matrix[i][j];\\n            }\\n        }\\n\\n        return ans;\\n    }\\n}","compare_result":"111111111111111111111111111111111111","title_slug":"transpose-matrix","has_notes":false,"flag_type":1,"frontend_id":443},{"id":1802712138,"question_id":3619,"lang":"java","lang_name":"Java","time":"5\xc2\xa0months, 1\xc2\xa0week","timestamp":1760552791,"status":10,"status_display":"Accepted","runtime":"17 ms","url":"/submissions/detail/1802712138/","is_pending":"Not Pending","title":"Adjacent Increasing Subarrays Detection II","memory":"89 MB","code":"class Solution {\\n    public int maxIncreasingSubarrays(List<Integer> nums){\\n        int cnt = 1;\\n        int prevcnt = 0;\\n        int ans = 0 ; \\n        for(int i = 1 ; i < nums.size() ; i++)\\n        {\\n            if(nums.get(i) > nums.get(i-1))\\n            {\\n                cnt++;\\n            }\\n            else\\n            {\\n                prevcnt = cnt;\\n                cnt = 1;\\n            }\\n            ans = Math.max(ans,Math.min(prevcnt,cnt));\\n            ans = Math.max(ans,cnt/2);\\n        }\\n\\n        return ans;\\n\\n        \\n    \\n\\n    }\\n\\n\\n    \\n}","compare_result":"","title_slug":"adjacent-increasing-subarrays-detection-ii","has_notes":false,"flag_type":1,"frontend_id":442},{"id":1801689528,"question_id":3619,"lang":"java","lang_name":"Java","time":"5\xc2\xa0months, 1\xc2\xa0week","timestamp":1760465026,"status":14,"status_display":"Time Limit Exceeded","runtime":"N/A","url":"/submissions/detail/1801689528/","is_pending":"Not Pending","title":"Adjacent Increasing Subarrays Detection II","memory":"N/A","code":"class Solution {\\n    public int maxIncreasingSubarrays(List<Integer> nums) {\\n        int start = 1;\\n        int end = nums.size()/2;\\n        int ans = 0;\\n        while(start <= end)\\n        {\\n            int mid = start+(end-start)/2;\\n            if(isIncreasing(nums,mid))\\n            {\\n                ans = mid;\\n                start = mid+1;\\n            }\\n            else\\n            {\\n                end = mid-1;\\n            }\\n        }\\n        return ans;\\n    }\\n\\n    public static boolean isIncreasing(List<Integer> list , int mid)\\n    {\\n        int k = mid*2;\\n        for(int i = 0 ; i <= list.size()-k ; i++)\\n        {\\n            //first half\\n            boolean first = true;\\n            boolean second = true;\\n            for(int j = i ; j < i+mid-1 ; j++)\\n            {\\n                if(list.get(j) >= list.get(j+1))\\n                {\\n                    first = false;\\n                    break;\\n\\n                }\\n            }\\n            //second half\\n            for(int s = i+mid ; s < i+k-1  ; s++)\\n            {\\n                if(list.get(s) >= list.get(s+1))\\n                {\\n                    second = false;\\n                    break;\\n\\n                }\\n            }\\n            if(first &&  second)\\n            {\\n                return true;\\n            }\\n        }\\n        return false;\\n\\n    }\\n}","compare_result":"","title_slug":"adjacent-increasing-subarrays-detection-ii","has_notes":false,"flag_type":1,"frontend_id":441},{"id":1801533345,"question_id":3612,"lang":"java","lang_name":"Java","time":"5\xc2\xa0months, 1\xc2\xa0week","timestamp":1760456708,"status":10,"status_display":"Accepted","runtime":"1 ms","url":"/submissions/detail/1801533345/","is_pending":"Not Pending","title":"Adjacent Increasing Subarrays Detection I","memory":"45.2 MB","code":"clas